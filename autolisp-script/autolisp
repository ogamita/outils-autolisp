#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOU'
Usage:
  autolisp [--autocad|--bricscad] { source.lsp | -x expression }... [--dwg file.dwg] [--main C:MAIN]

Examples:
  autolisp test.lsp
  autolisp lib1.lsp lib2.lsp --main C:RUN
  autolisp -x '(princ (+ 1 2))'
  autolisp init.lsp -x '(setq *x* 42)' test.lsp

Semantics:
  - Les éléments { source.lsp | -x expression } sont traités dans l'ordre.
  - Chaque source.lsp est chargé avec (load "...").
  - Chaque -x expression est évalué dans le contexte AutoLISP.
  - Si au moins un fichier source.lsp est fourni, (${MAIN:-C:MAIN}) est appelé à la fin,
    sauf si --main '' est explicitement utilisé pour le désactiver.

Outputs:
  stdout  -> résultats et résumé produits par le runner
  stderr  -> erreurs AutoLISP capturées par le runner
  exit    -> code lu dans STATUSFILE

Environment overrides:
  AUTOCAD_ACCORECONSOLE   Path to accoreconsole.exe (Windows)
  BRICSCAD_EXE            Path to bricscad.exe      (Windows)
  AUTOLISP_DWG            Default DWG for AutoCAD Core Console if --dwg not provided
  AUTOLISP_WAIT_SECS      Timeout for macOS UI fallback (default: 180)
  AUTOLISP_KEEP_WORKDIR   Set to 1 to keep temp workdir
  AUTOLISP_VERBOSE        Set to 1 for diagnostics
EOU
}

ENGINE=""
DWG=""
MAIN="C:MAIN"

# Internal action encoding: LOAD:<abs-path> | EVAL:<raw-expression>
declare -a ACTIONS=()

die() {
  echo "$*" >&2
  exit 2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --autocad)
      ENGINE="autocad"
      shift
      ;;
    --bricscad)
      ENGINE="bricscad"
      shift
      ;;
    --dwg)
      [[ $# -ge 2 ]] || die "Missing argument after --dwg"
      DWG="$2"
      shift 2
      ;;
    --main)
      [[ $# -ge 2 ]] || die "Missing argument after --main"
      MAIN="$2"
      shift 2
      ;;
    -x)
      [[ $# -ge 2 ]] || die "Missing expression after -x"
      ACTIONS+=("EVAL:$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        ACTIONS+=("LOAD:$1")
        shift
      done
      break
      ;;
    -*)
      die "Unknown option: $1"
      ;;
    *)
      ACTIONS+=("LOAD:$1")
      shift
      ;;
  esac
done

[[ ${#ACTIONS[@]} -gt 0 ]] || die "Missing input: provide at least one source.lsp or -x expression"

OS="$(uname -s || true)"
IS_WINDOWS=0
case "$OS" in
  MINGW*|MSYS*|CYGWIN*) IS_WINDOWS=1 ;;
esac

if [[ -z "$ENGINE" ]]; then
  if [[ $IS_WINDOWS -eq 1 ]]; then
    if [[ -n "${AUTOCAD_ACCORECONSOLE:-}" ]] || compgen -G "/c/Program Files/Autodesk/*/accoreconsole.exe" >/dev/null; then
      ENGINE="autocad"
    elif [[ -n "${BRICSCAD_EXE:-}" ]] || compgen -G "/c/Program Files*/Bricsys/*/bricscad.exe" >/dev/null; then
      ENGINE="bricscad"
    else
      echo "No engine found. Use --autocad or --bricscad and set AUTOCAD_ACCORECONSOLE / BRICSCAD_EXE." >&2
      exit 3
    fi
  else
    ENGINE="bricscad"
  fi
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_AUTOLISP_WORKDIR="$SCRIPT_DIR/.autolisp-runs"
BASE_WORKDIR="${AUTOLISP_WORKDIR:-$DEFAULT_AUTOLISP_WORKDIR}"
mkdir -p "$BASE_WORKDIR"
WORKDIR="$(mktemp -d "$BASE_WORKDIR/autolisp.XXXXXX")"

CLEANUP_WORKDIR="${AUTOLISP_KEEP_WORKDIR:-0}"
AUTOLISP_VERBOSE="${AUTOLISP_VERBOSE:-0}"
INTERRUPTED=0
MACOS_ASYNC=0

on_interrupt() {
  INTERRUPTED=1
  CLEANUP_WORKDIR=1
  echo "autolisp: interrupt requested; keeping workdir: $WORKDIR" >&2
}

cleanup_workdir() {
  if [[ "$CLEANUP_WORKDIR" != "1" ]]; then
    rm -rf "$WORKDIR"
  elif [[ "$AUTOLISP_VERBOSE" == "1" || "$INTERRUPTED" == "1" ]]; then
    echo "autolisp: keeping workdir: $WORKDIR" >&2
  fi
}
trap cleanup_workdir EXIT
trap on_interrupt INT TERM

OUTFILE="$WORKDIR/output.txt"
ERRFILE="$WORKDIR/errors.txt"
STATUSFILE="$WORKDIR/status.txt"
: >"$OUTFILE"
: >"$ERRFILE"
echo "__PENDING__" >"$STATUSFILE"

escape_lisp_string() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

to_abs_path() {
  local p="$1"
  local dir base
  dir="$(cd "$(dirname "$p")" && pwd)"
  base="$(basename "$p")"
  printf '%s/%s' "$dir" "$base"
}

to_lisp_path() {
  local p="$1"
  p="${p//\\//}"
  printf '%s' "$p"
}

# Resolve loads now and build search path list.
declare -a SEARCH_DIRS=()
declare -a RESOLVED_ACTIONS=()
HAS_LOAD_ACTION=0

for action in "${ACTIONS[@]}"; do
  kind="${action%%:*}"
  value="${action#*:}"
  if [[ "$kind" == "LOAD" ]]; then
    [[ -f "$value" ]] || die "Not found: $value"
    abs_src="$(to_abs_path "$value")"
    abs_src="$(to_lisp_path "$abs_src")"
    RESOLVED_ACTIONS+=("LOAD:$abs_src")
    abs_dir="$(dirname "$abs_src")"
    HAS_LOAD_ACTION=1

    present=0
    for existing in "${SEARCH_DIRS[@]:-}"; do
      if [[ "$existing" == "$abs_dir" ]]; then
        present=1
        break
      fi
    done
    [[ $present -eq 1 ]] || SEARCH_DIRS+=("$abs_dir")
  else
    RESOLVED_ACTIONS+=("$action")
  fi
done

RUNLSPFILE="$WORKDIR/run-common.lsp"
{
  echo ";;; Auto-generated by autolisp-improved-bricscad25"
  echo '(setq _autolisp_old_srchpath (getvar "SRCHPATH"))'
  if [[ ${#SEARCH_DIRS[@]} -gt 0 ]]; then
    srch_prefix=""
    for dir in "${SEARCH_DIRS[@]}"; do
      srch_prefix+="$(escape_lisp_string "$dir");"
    done
    printf '(setvar "SRCHPATH" (strcat "%s" _autolisp_old_srchpath))\n' "$srch_prefix"
  fi
  printf '(setq *AUTOLISP_OUTFILE* "%s")\n' "$(escape_lisp_string "$OUTFILE")"
  printf '(setq *AUTOLISP_ERRFILE* "%s")\n' "$(escape_lisp_string "$ERRFILE")"
  printf '(setq *AUTOLISP_STATUSFILE* "%s")\n' "$(escape_lisp_string "$STATUSFILE")"
  printf '(setq *AUTOLISP_HAS_LOAD_ACTION* %s)\n' "$HAS_LOAD_ACTION"
  printf '(setq *AUTOLISP_MAIN_SYMBOL* "%s")\n' "$(escape_lisp_string "$MAIN")"

  cat <<'EOLISP'
(defun autolisp--write-line (path text / f)
  (setq f (open path "a"))
  (if f
    (progn
      (write-line text f)
      (close f)
      T)
    nil))

(defun autolisp--stringify (x)
  (cond
    ((= (type x) 'STR) x)
    (T (vl-princ-to-string x))))

(defun autolisp-out (x)
  (autolisp--write-line *AUTOLISP_OUTFILE* (autolisp--stringify x)))

(defun autolisp-err (x)
  (autolisp--write-line *AUTOLISP_ERRFILE* (autolisp--stringify x)))

(defun autolisp-set-status (code / f)
  (setq f (open *AUTOLISP_STATUSFILE* "w"))
  (if f
    (progn
      (write-line (itoa code) f)
      (close f)
      T)
    nil))

(defun autolisp-finalize (code)
  (if _autolisp_old_srchpath
    (setvar "SRCHPATH" _autolisp_old_srchpath))
  (autolisp-set-status code)
  (quit))

(setq *AUTOLISP_TOTAL* 0)
(setq *AUTOLISP_OK* 0)
(setq *AUTOLISP_FAIL* 0)
(setq *AUTOLISP_ERROR* 0)

(defun autolisp-run-expr (expr-text / form result)
  (setq *AUTOLISP_TOTAL* (+ *AUTOLISP_TOTAL* 1))
  (autolisp-out (strcat "EVAL " expr-text))
  (setq form (read expr-text))
  ;; Correct BricsCAD/Visual LISP calling convention:
  ;;   (vl-catch-all-apply 'function (list args...))
  (setq result (vl-catch-all-apply 'eval (list form)))
  (if (vl-catch-all-error-p result)
    (progn
      (setq *AUTOLISP_ERROR* (+ *AUTOLISP_ERROR* 1))
      (autolisp-err (strcat "ERROR " (vl-catch-all-error-message result)))
      nil)
    (progn
      (setq *AUTOLISP_OK* (+ *AUTOLISP_OK* 1))
      (autolisp-out (strcat "RESULT " (vl-princ-to-string result)))
      T)))

(defun autolisp-run-load (path / result)
  (setq *AUTOLISP_TOTAL* (+ *AUTOLISP_TOTAL* 1))
  (autolisp-out (strcat "LOAD " path))
  (setq result (vl-catch-all-apply 'load (list path)))
  (if (vl-catch-all-error-p result)
    (progn
      (setq *AUTOLISP_ERROR* (+ *AUTOLISP_ERROR* 1))
      (autolisp-err (strcat "ERROR load " path ": " (vl-catch-all-error-message result)))
      nil)
    (progn
      (setq *AUTOLISP_OK* (+ *AUTOLISP_OK* 1))
      T)))

(defun autolisp-call-main (main-name / sym result)
  (if (or (null main-name) (= main-name ""))
    T
    (progn
      (setq *AUTOLISP_TOTAL* (+ *AUTOLISP_TOTAL* 1))
      (autolisp-out (strcat "CALL " main-name))
      (setq sym (read main-name))
      (setq result (vl-catch-all-apply sym '()))
      (if (vl-catch-all-error-p result)
        (progn
          (setq *AUTOLISP_ERROR* (+ *AUTOLISP_ERROR* 1))
          (autolisp-err (strcat "ERROR call " main-name ": " (vl-catch-all-error-message result)))
          nil)
        (progn
          (setq *AUTOLISP_OK* (+ *AUTOLISP_OK* 1))
          (autolisp-out (strcat "RESULT " (vl-princ-to-string result)))
          T)))))

(setq *AUTOLISP_STOP* nil)
EOLISP

  for action in "${RESOLVED_ACTIONS[@]}"; do
    kind="${action%%:*}"
    value="${action#*:}"
    if [[ "$kind" == "LOAD" ]]; then
      printf '(if (not *AUTOLISP_STOP*) (if (not (autolisp-run-load "%s")) (setq *AUTOLISP_STOP* T)))\n' "$(escape_lisp_string "$value")"
    else
      printf '(if (not *AUTOLISP_STOP*) (if (not (autolisp-run-expr "%s")) (setq *AUTOLISP_STOP* T)))\n' "$(escape_lisp_string "$value")"
    fi
  done

  cat <<'EOLISP'
(if (and (not *AUTOLISP_STOP*) (= *AUTOLISP_HAS_LOAD_ACTION* 1))
  (if (not (autolisp-call-main *AUTOLISP_MAIN_SYMBOL*))
    (setq *AUTOLISP_STOP* T)))

(autolisp-out
  (strcat
    "TOTAL=" (itoa *AUTOLISP_TOTAL*)
    " OK=" (itoa *AUTOLISP_OK*)
    " FAIL=" (itoa *AUTOLISP_FAIL*)
    " ERROR=" (itoa *AUTOLISP_ERROR*)))

(if *AUTOLISP_STOP*
  (autolisp-finalize 1)
  (autolisp-finalize 0))
EOLISP
} > "$RUNLSPFILE"

SCRFILE="$WORKDIR/run.scr"
cat > "$SCRFILE" <<EOF2
(load "$(escape_lisp_string "$RUNLSPFILE")")
EOF2

export OUTFILE ERRFILE STATUSFILE

run_windows_autocad() {
  local acc="${AUTOCAD_ACCORECONSOLE:-}"
  if [[ -z "$acc" ]]; then
    acc="$(ls -1 "/c/Program Files/Autodesk"/*/accoreconsole.exe 2>/dev/null | head -n 1 || true)"
  fi
  if [[ -z "$acc" || ! -f "$acc" ]]; then
    echo "accoreconsole.exe not found. Set AUTOCAD_ACCORECONSOLE." >&2
    return 3
  fi

  local dwg="${DWG:-${AUTOLISP_DWG:-}}"
  if [[ -z "$dwg" || ! -f "$dwg" ]]; then
    echo "AutoCAD Core Console needs a DWG. Provide --dwg file.dwg or set AUTOLISP_DWG." >&2
    return 2
  fi

  "$acc" /i "$dwg" /s "$SCRFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
}

run_windows_bricscad() {
  local exe="${BRICSCAD_EXE:-}"
  if [[ -z "$exe" ]]; then
    exe="$(ls -1 "/c/Program Files"*/Bricsys/*/bricscad.exe 2>/dev/null | head -n 1 || true)"
  fi
  if [[ -z "$exe" || ! -f "$exe" ]]; then
    echo "bricscad.exe not found. Set BRICSCAD_EXE." >&2
    return 3
  fi

  "$exe" /B "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
}

run_macos_bricscad_fallback() {
  local app=""
  app="$(ls -1d /Applications/BricsCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "BricsCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  local appname
  appname="$(basename "$app" .app)"
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  export AUTOLISP_LISP_CMD="$lisp_cmd"
  export AUTOLISP_APPNAME="$appname"
  /usr/bin/osascript <<'OSA' || true
set appName to system attribute "AUTOLISP_APPNAME"
tell application appName to activate
delay 1
tell application "System Events"
  key code 53
  key code 53
  delay 0.15
  set lispCmd to system attribute "AUTOLISP_LISP_CMD"
  keystroke lispCmd
  key code 36
end tell
OSA
}

run_macos_autocad_fallback() {
  local app=""
  app="$(ls -1d /Applications/Autodesk*/AutoCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "AutoCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi

  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  export AUTOLISP_LISP_CMD="$lisp_cmd"

  /usr/bin/osascript <<'OSA' || true
tell application "AutoCAD" to activate
delay 1
tell application "System Events"
  key code 53
  key code 53
  delay 0.15
  set lispCmd to system attribute "AUTOLISP_LISP_CMD"
  keystroke lispCmd
  key code 36
end tell
OSA
}

wait_for_macos_async() {
  local timeout="${AUTOLISP_WAIT_SECS:-180}"
  while [[ "$timeout" -gt 0 ]]; do
    local s
    s="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    if [[ -n "$s" && "$s" != "__PENDING__" ]]; then
      return 0
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  return 0
}

case "$ENGINE" in
  autocad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_autocad || true
    else
      run_macos_autocad_fallback || true
    fi
    ;;
  bricscad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_bricscad || true
    else
      run_macos_bricscad_fallback || true
    fi
    ;;
  *)
    echo "Unknown engine: $ENGINE" >&2
    exit 2
    ;;
esac

if [[ "$MACOS_ASYNC" -eq 1 ]]; then
  if [[ -z "${AUTOLISP_KEEP_WORKDIR:-}" ]]; then
    CLEANUP_WORKDIR=1
  fi
  wait_for_macos_async
fi

if [[ "$INTERRUPTED" -eq 1 ]]; then
  exit 130
fi

cat "$OUTFILE" || true
cat "$ERRFILE" >&2 || true

STATUS="1"
if [[ -s "$STATUSFILE" ]]; then
  STATUS="$(awk 'NF{line=$0} END{print line}' "$STATUSFILE" | tr -d '[:space:]')"
fi
if ! [[ "$STATUS" =~ ^[0-9]+$ ]]; then
  summary="$(awk '/^TOTAL=/{line=$0} END{print line}' "$OUTFILE" 2>/dev/null || true)"
  if [[ -n "$summary" && "$summary" =~ FAIL=0[[:space:]]+ERROR=0$ ]]; then
    STATUS=0
  else
    STATUS=1
  fi
fi
exit "$STATUS"
