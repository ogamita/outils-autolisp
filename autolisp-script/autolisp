#!/usr/bin/env bash
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
# Shell-side helpers for the future remote I/O protocol.
. "$SELF_DIR/lib/autolisp-remote-io.sh"
VERSION_FILE="$SELF_DIR/VERSION.TXT"
if [[ -f "$VERSION_FILE" ]]; then
  # shellcheck source=/dev/null
  . "$VERSION_FILE"
fi

autolisp_version_string() {
  printf 'autolisp %s.%s.%s\n' "${VERSION_MAJOR:-0}" "${VERSION_MINOR:-0}" "${VERSION_PATCH:-0}"
}

usage() {
  cat <<'EOU'
Usage:
  autolisp -V|--version | -h|--help
  autolisp [options]... { [-l|--load] source.lsp | -x|--eval expression | -i|--interactive | --main C:MAIN | --quit }...

  Les options d'action peuvent être mélangées à volonté et sont traitées dans l'ordre.

Examples:
  autolisp test.lsp
  autolisp -l lib1.lsp -l lib2.lsp --main C:RUN
  autolisp --bricscad --epure test.lsp
  autolisp -x '(princ (+ 1 2))'
  autolisp --eval '(setq *x* 42)' test.lsp
  autolisp -i

Semantics:
  - Les actions { [-l|--load] source.lsp | -x|--eval expression } sont traitées dans l'ordre.
  - Chaque source.lsp est chargé avec (load "...").
  - Chaque -x|--eval expression est évaluée comme une forme AutoLISP.
  - Si au moins un fichier source.lsp est fourni, (${MAIN:-C:MAIN}) est appelé à la fin.
  - --quit termine le moteur et autolisp ; les options suivantes sont ignorées.

Outputs:
  stdout  -> contenu de OUTFILE
  stderr  -> contenu de ERRFILE
  exit    -> code lu dans STATUSFILE

Generic options:
  -V, --version           Affiche la version puis quitte.
  -h, --help              Affiche ce message d'aide puis quitte.
  -q, --quiet             Supprime les messages d'information non essentiels.
  -v, --verbose           Affiche les labels structurés et davantage de diagnostics.
  -norc, --no-init        Inhibe le chargement de ~/.autolisp{,rc}{,.lsp}.

Action options (processed in order):
  -l, --load FILE         Charger un fichier AutoLISP (load).
  -x, --eval EXPRESSION   Évaluer une forme AutoLISP.
  -i, --interactive       Active le mode REPL.
  --main C:MAIN           Nom de la commande appelée après les actions.
  --quit                  Force la sortie ; ignore les options suivantes.

Engine options:
  --autocad               Force le moteur AutoCAD.
  --bricscad              Force le moteur BricsCAD.
  --dwg FILE              DWG fourni au Core Console AutoCAD.

Specific options:
  --epure                 Sous Windows, charge EPURE avant le script principal.
                          BricsCAD: lance /P Epure avec le bootstrap
                          %APPDATA%\sncf\epure\epure 2022_b\control_path_epure_2022.scr
                          AutoCAD: lance /p Epure avec le bootstrap
                          %APPDATA%\sncf\epure\epure 2022\control_path_epure_2022.scr
                          Avec AutoCAD, cette option requiert AUTOCAD_EXE.

Technical options:
  --timeout N             Durée maximale d'attente du runtime CAD.
  --bootstrap-phase PHASE marker | core | log | full
  --mode MODE             automation | batch (BricsCAD macOS)
  --backend BACKEND       attach | launch (mode automation macOS)
  --bricscad-macos-profile NAME   Profil BricsCAD pour le mode batch macOS.

Environment overrides:
  AUTOCAD_ACCORECONSOLE   Path to accoreconsole.exe (Windows)
  AUTOCAD_COM_MODE        auto | attach | launch | off   (Windows + AutoCAD only)
  AUTOCAD_EXE             Path to acad.exe / acadlt.exe  (Windows)
  BRICSCAD_EXE            Path to bricscad.exe      (Windows)
  AUTOLISP_MODE           auto | automation | batch
  AUTOLISP_BACKEND        attach | launch
  BRICSCAD_MACOS_PROFILE  BricsCAD profile name     (macOS + BricsCAD batch only)
  AUTOLISP_BOOTSTRAP_PHASE marker | core | log | full
  AUTOLISP_DWG            Default DWG for AutoCAD Core Console if --dwg not provided
  BRICSCAD_COM_MODE       auto | attach | launch | off   (Windows + BricsCAD only)
  AUTOLISP_EPURE         1 to launch CAD with EPURE on Windows
  AUTOLISP_TIMEOUT        Legacy timeout override in seconds
  AUTOLISP_WAIT_SECS      wait timeout for async modes / COM bridge (default: 180)
  AUTOLISP_KEEP_WORKDIR   1 to keep temporary workdir
  AUTOLISP_VERBOSE        1 for extra diagnostics
  AUTOLISP_QUIET          1 to suppress informational messages

Notes:
  - AutoCAD Core Console (accoreconsole.exe) est Windows-only dans la pratique.
  - --epure n'a d'effet que sous Windows.
  - Sous Windows + BricsCAD, le script peut utiliser un pont COM autonome généré dans le workdir.
  - Sous macOS, le fallback reste piloté par UI scripting et dépend des autorisations Accessibilité.
EOU
}

ENGINE=""
DWG=""
MAIN="C:MAIN"
MAIN_REQUESTED=0
TIMEOUT_SECS="${AUTOLISP_WAIT_SECS:-${AUTOLISP_TIMEOUT:-180}}"
AUTOCAD_COM_MODE="${AUTOCAD_COM_MODE:-auto}"
AUTOCAD_EXE="${AUTOCAD_EXE:-}"
BRICSCAD_EXE="${BRICSCAD_EXE:-C:/Program Files/Bricsys/BricsCAD V25 fr_FR/bricscad.exe}"
CAD_MODE="${AUTOLISP_MODE:-auto}"
CAD_BACKEND="${AUTOLISP_BACKEND:-launch}"
BRICSCAD_MACOS_PROFILE="${BRICSCAD_MACOS_PROFILE:-}"
EPURE_REQUESTED="${AUTOLISP_EPURE:-0}"
AUTOLISP_REMOTE_IO_MODE="${AUTOLISP_REMOTE_IO_MODE:-auto}"
BOOTSTRAP_PHASE="${AUTOLISP_BOOTSTRAP_PHASE:-full}"
INTERACTIVE=0
CLI_VERBOSE=0
CLI_QUIET=0
VERSION_ONLY=0
NO_INIT=0
QUIT_REQUESTED=0

declare -a ACTION_KINDS=()
declare -a ACTION_VALUES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --autocad)
      ENGINE="autocad"
      shift
      ;;
    --bricscad)
      ENGINE="bricscad"
      shift
      ;;
    --timeout)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --timeout" >&2
        usage
        exit 2
      fi
      TIMEOUT_SECS="$2"
      shift 2
      ;;
    --bootstrap-phase)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bootstrap-phase" >&2
        usage
        exit 2
      fi
      BOOTSTRAP_PHASE="$2"
      shift 2
      ;;
    --mode)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --mode" >&2
        usage
        exit 2
      fi
      CAD_MODE="$2"
      shift 2
      ;;
    --backend)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --backend" >&2
        usage
        exit 2
      fi
      CAD_BACKEND="$2"
      shift 2
      ;;
    --bricscad-macos-profile)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bricscad-macos-profile" >&2
        usage
        exit 2
      fi
      BRICSCAD_MACOS_PROFILE="$2"
      shift 2
      ;;
    --epure)
      EPURE_REQUESTED=1
      shift
      ;;
    -V|--version)
      VERSION_ONLY=1
      shift
      ;;
    -norc|--no-init)
      NO_INIT=1
      shift
      ;;
    --quit)
      QUIT_REQUESTED=1
      shift
      break
      ;;
    --dwg)
      DWG="${2:-}"
      shift 2
      ;;
    --main)
      MAIN="${2:-}"
      MAIN_REQUESTED=1
      shift 2
      ;;
    -i|--interactive)
      INTERACTIVE=1
      shift
      ;;
    -v|--verbose)
      CLI_VERBOSE=1
      shift
      ;;
    -q|--quiet)
      CLI_QUIET=1
      shift
      ;;
    -x|--eval)
      if [[ $# -lt 2 ]]; then
        echo "Missing expression after $1" >&2
        usage
        exit 2
      fi
      ACTION_KINDS+=("eval")
      ACTION_VALUES+=("$2")
      shift 2
      ;;
    -l|--load)
      if [[ $# -lt 2 ]]; then
        echo "Missing file after $1" >&2
        usage
        exit 2
      fi
      ACTION_KINDS+=("load")
      ACTION_VALUES+=("$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        ACTION_KINDS+=("load")
        ACTION_VALUES+=("$1")
        shift
      done
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      ACTION_KINDS+=("load")
      ACTION_VALUES+=("$1")
      shift
      ;;
  esac
done

if [[ "$VERSION_ONLY" -eq 1 ]]; then
  autolisp_version_string
  exit 0
fi

interactive_form_complete() {
  local form="$1"
  perl -e '
my $s = shift;
my ($depth, $in_string, $escape, $in_comment, $started) = (0, 0, 0, 0, 0);
foreach my $ch (split //, $s) {
  if ($in_comment) {
    $in_comment = 0 if $ch eq "\n";
    next;
  }
  if ($in_string) {
    $started = 1;
    if ($escape) {
      $escape = 0;
      next;
    }
    if ($ch eq "\\") {
      $escape = 1;
      next;
    }
    if ($ch eq "\"") {
      $in_string = 0;
    }
    next;
  }
  if ($ch eq ";") {
    $in_comment = 1;
    next;
  }
  if ($ch =~ /\s/) {
    next;
  }
  $started = 1;
  if ($ch eq "\"") {
    $in_string = 1;
    next;
  }
  if ($ch eq "(") {
    $depth++;
    next;
  }
  if ($ch eq ")") {
    $depth-- if $depth > 0;
    next;
  }
}
exit(($started && !$in_string && !$in_comment && $depth == 0) ? 0 : 1);
' -- "$form"
}

interactive_print_response() {
  local stdout_file="$1"
  local stderr_file="$2"
  local stdout_block result_line emitted=0

  stdout_block="$(
    awk '
    BEGIN { capture = 0 }
    /^OUTPUT$/ { capture = 1; next }
    /^RESULT / { capture = 0 }
    capture { print }
    ' "$stdout_file"
  )"
  result_line="$(awk '/^RESULT /{sub(/^RESULT /, ""); print; exit}' "$stdout_file")"

  if autolisp_is_verbose; then
    printf 'STDOUT\n'
    if [[ -n "$stdout_block" ]]; then
      printf '%s\n' "$stdout_block"
    fi

    printf 'STDERR\n'
    if [[ -s "$stderr_file" ]]; then
      cat "$stderr_file"
    fi

    printf 'RESULT\n'
    if [[ -n "$result_line" ]]; then
      printf '%s\n' "$result_line"
    fi
    printf '\n'
    return 0
  fi

  if [[ -n "$stdout_block" ]]; then
    printf '%s\n' "$stdout_block"
    emitted=1
  fi

  if [[ -s "$stderr_file" ]]; then
    cat "$stderr_file"
    emitted=1
  fi

  if [[ -n "$result_line" ]]; then
    printf '%s\n' "$result_line"
    emitted=1
  fi

  if [[ "$emitted" -eq 1 ]]; then
    printf '\n'
  fi
}

write_atomic_file() {
  autolisp_protocol_write_atomic_file "$1" "$2"
}

read_status_file() {
  if [[ -f "$STATUSFILE" ]]; then
    awk 'NF{line=$0} END{print line}' "$STATUSFILE" 2>/dev/null || true
  fi
}

batch_runner_done_without_status() {
  local current_status="$1"
  local batch_rc=""
  if [[ "$BRICSCAD_BATCH_COMPLETED" -eq 1 ]]; then
    if [[ -z "$current_status" || "$current_status" == "__PENDING__" || "$current_status" == "99" ]]; then
      CLEANUP_WORKDIR="1"
      FORCE_REPORT_WORKDIR="1"
      batch_rc="$BRICSCAD_BATCH_RC"
      autolisp_error "BricsCAD batch process exited before writing a final status."
      if [[ -n "$batch_rc" ]]; then
        autolisp_error "BricsCAD batch exit code: $batch_rc"
      fi
      autolisp_hint "the startup script may not have run, or (load \"$RUNLSPFILE\") failed before autolisp initialized."
      autolisp_verbose_dump_file "$WORKDIR/bricscad-stderr.txt"
      return 0
    fi
  fi
  if [[ "$BRICSCAD_BATCH_LAUNCHED" -eq 1 ]]; then
    if ! bricscad_batch_process_running; then
      reap_bricscad_batch_process || true
      if [[ -z "$current_status" || "$current_status" == "__PENDING__" || "$current_status" == "99" ]]; then
        CLEANUP_WORKDIR="1"
        FORCE_REPORT_WORKDIR="1"
        batch_rc="$BRICSCAD_BATCH_RC"
        autolisp_error "BricsCAD batch process exited before writing a final status."
        if [[ -n "$batch_rc" ]]; then
          autolisp_error "BricsCAD batch exit code: $batch_rc"
        fi
        autolisp_hint "the startup script may not have run, or (load \"$RUNLSPFILE\") failed before autolisp initialized."
        autolisp_verbose_dump_file "$WORKDIR/bricscad-stderr.txt"
        return 0
      fi
    fi
  fi
  return 1
}

batch_startup_stalled() {
  local current_status="$1"
  local now elapsed

  [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]] || return 1
  [[ "$BRICSCAD_BATCH_LAUNCHED" -eq 1 && "$BRICSCAD_BATCH_START_TS" -gt 0 ]] || return 1
  [[ "$current_status" == "__PENDING__" ]] || return 1
  [[ ! -s "$OUTFILE" && ! -s "$ERRFILE" ]] || return 1
  bricscad_batch_process_running || return 1

  now="$(date +%s 2>/dev/null || echo 0)"
  [[ "$now" =~ ^[0-9]+$ ]] || return 1
  elapsed=$((now - BRICSCAD_BATCH_START_TS))
  [[ "$elapsed" -ge "$BRICSCAD_BATCH_STARTUP_TIMEOUT_SECS" ]] || return 1

  CLEANUP_WORKDIR="1"
  FORCE_REPORT_WORKDIR="1"
  autolisp_error "BricsCAD batch launch stayed pending for ${BRICSCAD_BATCH_STARTUP_TIMEOUT_SECS}s without running the startup script."
  autolisp_hint "on this macOS setup, BricsCAD likely ignored the requested startup file before AutoLISP initialized."
  if [[ -n "$BRICSCAD_BATCH_COMMAND_FILE" && -f "$BRICSCAD_BATCH_COMMAND_FILE" ]]; then
    autolisp_verbose_note "DETAIL: status.txt stayed '__PENDING__' and no output or error file was produced."
    autolisp_verbose_note "DETAIL: attempted launch command:"
    autolisp_verbose_dump_file "$BRICSCAD_BATCH_COMMAND_FILE"
  fi
  kill_bricscad_batch_process || true
  return 0
}

wait_for_status_value() {
  local expected="$1"
  local timeout="$TIMEOUT_SECS"
  local current
  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi
    current="$(read_status_file)"
    if [[ "$current" == "$expected" ]]; then
      return 0
    fi
    if batch_startup_stalled "$current"; then
      return 124
    fi
    if batch_runner_done_without_status "$current"; then
      return 1
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  autolisp_error "timeout waiting for status '$expected' after ${TIMEOUT_SECS}s"
  return 124
}

wait_for_protocol_ready() {
  local timeout="$TIMEOUT_SECS"
  local protocol_status legacy_status

  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi

    protocol_status="$(autolisp_protocol_read_status)"
    case "$protocol_status" in
      READY*|WAITING-INPUT*)
        return 0
        ;;
      FAILED*)
        autolisp_error "protocol runtime failed during startup: $protocol_status"
        return 1
        ;;
    esac

    legacy_status="$(read_status_file)"
    if batch_startup_stalled "$legacy_status"; then
      return 124
    fi
    if batch_runner_done_without_status "$legacy_status"; then
      return 1
    fi

    sleep 1
    timeout=$((timeout - 1))
  done

  autolisp_error "timeout waiting for protocol runtime readiness after ${TIMEOUT_SECS}s"
  return 124
}

wait_for_protocol_status_prefix() {
  local expected_prefix="$1"
  local timeout="$TIMEOUT_SECS"
  local protocol_status legacy_status

  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi

    protocol_status="$(autolisp_protocol_read_status)"
    case "$protocol_status" in
      "$expected_prefix"|"$expected_prefix "*) return 0 ;;
      FAILED*)
        autolisp_error "protocol runtime failed: $protocol_status"
        return 1
        ;;
    esac

    legacy_status="$(read_status_file)"
    if batch_startup_stalled "$legacy_status"; then
      return 124
    fi
    if batch_runner_done_without_status "$legacy_status"; then
      return 1
    fi

    sleep 1
    timeout=$((timeout - 1))
  done

  autolisp_error "timeout waiting for protocol status '$expected_prefix' after ${TIMEOUT_SECS}s"
  return 124
}

wait_for_batch_process_exit() {
  local timeout="$TIMEOUT_SECS"
  [[ "$BRICSCAD_BATCH_LAUNCHED" -eq 1 ]] || return 0

  while [[ "$timeout" -gt 0 ]]; do
    if ! bricscad_batch_process_running; then
      reap_bricscad_batch_process || true
      return 0
    fi
    sleep 1
    timeout=$((timeout - 1))
  done

  autolisp_error "BricsCAD batch process did not exit after writing its final status within ${TIMEOUT_SECS}s."
  return 124
}

PROTOCOL_REQUEST_SEQ=0
PROTOCOL_REQUEST_SEQFILE=""
PROTOCOL_CLIENT_REQ_ID=0
PROTOCOL_STREAM_OUT_LINES=0
PROTOCOL_STREAM_ERR_LINES=0
PROTOCOL_STREAM_OUTPUT_OPEN=0
PROTOCOL_STREAMED_OUTPUT=0
PROTOCOL_FOREGROUND_RELAY_PID=""
PROTOCOL_LAST_REQUEST_QUIT=0
PROTOCOL_INTERACTIVE_HELPER_PID=""
PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN=0

protocol_new_request_slot() {
  local seq=0

  if [[ -n "$PROTOCOL_REQUEST_SEQFILE" && -f "$PROTOCOL_REQUEST_SEQFILE" ]]; then
    seq="$(awk 'NF{line=$0} END{print line}' "$PROTOCOL_REQUEST_SEQFILE" 2>/dev/null || echo 0)"
  fi
  if ! [[ "$seq" =~ ^[0-9]+$ ]]; then
    seq=0
  fi
  seq=$((seq + 1))
  if [[ -n "$PROTOCOL_REQUEST_SEQFILE" ]]; then
    printf '%s\n' "$seq" >"$PROTOCOL_REQUEST_SEQFILE"
  fi
  printf -v PROTOCOL_REQUEST_TAG '%03d' "$seq"
}

build_protocol_eval_request() {
  local form_text="$1"
  local eval_file request_file lisp_eval_file

  protocol_new_request_slot
  eval_file="$WORKDIR/protocol-eval-$PROTOCOL_REQUEST_TAG.lsp"
  request_file="$WORKDIR/protocol-request-$PROTOCOL_REQUEST_TAG.lsp"
  lisp_eval_file="$(to_runtime_lisp_path "$eval_file")"

  printf '%s' "$form_text" >"$eval_file"
  {
    printf '(autolisp-request-reset)\n'
    printf '(if (autolisp-run-eval-file 1 "%s") (autolisp-note-ok) (autolisp-note-fail))\n' \
      "$(escape_lisp_string "$lisp_eval_file")"
    printf '(autolisp-request-exit-code)\n'
  } >"$request_file"

  printf '%s\n' "$request_file"
}

build_protocol_actions_request() {
  local request_file idx kind abs_src eval_src

  protocol_new_request_slot
  request_file="$WORKDIR/protocol-request-$PROTOCOL_REQUEST_TAG.lsp"

  {
    printf '(autolisp-request-reset)\n'
    for idx in "${!ACTION_KINDS[@]}"; do
      kind="${ACTION_KINDS[$idx]}"
      if [[ "$kind" == "load" ]]; then
        abs_src="${LOAD_PATHS[$idx]}"
        printf '(if (autolisp-run-load %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' \
          "$((idx + 1))" "$(escape_lisp_string "$abs_src")"
      else
        eval_src="${EVAL_PATHS[$idx]}"
        printf '(if (autolisp-run-eval-file %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' \
          "$((idx + 1))" "$(escape_lisp_string "$eval_src")"
      fi
    done
    if [[ "$HAS_LOAD_ACTION" -eq 1 ]]; then
      printf '(if (= *AUTOLISP_FAIL* 0) (if (autolisp-run-main %s "%s") (autolisp-note-ok) (autolisp-note-fail)))\n' \
        "$(( ${#ACTION_KINDS[@]} + 1 ))" "$(escape_lisp_string "$MAIN")"
    fi
    printf '(autolisp-request-exit-code)\n'
  } >"$request_file"

  printf '%s\n' "$request_file"
}

build_protocol_main_request() {
  local request_file

  protocol_new_request_slot
  request_file="$WORKDIR/protocol-request-$PROTOCOL_REQUEST_TAG.lsp"

  {
    printf '(autolisp-request-reset)\n'
    printf '(if (= *AUTOLISP_FAIL* 0) (if (autolisp-run-main %s "%s") (autolisp-note-ok) (autolisp-note-fail)))\n' \
      "$(( ${#ACTION_KINDS[@]} + 1 ))" "$(escape_lisp_string "$MAIN")"
    printf '(autolisp-request-exit-code)\n'
  } >"$request_file"

  printf '%s\n' "$request_file"
}

build_protocol_noninteractive_startup_payload() {
  local request_file payload_file lisp_request_file

  request_file="$(build_protocol_actions_request)"
  payload_file="$WORKDIR/protocol-startup.lsp"
  lisp_request_file="$(to_runtime_lisp_path "$request_file")"

  {
    printf '(progn\n'
    printf '  (load "%s")\n' "$(escape_lisp_string "$lisp_request_file")"
    printf '  (setq *AUTOLISP_PROTOCOL_STOP* T)\n'
    printf '  (if (> *AUTOLISP_FAIL* 0) 1 0))\n'
  } >"$payload_file"

  cat "$payload_file"
}

prime_protocol_noninteractive_startup() {
  local payload

  payload="$(build_protocol_noninteractive_startup_payload)"
  autolisp_protocol_send_stdin "$payload"
}

submit_protocol_request_file() {
  local request_file="$1"
  local load_form lisp_request_file
  local stream_output=1

  PROTOCOL_CLIENT_REQ_ID=$((PROTOCOL_CLIENT_REQ_ID + 1))
  PROTOCOL_LAST_REQUEST_QUIT=0
  lisp_request_file="$(to_runtime_lisp_path "$request_file")"
  load_form="$(printf '(load "%s")\n' "$(escape_lisp_string "$lisp_request_file")")"
  if [[ "$INTERACTIVE" -eq 1 && "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 0 ]]; then
    stream_output=1
  else
    stream_output=0
  fi
  protocol_stream_request_reset
  autolisp_protocol_send_stdin "$load_form"
  wait_for_protocol_request_done "$PROTOCOL_CLIENT_REQ_ID" "$stream_output"
  if [[ "$INTERACTIVE" -eq 0 ]]; then
    protocol_flush_request_updates
  fi
}

shutdown_protocol_session() {
  autolisp_protocol_send_control "SHUTDOWN"
  wait_for_protocol_status_prefix "STOPPED" || return $?
  wait_for_batch_process_exit
}

protocol_stream_request_reset() {
  PROTOCOL_STREAM_OUT_LINES=0
  PROTOCOL_STREAM_ERR_LINES=0
  PROTOCOL_STREAM_OUTPUT_OPEN=0
  if [[ -n "${PROTOCOL_STREAM_MARKER:-}" ]]; then
    rm -f "$PROTOCOL_STREAM_MARKER"
  fi
}

protocol_emit_out_line() {
  local line="$1"

  PROTOCOL_STREAMED_OUTPUT=1
  if [[ -n "${PROTOCOL_STREAM_MARKER:-}" ]]; then
    : >"$PROTOCOL_STREAM_MARKER"
  fi

  case "$line" in
    LOAD\ *|EVAL\ *|MAIN\ *)
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      fi
      ;;
    '<<<AUTOLISP-STDOUT>>>'*)
      if autolisp_is_verbose && [[ "$PROTOCOL_STREAM_OUTPUT_OPEN" -eq 0 ]]; then
        printf 'OUTPUT\n'
        PROTOCOL_STREAM_OUTPUT_OPEN=1
      fi
      printf '%s\n' "${line#<<<AUTOLISP-STDOUT>>>}"
      ;;
    LOADED\ *)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    RESULT\ *)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      else
        printf '%s\n' "${line#RESULT }"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    MAIN-RESULT\ *)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      else
        printf '%s\n' "${line#MAIN-RESULT }"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    TOTAL=*)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    *)
      printf '%s\n' "$line"
      ;;
  esac
}

protocol_flush_out_updates() {
  local total_lines new_lines line

  [[ -f "$OUTFILE" ]] || return 0
  total_lines="$(wc -l <"$OUTFILE" 2>/dev/null || echo 0)"
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
  if [[ "$total_lines" -lt "$PROTOCOL_STREAM_OUT_LINES" ]]; then
    PROTOCOL_STREAM_OUT_LINES=0
    PROTOCOL_STREAM_OUTPUT_OPEN=0
  fi
  if [[ "$total_lines" -le "$PROTOCOL_STREAM_OUT_LINES" ]]; then
    return 0
  fi
  new_lines="$(awk -v start="$((PROTOCOL_STREAM_OUT_LINES + 1))" 'NR >= start { print }' "$OUTFILE")"
  while IFS= read -r line; do
    protocol_emit_out_line "$line"
  done <<<"$new_lines"
  PROTOCOL_STREAM_OUT_LINES="$total_lines"
}

protocol_flush_err_updates() {
  local total_lines new_lines line

  [[ -f "$ERRFILE" ]] || return 0
  total_lines="$(wc -l <"$ERRFILE" 2>/dev/null || echo 0)"
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
  if [[ "$total_lines" -lt "$PROTOCOL_STREAM_ERR_LINES" ]]; then
    PROTOCOL_STREAM_ERR_LINES=0
  fi
  if [[ "$total_lines" -le "$PROTOCOL_STREAM_ERR_LINES" ]]; then
    return 0
  fi
  new_lines="$(awk -v start="$((PROTOCOL_STREAM_ERR_LINES + 1))" 'NR >= start { print }' "$ERRFILE")"
  while IFS= read -r line; do
    PROTOCOL_STREAMED_OUTPUT=1
    if [[ -n "${PROTOCOL_STREAM_MARKER:-}" ]]; then
      : >"$PROTOCOL_STREAM_MARKER"
    fi
    printf '%s\n' "$line" >&2
  done <<<"$new_lines"
  PROTOCOL_STREAM_ERR_LINES="$total_lines"
}

protocol_flush_request_updates() {
  protocol_flush_out_updates
  protocol_flush_err_updates
}

protocol_feed_waiting_input() {
  local line

  IFS= read -r line || return 1
  autolisp_protocol_send_stdin "$line"$'\n'
}

wait_for_protocol_request_done() {
  local req_id="$1"
  local stream_output="${2:-1}"
  local current_status=""
  local legacy_status=""
  local start_ts now elapsed

  start_ts="$(date +%s 2>/dev/null || echo 0)"
  while true; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi

    if [[ "$stream_output" -eq 1 ]]; then
      protocol_flush_request_updates
    fi
    current_status="$(autolisp_protocol_read_status)"
    if [[ "$current_status" == "DONE $req_id" || "$current_status" == "DONE $req_id "* ]]; then
      if [[ "$current_status" == "DONE $req_id QUIT" ]]; then
        PROTOCOL_LAST_REQUEST_QUIT=1
      fi
      if [[ "$stream_output" -eq 1 ]]; then
        protocol_flush_request_updates
      fi
      return 0
    fi
    if [[ "$current_status" == "STOPPED" ]]; then
      legacy_status="$(read_status_file)"
      if [[ "$legacy_status" == "0" ]]; then
        PROTOCOL_LAST_REQUEST_QUIT=1
        return 0
      fi
    fi
    if [[ "$current_status" == "FAILED READ" || "$current_status" == "STOPPED" ]]; then
      if [[ "$stream_output" -eq 1 ]]; then
        protocol_flush_request_updates
      fi
      return 1
    fi
    if [[ "$current_status" == "WAITING-INPUT" ]]; then
      if ! protocol_feed_waiting_input; then
        autolisp_error "stdin closed while AutoLISP was waiting for input."
        return 1
      fi
      continue
    fi
    if batch_startup_stalled "$current_status"; then
      return 124
    fi
    if batch_runner_done_without_status "$current_status"; then
      return 1
    fi

    now="$(date +%s 2>/dev/null || echo 0)"
    if [[ "$start_ts" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ ]]; then
      elapsed=$((now - start_ts))
      if [[ "$elapsed" -ge "$TIMEOUT_SECS" ]]; then
        autolisp_error "timeout waiting for protocol request $req_id after ${TIMEOUT_SECS}s"
        return 124
      fi
    fi
    sleep 0.1
  done
}

protocol_foreground_relay_loop() {
  local current_status=""
  local line=""

  protocol_stream_request_reset
  while true; do
    protocol_flush_request_updates
    current_status="$(autolisp_protocol_read_status)"
    case "$current_status" in
      DONE*)
        protocol_flush_request_updates
        protocol_stream_request_reset
        ;;
      STOPPED|FAILED*)
        protocol_flush_request_updates
        return 0
        ;;
      WAITING-INPUT)
        if [[ -r /dev/tty ]]; then
          IFS= read -r line </dev/tty || return 1
          autolisp_protocol_send_stdin "$line"$'\n'
          continue
        fi
        ;;
    esac
    sleep 0.1
  done
}

start_protocol_foreground_relay() {
  [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]] || return 0
  PROTOCOL_STREAM_MARKER="$WORKDIR/protocol-streamed.flag"
  rm -f "$PROTOCOL_STREAM_MARKER"
  protocol_foreground_relay_loop &
  PROTOCOL_FOREGROUND_RELAY_PID=$!
}

stop_protocol_foreground_relay() {
  [[ -n "$PROTOCOL_FOREGROUND_RELAY_PID" ]] || return 0
  kill "$PROTOCOL_FOREGROUND_RELAY_PID" 2>/dev/null || true
  wait "$PROTOCOL_FOREGROUND_RELAY_PID" 2>/dev/null || true
  PROTOCOL_FOREGROUND_RELAY_PID=""
}

start_protocol_interactive_helper() {
  [[ "$USE_REMOTE_PROTOCOL" -eq 1 && "$INTERACTIVE" -eq 1 && "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]] || return 0
  exec 9<&0
  PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN=1
  run_protocol_interactive_repl <&9 &
  PROTOCOL_INTERACTIVE_HELPER_PID=$!
}

wait_protocol_interactive_helper() {
  local rc=0
  [[ -n "$PROTOCOL_INTERACTIVE_HELPER_PID" ]] || return 0
  if wait "$PROTOCOL_INTERACTIVE_HELPER_PID"; then
    rc=0
  else
    rc=$?
  fi
  PROTOCOL_INTERACTIVE_HELPER_PID=""
  if [[ "$PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN" -eq 1 ]]; then
    exec 9<&-
    PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN=0
  fi
  return "$rc"
}

run_protocol_noninteractive() {
  local request_file kind form_text

  wait_for_protocol_ready || return $?
  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      form_text="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      form_text="${ACTION_VALUES[$idx]}"
    fi
    request_file="$(build_protocol_eval_request "$form_text")"
    submit_protocol_request_file "$request_file" || return $?
  done
  if [[ "$MAIN_REQUESTED" -eq 1 ]]; then
    request_file="$(build_protocol_main_request)"
    submit_protocol_request_file "$request_file" || return $?
  fi
  shutdown_protocol_session
}

run_protocol_interactive_repl() {
  local prompt cont_prompt line buffer request_file rendered_file kind form_text idx

  prompt="autolisp> "
  cont_prompt="......> "
  wait_for_protocol_ready || return $?

  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      form_text="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      form_text="${ACTION_VALUES[$idx]}"
    fi
    request_file="$(build_protocol_eval_request "$form_text")"
    submit_protocol_request_file "$request_file" || return $?
    if [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 0 ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    elif [[ ! -f "${PROTOCOL_STREAM_MARKER:-}" ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    fi
  done

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    request_file="$(build_protocol_eval_request "$buffer")"
    submit_protocol_request_file "$request_file" || return $?
    if [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 0 ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    elif [[ ! -f "${PROTOCOL_STREAM_MARKER:-}" ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    fi
    if [[ "$PROTOCOL_LAST_REQUEST_QUIT" -eq 1 ]]; then
      printf 'Bye bye!\n'
      wait_for_protocol_status_prefix "STOPPED" || true
      wait_for_batch_process_exit || true
      return 0
    fi
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi

  shutdown_protocol_session
}

run_interactive_repl() {
  local self prompt cont_prompt line buffer case_dir stdout_file stderr_file kind action_form idx
  declare -a repl_args=()

  self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  prompt="autolisp> "
  cont_prompt="......> "
  [[ -n "$ENGINE" ]] && repl_args+=("--$ENGINE")
  repl_args+=("--timeout" "$TIMEOUT_SECS")
  if autolisp_is_quiet; then
    repl_args+=("--quiet")
  elif autolisp_is_verbose; then
    repl_args+=("--verbose")
  fi
  [[ -n "$DWG" ]] && repl_args+=("--dwg" "$DWG")
  repl_args+=("--mode" "$CAD_MODE" "--backend" "$CAD_BACKEND")
  if [[ "$ENGINE" == "bricscad" && -n "$BRICSCAD_MACOS_PROFILE" ]]; then
    repl_args+=("--bricscad-macos-profile" "$BRICSCAD_MACOS_PROFILE")
  fi
  if [[ "$EPURE_REQUESTED" == "1" ]]; then
    repl_args+=("--epure")
  fi

  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      action_form="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      action_form="${ACTION_VALUES[$idx]}"
    fi
    case_dir="$(mktemp -d "${TMPDIR:-/tmp}/autolisp-repl.XXXXXX")"
    stdout_file="$case_dir/stdout.txt"
    stderr_file="$case_dir/stderr.txt"
    AUTOLISP_SUPPRESS_VERSION_BANNER=1 "$self" "${repl_args[@]}" -x "$action_form" >"$stdout_file" 2>"$stderr_file" || true
    interactive_print_response "$stdout_file" "$stderr_file"
    rm -rf "$case_dir"
  done

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    case_dir="$(mktemp -d "${TMPDIR:-/tmp}/autolisp-repl.XXXXXX")"
    stdout_file="$case_dir/stdout.txt"
    stderr_file="$case_dir/stderr.txt"

    AUTOLISP_SUPPRESS_VERSION_BANNER=1 "$self" "${repl_args[@]}" -x "$buffer" >"$stdout_file" 2>"$stderr_file" || true
    interactive_print_response "$stdout_file" "$stderr_file"
    rm -rf "$case_dir"
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi
  return 0
}

run_batch_interactive_repl() {
  local prompt cont_prompt line buffer req_id payload rendered_file kind action_form idx
  prompt="autolisp> "
  cont_prompt="......> "
  req_id=0

  if ! wait_for_status_value "READY 0"; then
    return $?
  fi

  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      action_form="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      action_form="${ACTION_VALUES[$idx]}"
    fi
    req_id=$((req_id + 1))
    payload=";REQ $req_id"$'\n'"$action_form"$'\n'
    write_atomic_file "$INPFILE" "$payload"
    if ! wait_for_status_value "READY $req_id"; then
      return $?
    fi
    rendered_file="$WORKDIR/interactive-rendered.txt"
    render_stdout "$OUTFILE" "" 1 >"$rendered_file"
    interactive_print_response "$rendered_file" "$ERRFILE"
  done

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    req_id=$((req_id + 1))
    payload=";REQ $req_id"$'\n'"$buffer"$'\n'
    write_atomic_file "$INPFILE" "$payload"

    if ! wait_for_status_value "READY $req_id"; then
      return $?
    fi

    rendered_file="$WORKDIR/interactive-rendered.txt"
    render_stdout "$OUTFILE" "" 1 >"$rendered_file"
    interactive_print_response "$rendered_file" "$ERRFILE"
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi

  req_id=$((req_id + 1))
  payload=";REQ $req_id"$'\n'"'__AUTOLISP_QUIT__"$'\n'
  write_atomic_file "$INPFILE" "$payload"
  wait_for_status_value "STOP $req_id" || true
  # BricsCAD macOS batch shutdown is crash-prone, so terminate the launched PID
  # from the wrapper instead of asking BricsCAD to run its own _QUIT path.
  kill_bricscad_batch_process || true
  return 0
}

if [[ "$INTERACTIVE" -eq 1 && "$BOOTSTRAP_PHASE" != "full" ]]; then
  echo "Interactive mode requires --bootstrap-phase full." >&2
  exit 2
fi

OS="${AUTOLISP_OS:-$(uname -s || true)}"
IS_WINDOWS=0
case "$OS" in
  MINGW*|MSYS*|CYGWIN*) IS_WINDOWS=1 ;;
esac
IS_MACOS=0
case "$OS" in
  Darwin) IS_MACOS=1 ;;
esac

if [[ -z "${ENGINE}" ]]; then
  if [[ $IS_WINDOWS -eq 1 ]]; then
    if [[ -n "${AUTOCAD_EXE:-}" || -n "${AUTOCAD_ACCORECONSOLE:-}" ]] || compgen -G "/c/Program Files/Autodesk/*/accoreconsole.exe" >/dev/null; then
      ENGINE="autocad"
    elif [[ -n "${BRICSCAD_EXE:-}" ]] || compgen -G "/c/Program Files*/Bricsys/*/bricscad.exe" >/dev/null; then
      ENGINE="bricscad"
    else
      echo "No engine found. Use --autocad or --bricscad and set AUTOCAD_EXE / AUTOCAD_ACCORECONSOLE / BRICSCAD_EXE." >&2
      exit 3
    fi
  else
    ENGINE="bricscad"
  fi
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_AUTOLISP_WORKDIR="$SCRIPT_DIR/.autolisp-runs"
BASE_WORKDIR=""
CLEANUP_WORKDIR="${AUTOLISP_KEEP_WORKDIR:-0}"
AUTOLISP_VERBOSE="${AUTOLISP_VERBOSE:-0}"
AUTOLISP_QUIET="${AUTOLISP_QUIET:-0}"
INTERRUPTED=0
INTERRUPT_COUNT=0
MACOS_ASYNC=0
BRICSCAD_BRIDGE_MODE="direct"
BRICSCAD_COM_ATTACHED=0
BRICSCAD_COM_CREATED=0
BRICSCAD_COM_MODE="${BRICSCAD_COM_MODE:-auto}"
BRICSCAD_MACOS_EFFECTIVE_MODE=""
BRICSCAD_BATCH_PID=""
BRICSCAD_BATCH_CHILD_PID=""
BRICSCAD_BATCH_LAUNCHED=0
BRICSCAD_BATCH_RC=""
BRICSCAD_BATCH_REAPED=0
BRICSCAD_BATCH_COMPLETED=0
BRICSCAD_BATCH_START_TS=0
BRICSCAD_BATCH_STARTUP_TIMEOUT_SECS="${AUTOLISP_BRICSCAD_BATCH_STARTUP_TIMEOUT:-15}"

case "$CAD_MODE" in
  automation)
    AUTOCAD_COM_MODE="$CAD_BACKEND"
    BRICSCAD_COM_MODE="$CAD_BACKEND"
    ;;
  batch)
    AUTOCAD_COM_MODE="off"
    BRICSCAD_COM_MODE="off"
    ;;
esac

if [[ "$EPURE_REQUESTED" == "1" && $IS_WINDOWS -eq 1 ]]; then
  if [[ "$ENGINE" == "bricscad" ]]; then
    BRICSCAD_COM_MODE="off"
  elif [[ "$ENGINE" == "autocad" ]]; then
    AUTOCAD_COM_MODE="off"
  fi
fi

BRICSCAD_BATCH_COMMAND_FILE=""
EXPERIMENTAL_MACOS_BATCH_OPEN="${AUTOLISP_EXPERIMENTAL_MACOS_BATCH_OPEN:-0}"
FORCE_REPORT_WORKDIR=0
AUTOLISP_VERBOSITY=1
BRICSCAD_LAUNCH_ANNOUNCER_PID=""

if [[ "$AUTOLISP_VERBOSE" =~ ^[1-9][0-9]*$ ]]; then
  AUTOLISP_VERBOSITY=2
fi
if [[ "$AUTOLISP_QUIET" == "1" ]]; then
  AUTOLISP_VERBOSITY=0
fi
if [[ "$CLI_VERBOSE" -eq 1 ]]; then
  AUTOLISP_VERBOSITY=2
fi
if [[ "$CLI_QUIET" -eq 1 ]]; then
  AUTOLISP_VERBOSITY=0
fi

autolisp_is_quiet() {
  [[ "$AUTOLISP_VERBOSITY" -le 0 ]]
}

autolisp_is_verbose() {
  [[ "$AUTOLISP_VERBOSITY" -ge 2 ]]
}

autolisp_error() {
  printf 'ERROR: %s\n' "$*" >&2
}

autolisp_hint() {
  autolisp_is_quiet && return 0
  printf 'HINT: %s\n' "$*" >&2
}

autolisp_verbose_note() {
  autolisp_is_verbose || return 0
  printf '%s\n' "$*" >&2
}

autolisp_verbose_dump_file() {
  local file="$1"
  [[ -s "$file" ]] || return 0
  autolisp_is_verbose || return 0
  cat "$file" >&2
}

on_interrupt() {
  INTERRUPT_COUNT=$((INTERRUPT_COUNT + 1))
  if [[ "$INTERRUPT_COUNT" -ge 2 ]]; then
    CLEANUP_WORKDIR="1"
    kill_bricscad_batch_process || true
    echo "autolisp: second interrupt received; aborting now." >&2
    exit 130
  fi
  INTERRUPTED=1
  CLEANUP_WORKDIR="1"
  kill_bricscad_batch_process || true
  echo "autolisp: interrupt requested; keeping workdir and finishing current handshake..." >&2
}

cleanup_workdir() {
  if [[ "${CLEANUP_WORKDIR}" != "1" ]]; then
    rm -rf "$WORKDIR"
  else
    if ! autolisp_is_quiet && [[ "$INTERRUPTED" == "1" || "$FORCE_REPORT_WORKDIR" == "1" ]]; then
      echo "autolisp: keeping workdir: $WORKDIR" >&2
    fi
  fi
}
trap cleanup_workdir EXIT
trap on_interrupt INT TERM

reap_bricscad_batch_process() {
  local rc=0
  if [[ "$BRICSCAD_BATCH_LAUNCHED" -ne 1 || "$BRICSCAD_BATCH_REAPED" -eq 1 ]]; then
    return 0
  fi
  if [[ -z "$BRICSCAD_BATCH_CHILD_PID" ]]; then
    BRICSCAD_BATCH_REAPED=1
    return 0
  fi
  if wait "$BRICSCAD_BATCH_CHILD_PID" 2>/dev/null; then
    rc=0
  else
    rc=$?
    if [[ "$rc" -eq 127 ]]; then
      rc=0
    fi
  fi
  BRICSCAD_BATCH_RC="$rc"
  BRICSCAD_BATCH_REAPED=1
  return 0
}

find_macos_bricscad_app() {
  ls -1d /Applications/BricsCAD*.app 2>/dev/null | head -n 1 || true
}

find_macos_bricscad_cli() {
  if [[ -n "${BRICSCAD_EXE:-}" && -f "${BRICSCAD_EXE}" ]]; then
    printf '%s\n' "$BRICSCAD_EXE"
    return 0
  fi

  local app
  app="$(find_macos_bricscad_app)"
  if [[ -n "$app" && -x "$app/Contents/MacOS/bricscad" ]]; then
    printf '%s\n' "$app/Contents/MacOS/bricscad"
    return 0
  fi

  return 1
}

find_macos_app_bundle_from_exe() {
  local exe="$1"
  if [[ "$exe" == *.app ]]; then
    printf '%s\n' "$exe"
    return 0
  fi
  if [[ "$exe" == */Contents/MacOS/* ]]; then
    printf '%s.app\n' "${exe%/Contents/MacOS/*}"
    return 0
  fi
  return 1
}

read_macos_bundle_version() {
  local bundle="$1"
  local plist="$bundle/Contents/Info.plist"
  [[ -f "$plist" ]] || return 1
  /usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' "$plist" 2>/dev/null || true
}

read_bricscad_runtime_info() {
  local product="" version="" program=""

  [[ -f "${AUTOLISP_PROTOCOL_INFOFILE:-}" ]] || return 1
  product="$(sed -n '1p' "$AUTOLISP_PROTOCOL_INFOFILE" 2>/dev/null || true)"
  version="$(sed -n '2p' "$AUTOLISP_PROTOCOL_INFOFILE" 2>/dev/null || true)"
  program="$(sed -n '3p' "$AUTOLISP_PROTOCOL_INFOFILE" 2>/dev/null || true)"
  if [[ -z "$product" && -z "$version" && -z "$program" ]]; then
    return 1
  fi
  printf '%s\t%s\t%s\n' "$product" "$version" "$program"
}

normalize_bricscad_version() {
  local raw="$1"
  local normalized=""

  normalized="$(printf '%s\n' "$raw" | awk '{ print $1; exit }')"
  if [[ -n "$normalized" ]]; then
    printf '%s\n' "$normalized"
    return 0
  fi
  [[ -n "$raw" ]] || return 1
  printf '%s\n' "$raw"
}

bricscad_version_for_exe() {
  local info=""
  local exe="$1"
  local bundle=""
  local version=""

  info="$(read_bricscad_runtime_info || true)"
  if [[ -n "$info" ]]; then
    version="$(printf '%s\n' "$info" | awk -F '\t' '{ print $2; exit }')"
    normalize_bricscad_version "$version"
    return $?
  fi
  bundle="$(find_macos_app_bundle_from_exe "$exe" || true)"
  if [[ -n "$bundle" ]]; then
    read_macos_bundle_version "$bundle"
    return 0
  fi
  return 1
}

bricscad_should_announce_launch() {
  local exe="$1"
  [[ "$ENGINE" == "bricscad" ]] || return 1
  autolisp_is_quiet && return 1
  [[ "$INTERACTIVE" -eq 1 ]] || return 1
  case "$exe" in
    */BricsCAD*.app/Contents/MacOS/bricscad|*/BricsCAD*.app)
      return 0
      ;;
  esac
  return 1
}

emit_bricscad_launch_message() {
  local pid="$1"
  local exe="$2"
  local info=""
  local product="BricsCAD"
  local version=""
  local version_raw=""
  local program=""
  local msg=""

  bricscad_should_announce_launch "$exe" || return 0
  [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] || return 0

  info="$(read_bricscad_runtime_info || true)"
  if [[ -n "$info" ]]; then
    product="$(printf '%s\n' "$info" | awk -F '\t' '{ print $1; exit }')"
    version_raw="$(printf '%s\n' "$info" | awk -F '\t' '{ print $2; exit }')"
    version="$(normalize_bricscad_version "$version_raw" || true)"
    program="$(printf '%s\n' "$info" | awk -F '\t' '{ print $3; exit }')"
  else
    version="$(bricscad_version_for_exe "$exe" || true)"
  fi
  [[ -n "$product" ]] || product="BricsCAD"
  msg="autolisp: launched $product"
  if [[ -n "$version" ]]; then
    msg="$msg $version"
  fi
  msg="$msg pid=$pid"
  if autolisp_is_verbose; then
    if [[ -n "$version_raw" && "$version_raw" != "$version" ]]; then
      msg="$msg acadver=\"$version_raw\""
    fi
    if [[ -n "$program" ]]; then
      msg="$msg program=$program"
    fi
    msg="$msg profile=${BRICSCAD_MACOS_PROFILE:-default}"
  fi
  echo "$msg" >&2
}

launch_bricscad_announce_loop() {
  local exe="$1"
  local pid=""
  local tries=0

  bricscad_should_announce_launch "$exe" || return 0
  while [[ "$tries" -lt 300 ]]; do
    pid="$(find_bricscad_batch_pid || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && read_bricscad_runtime_info >/dev/null 2>&1; then
      emit_bricscad_launch_message "$pid" "$exe"
      return 0
    fi
    sleep 0.1
    tries=$((tries + 1))
  done
  return 0
}

start_bricscad_launch_announcer() {
  local exe="$1"
  bricscad_should_announce_launch "$exe" || return 0
  launch_bricscad_announce_loop "$exe" &
  BRICSCAD_LAUNCH_ANNOUNCER_PID=$!
}

stop_bricscad_launch_announcer() {
  [[ -n "$BRICSCAD_LAUNCH_ANNOUNCER_PID" ]] || return 0
  wait "$BRICSCAD_LAUNCH_ANNOUNCER_PID" 2>/dev/null || true
  BRICSCAD_LAUNCH_ANNOUNCER_PID=""
}

find_bricscad_batch_pid() {
  local pid

  pid="$(
    ps -axo pid=,command= 2>/dev/null \
      | awk -v scr="$SCRFILE" '
          index($0, scr) {
            sub(/^[[:space:]]+/, "", $0)
            split($0, fields, /[[:space:]]+/)
            print fields[1]
            exit
          }'
  )"
  if [[ "$pid" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$pid"
    return 0
  fi
  return 1
}

bricscad_batch_process_running() {
  local pid

  if [[ -n "$BRICSCAD_BATCH_PID" ]] && kill -0 "$BRICSCAD_BATCH_PID" 2>/dev/null; then
    return 0
  fi

  pid="$(find_bricscad_batch_pid || true)"
  if [[ "$pid" =~ ^[0-9]+$ ]]; then
    BRICSCAD_BATCH_PID="$pid"
    return 0
  fi

  return 1
}

macos_app_running() {
  local appname="$1"
  local running
  running="$(
    /usr/bin/osascript - "$appname" <<'OSA' 2>/dev/null || true
on run argv
  set appName to item 1 of argv
  tell application "System Events"
    if exists process appName then
      return "1"
    end if
  end tell
  return "0"
end run
OSA
  )"
  [[ "$running" == "1" ]]
}

escape_lisp_string() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

to_abs_path() {
  local p="$1"
  local dir base
  dir="$(cd "$(dirname "$p")" && pwd)"
  base="$(basename "$p")"
  printf '%s/%s' "$dir" "$base"
}

to_lisp_path() {
  local p="$1"
  p="${p//\\//}"
  printf '%s' "$p"
}

to_windows_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$p"
  elif [[ "$p" =~ ^/([a-zA-Z])/(.*)$ ]]; then
    local drive rest
    drive="${BASH_REMATCH[1]}"
    rest="${BASH_REMATCH[2]}"
    rest="${rest//\//\\}"
    printf '%s:\\%s' "${drive^^}" "$rest"
  else
    printf '%s' "$p"
  fi
}

to_unix_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -u "$p"
  elif [[ "$p" =~ ^([A-Za-z]):\\(.*)$ ]]; then
    local drive rest
    drive="${BASH_REMATCH[1]}"
    rest="${BASH_REMATCH[2]//\\//}"
    printf '/%s/%s' "${drive,,}" "$rest"
  else
    printf '%s' "$p"
  fi
}

to_runtime_lisp_path() {
  local p="$1"
  if [[ $IS_WINDOWS -eq 1 ]]; then
    p="$(to_windows_path "$p")"
  fi
  to_lisp_path "$p"
}

escape_vbs_string() {
  local s="$1"
  s=${s//\"/\"\"}
  printf '%s' "$s"
}

windows_epure_control_script() {
  local engine="$1"
  local appdata="${APPDATA:-}"
  local relative=""
  local candidate=""

  if [[ -z "$appdata" ]] && command -v cmd.exe >/dev/null 2>&1; then
    appdata="$(cmd.exe /c 'echo %APPDATA%' 2>/dev/null | tr -d '\r' || true)"
  fi
  [[ -n "$appdata" ]] || return 1

  case "$engine" in
    bricscad)
      relative="sncf\\epure\\epure 2022_b\\control_path_epure_2022.scr"
      ;;
    autocad)
      relative="sncf\\epure\\epure 2022\\control_path_epure_2022.scr"
      ;;
    *)
      return 1
      ;;
  esac

  candidate="$appdata\\$relative"
  if [[ -f "$(to_unix_path "$candidate")" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi
  return 1
}

windows_cad_workdir() {
  local exe="$1"
  local exe_unix=""
  local exe_dir=""
  local candidate=""

  exe_unix="$(to_unix_path "$exe")"
  exe_dir="$(dirname "$exe_unix")"
  candidate="$exe_dir/UserDataCache"
  if [[ -d "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi
  printf '%s\n' "$exe_dir"
}

find_log_file() {
  local f
  f="$(
    find "$LOGDIR" -maxdepth 1 -type f \( -name '*.log' -o -name '*.txt' \) 2>/dev/null \
      | awk 'NF' \
      | while read -r x; do
          ts=$(stat -f '%m' "$x" 2>/dev/null || stat -c '%Y' "$x" 2>/dev/null || echo 0)
          printf '%s\t%s\n' "$ts" "$x"
        done \
      | sort -nr \
      | awk 'NR==1{print $2}'
  )"
  printf '%s\n' "$f"
}

replay_from_log() {
  local logf="$1"
  [[ -n "$logf" && -f "$logf" ]] || return 0

  awk '
  BEGIN { inblock = 0; saw_output = 0 }
  /^<<<AUTOLISP-BEGIN:/ {
    kind = $0
    sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("> [%s %s]\n", a[1], a[2])
    inblock = 1
    saw_output = 0
    next
  }
  /^<<<AUTOLISP-END:/ {
    kind = $0
    sub(/^<<<AUTOLISP-END:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("=> rc=%s\n", a[3])
    inblock = 0
    next
  }
  {
    if (!inblock) next
    if ($0 ~ /^[[:space:]]*$/) next
    if (!saw_output) {
      print "OUTPUT"
      saw_output = 1
    }
    print
  }
  ' "$logf"
}

find_session_output_file() {
  local candidate

  candidate="$(find_log_file)"
  if [[ -n "$candidate" && -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
    printf '%s\n' "$candidate"
    return 0
  fi

  for candidate in \
    "$WORKDIR/direct-stdout.txt" \
    "$WORKDIR/bricscad-stdout.txt" \
    "$WORKDIR/autocad-stdout.txt"
  do
    if [[ -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

render_stdout() {
  local outfile="$1"
  local sessionfile="${2:-}"
  local verbose_mode="${3:-$CLI_VERBOSE}"

  awk -v sessionfile="$sessionfile" -v verbose_mode="$verbose_mode" '
  function append_output_line(line) {
    pending_output = pending_output line "\n"
  }
  function flush_output(    n, arr, i) {
    if (pending_output == "") return
    if (verbose_mode == "1") print "OUTPUT"
    n = split(pending_output, arr, "\n")
    if (n > 0 && arr[n] == "") n--
    for (i = 1; i <= n; i++) {
      print arr[i]
    }
    pending_output = ""
  }
  BEGIN {
    action_idx = 0
    pending_output = ""

    if (sessionfile != "") {
      inblock = 0
      while ((getline line < sessionfile) > 0) {
        if (line ~ /^<<<AUTOLISP-BEGIN:/) {
          kind = line
          sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
          sub(/>>>$/, "", kind)
          split(kind, a, ":")
          block_key = a[1] ":" a[2]
          block_lines[block_key] = ""
          inblock = 1
          continue
        }
        if (line ~ /^<<<AUTOLISP-END:/) {
          inblock = 0
          block_key = ""
          continue
        }
        if (!inblock) continue
        if (line ~ /^[[:space:]]*$/) continue
        block_lines[block_key] = block_lines[block_key] line "\n"
      }
      close(sessionfile)
    }
  }
  /^LOAD / {
    action_idx++
    pending_output = block_lines["LOAD:" action_idx]
    if (verbose_mode == "1") print
    next
  }
  /^EVAL / {
    action_idx++
    pending_output = block_lines["EXPR:" action_idx]
    if (verbose_mode == "1") print
    next
  }
  /^MAIN / {
    action_idx++
    pending_output = block_lines["MAIN:" action_idx]
    if (verbose_mode == "1") print
    next
  }
  /^<<<AUTOLISP-STDOUT>>>/ {
    append_output_line(substr($0, 22))
    next
  }
  /^LOADED / {
    flush_output()
    if (verbose_mode == "1") print
    next
  }
  /^RESULT / {
    flush_output()
    if (verbose_mode == "1") {
      print
    } else {
      sub(/^RESULT /, "", $0)
      print
    }
    next
  }
  /^MAIN-RESULT / {
    flush_output()
    if (verbose_mode == "1") {
      print
    } else {
      sub(/^MAIN-RESULT /, "", $0)
      print
    }
    next
  }
  /^TOTAL=/ {
    flush_output()
    if (verbose_mode == "1") print
    next
  }
  {
    print
  }
  END {
    flush_output()
  }
  ' "$outfile"
}

declare -a SEARCH_DIRS=()
declare -a LOAD_PATHS=()
declare -a EVAL_PATHS=()
HAS_LOAD_ACTION=0

case "$CAD_MODE" in
  auto|automation|batch) ;;
  *)
    echo "Invalid CAD mode: $CAD_MODE" >&2
    exit 2
    ;;
esac

case "$CAD_BACKEND" in
  attach|launch) ;;
  *)
    echo "Invalid CAD backend: $CAD_BACKEND" >&2
    exit 2
    ;;
esac

case "$BOOTSTRAP_PHASE" in
  marker|core|log|full) ;;
  *)
    echo "Invalid AUTOLISP_BOOTSTRAP_PHASE: $BOOTSTRAP_PHASE" >&2
    exit 2
    ;;
esac

case "$AUTOLISP_REMOTE_IO_MODE" in
  auto|on|off) ;;
  *)
    echo "Invalid AUTOLISP_REMOTE_IO_MODE: $AUTOLISP_REMOTE_IO_MODE" >&2
    exit 2
    ;;
esac

if [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 ]]; then
  BRICSCAD_MACOS_EFFECTIVE_MODE="$CAD_MODE"
  if [[ "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "auto" ]]; then
    if find_macos_bricscad_cli >/dev/null 2>&1; then
      BRICSCAD_MACOS_EFFECTIVE_MODE="batch"
    else
      BRICSCAD_MACOS_EFFECTIVE_MODE="automation"
    fi
  fi
fi

if [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" && -z "$BRICSCAD_MACOS_PROFILE" ]]; then
  BRICSCAD_MACOS_PROFILE="lisp"
fi

USE_REMOTE_PROTOCOL=0
if [[ "$ENGINE" == "bricscad" && ( ( $IS_MACOS -eq 1 && ( "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" || "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "automation" ) ) || ( $IS_WINDOWS -eq 1 && "$CAD_MODE" == "batch" && "$INTERACTIVE" -eq 1 ) ) && "$BOOTSTRAP_PHASE" == "full" ]]; then
  case "$AUTOLISP_REMOTE_IO_MODE" in
    auto|on)
      if [[ $IS_MACOS -eq 1 && ( "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" || "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "automation" ) ]]; then
        USE_REMOTE_PROTOCOL=1
      elif [[ $IS_WINDOWS -eq 1 && "$CAD_MODE" == "batch" ]]; then
        USE_REMOTE_PROTOCOL=1
      fi
      ;;
  esac
fi

USE_FOREGROUND_BATCH_PROTOCOL=0
if [[ "$USE_REMOTE_PROTOCOL" -eq 1 && "$ENGINE" == "bricscad" ]]; then
  if [[ $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]]; then
    USE_FOREGROUND_BATCH_PROTOCOL=1
  elif [[ $IS_WINDOWS -eq 1 && "$CAD_MODE" == "batch" ]]; then
    USE_FOREGROUND_BATCH_PROTOCOL=1
  fi
fi
if [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 && "$EXPERIMENTAL_MACOS_BATCH_OPEN" == "1" && "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" && "$CAD_BACKEND" == "launch" ]]; then
  USE_FOREGROUND_BATCH_PROTOCOL=0
fi

if [[ -n "${AUTOLISP_WORKDIR:-}" ]]; then
  BASE_WORKDIR="${AUTOLISP_WORKDIR}"
else
  BASE_WORKDIR="$DEFAULT_AUTOLISP_WORKDIR"
fi
mkdir -p "$BASE_WORKDIR"
WORKDIR="$(mktemp -d "$BASE_WORKDIR/autolisp.XXXXXX")"
PROTOCOL_REQUEST_SEQFILE="$WORKDIR/protocol-request-seq.txt"
rm -f "$PROTOCOL_REQUEST_SEQFILE"
autolisp_protocol_init_session "$WORKDIR"
autolisp_protocol_export_session
autolisp_protocol_reset_session

OUTFILE="$WORKDIR/output.txt"
ERRFILE="$WORKDIR/errors.txt"
STATUSFILE="$WORKDIR/status.txt"
INPFILE="$WORKDIR/input.lsp"
LOGDIR="$WORKDIR/logs"
: >"$OUTFILE"
: >"$ERRFILE"
echo "__PENDING__" >"$STATUSFILE"
rm -f "$INPFILE"
mkdir -p "$LOGDIR"
BRICSCAD_BATCH_COMMAND_FILE="$WORKDIR/bricscad-command.txt"

LISP_OUTFILE="$(to_runtime_lisp_path "$OUTFILE")"
LISP_ERRFILE="$(to_runtime_lisp_path "$ERRFILE")"
LISP_STATUSFILE="$(to_runtime_lisp_path "$STATUSFILE")"
LISP_INPFILE="$(to_runtime_lisp_path "$INPFILE")"
LISP_LOGDIR="$(to_runtime_lisp_path "$LOGDIR")"
LISP_RENDERFILE="$(to_runtime_lisp_path "$WORKDIR/render.txt")"
LISP_PROTOCOL_DIR="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_DIR")"
LISP_PROTOCOL_STATUSFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_STATUSFILE")"
LISP_PROTOCOL_STDINFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_STDINFILE")"
LISP_PROTOCOL_STDOUTFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_STDOUTFILE")"
LISP_PROTOCOL_STDERRFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_STDERRFILE")"
LISP_PROTOCOL_CONTROLFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_CONTROLFILE")"
LISP_PROTOCOL_HEARTBEATFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_HEARTBEATFILE")"
LISP_PROTOCOL_READFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_READFILE")"
LISP_PROTOCOL_INFOFILE="$(to_runtime_lisp_path "$AUTOLISP_PROTOCOL_INFOFILE")"
PROTOCOL_RUNTIME_FILE="$SCRIPT_DIR/runtime/autolisp-remote-io.lsp"
LISP_PROTOCOL_RUNTIME_FILE="$(to_runtime_lisp_path "$PROTOCOL_RUNTIME_FILE")"

for i in "${!ACTION_KINDS[@]}"; do
  kind="${ACTION_KINDS[$i]}"
  value="${ACTION_VALUES[$i]}"
  if [[ "$kind" == "load" ]]; then
    if [[ ! -f "$value" ]]; then
      echo "Not found: $value" >&2
      exit 2
    fi
    abs_src="$(to_abs_path "$value")"
    abs_src="$(to_runtime_lisp_path "$abs_src")"
    abs_dir="$(dirname "$abs_src")"
    LOAD_PATHS+=("$abs_src")
    HAS_LOAD_ACTION=1

    already_present=0
    for existing in "${SEARCH_DIRS[@]:-}"; do
      if [[ "$existing" == "$abs_dir" ]]; then
        already_present=1
        break
      fi
    done
    if [[ $already_present -eq 0 ]]; then
      SEARCH_DIRS+=("$abs_dir")
    fi
    EVAL_PATHS+=("")
  else
    LOAD_PATHS+=("")
    eval_file="$WORKDIR/eval-$((i + 1)).lsp"
    printf '%s' "$value" >"$eval_file"
    EVAL_PATHS+=("$(to_runtime_lisp_path "$eval_file")")
  fi
done

USE_BATCH_INTERACTIVE_REPL=0
if [[ "$INTERACTIVE" -eq 1 && "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" && "$USE_REMOTE_PROTOCOL" -eq 0 ]]; then
  USE_BATCH_INTERACTIVE_REPL=1
fi
if [[ "$INTERACTIVE" -eq 1 && "$USE_REMOTE_PROTOCOL" -eq 0 && "$USE_BATCH_INTERACTIVE_REPL" -eq 0 ]]; then
  run_interactive_repl
  exit $?
fi

if [[ "$INTERACTIVE" -eq 1 && "${AUTOLISP_SUPPRESS_VERSION_BANNER:-0}" != "1" ]]; then
  if ! autolisp_is_quiet; then
    autolisp_version_string
  fi
fi

QUIT_ON_FINISH=1
if [[ "$CAD_BACKEND" == "attach" ]]; then
  QUIT_ON_FINISH=0
fi
# En mode batch macOS, on veut terminer l'instance lancée pour les exécutions non interactives
# afin d'éviter d'accumuler des processus BricsCAD bloqués. On conserve la session uniquement
# pour le REPL batch (--interactive).
if [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" && "$INTERACTIVE" -eq 1 ]]; then
  QUIT_ON_FINISH=0
fi
# --quit force la fin de la session, indépendamment du backend ou du mode interactif.
if [[ "$QUIT_REQUESTED" -eq 1 ]]; then
  QUIT_ON_FINISH=1
fi

RUNLSPFILE="$WORKDIR/run-common.lsp"
if [[ "$BOOTSTRAP_PHASE" == "marker" ]]; then
  {
    printf '(setq f (open "%s" "w"))\n' "$(escape_lisp_string "$LISP_OUTFILE")"
    echo '(if f (progn (write-line "BOOTSTRAP MARKER" f) (close f)))'
    printf '(setq f (open "%s" "w"))\n' "$(escape_lisp_string "$LISP_STATUSFILE")"
    echo '(if f (progn (write-line "0" f) (close f)))'
  } >"$RUNLSPFILE"
elif [[ "$BOOTSTRAP_PHASE" == "core" && ${#ACTION_KINDS[@]} -eq 1 && "${ACTION_KINDS[0]}" == "eval" && "$HAS_LOAD_ACTION" -eq 0 ]]; then
  {
    printf '(setq *AUTOLISP_OUTFILE* "%s")\n' "$(escape_lisp_string "$LISP_OUTFILE")"
    printf '(setq *AUTOLISP_STATUSFILE* "%s")\n' "$(escape_lisp_string "$LISP_STATUSFILE")"
    printf '(setq *AUTOLISP_RENDERFILE* "%s")\n' "$(escape_lisp_string "$LISP_RENDERFILE")"
    cat <<'EOLISP'
(defun autolisp-slurp-file (path / f line acc)
  (setq f (open path "r"))
  (if (not f)
    ""
    (progn
      (setq acc "")
      (while (setq line (read-line f))
        (setq line (vl-string-translate "\r" "" line))
        (if (= acc "")
          (setq acc line)
          (setq acc (strcat acc "\n" line))))
      (close f)
      acc)))

(defun autolisp-render (obj / rendered)
  (setq rendered (vl-catch-all-apply 'vl-princ-to-string (list obj)))
  (if (vl-catch-all-error-p rendered)
    "<unprintable>"
    rendered))
EOLISP
    printf '(setq f (open *AUTOLISP_OUTFILE* "w"))\n'
    echo '(if f (close f))'
    printf '(setq f (open *AUTOLISP_STATUSFILE* "w"))\n'
    echo '(if f (progn (write-line "99" f) (close f)))'
    printf '(setq expr-text "%s")\n' "$(escape_lisp_string "${ACTION_VALUES[0]}")"
    echo '(setq expr (read expr-text))'
    echo '(setq result (eval expr))'
    printf '(setq f (open *AUTOLISP_OUTFILE* "a"))\n'
    echo '(if f (progn (write-line (strcat "EVAL " expr-text) f) (write-line (strcat "RESULT " (autolisp-render result)) f) (write-line "TOTAL=1 OK=1 FAIL=0 ERROR=0" f) (close f)))'
    printf '(setq f (open *AUTOLISP_STATUSFILE* "w"))\n'
    echo '(if f (progn (write-line "0" f) (close f)))'
  } >"$RUNLSPFILE"
else
{
  if [[ ${#SEARCH_DIRS[@]} -gt 0 ]]; then
    echo '(setq _autolisp_old_srchpath (getvar "SRCHPATH"))'
    srch_prefix=""
    for dir in "${SEARCH_DIRS[@]}"; do
      srch_prefix+="$(escape_lisp_string "$dir");"
    done
    printf '(setvar "SRCHPATH" (strcat "%s" _autolisp_old_srchpath))\n' "$srch_prefix"
  else
    echo '(setq _autolisp_old_srchpath nil)'
  fi
  printf '(setq *AUTOLISP_OUTFILE* "%s")\n' "$(escape_lisp_string "$LISP_OUTFILE")"
  printf '(setq *AUTOLISP_ERRFILE* "%s")\n' "$(escape_lisp_string "$LISP_ERRFILE")"
  printf '(setq *AUTOLISP_STATUSFILE* "%s")\n' "$(escape_lisp_string "$LISP_STATUSFILE")"
  printf '(setq *AUTOLISP_INPFILE* "%s")\n' "$(escape_lisp_string "$LISP_INPFILE")"
