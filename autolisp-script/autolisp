;; --- Resolution des chemins relatifs ---
;; acad.exe lance via COM CreateObject n'herite generalement pas du cwd du
;; shell appelant ; ses chemins relatifs (load, findfile, vlisp-compile...)
;; sont donc resolus contre son propre dossier d'install. On expose ici le
;; cwd d'invocation du wrapper et un helper pour absolutiser les chemins
;; cote LISP.

(defun autolisp-absolute-path-p (p)
  (cond
    ((or (null p) (not (= (type p) 'STR)) (= p "")) nil)
    ((or (= (substr p 1 1) "/")
         (= (substr p 1 1) "\\")) T)
    ((and (>= (strlen p) 2)
          (= (substr p 2 1) ":")) T)
    (T nil)))

(defun autolisp-resolve-path (p)
  (cond
    ((or (null p) (not (= (type p) 'STR))) p)
    ((autolisp-absolute-path-p p) p)
    ((or (null *AUTOLISP_INVOCATION_DIR*) (= *AUTOLISP_INVOCATION_DIR* "")) p)
    (T (strcat *AUTOLISP_INVOCATION_DIR* "/" p))))

;; Shadow vlisp-compile : absolutise le chemin source contre le cwd
;; d'invocation. La fonction d'origine est preservee sous
;; *autolisp-original-vlisp-compile* pour appel via apply.
;;
;; Sous AutoCAD, vlisp-compile (et toutes les fonctions VLISP-*
;; "interactives") n'est PAS exposee au demarrage tant que la
;; fenetre VLIDE n'a pas ete chargee : il faut invoquer la commande
;; _VLIDE pour faire apparaitre les bindings au runtime AutoLISP.
;; On essaye donc d'abord (type vlisp-compile) ; si la fonction est
;; absente, on charge VLIDE et on retente. Sous BricsCAD ou
;; accoreconsole (pas de VLIDE), les deux essais echouent, aucun
;; shadow n'est installe.
(defun autolisp--type-of-vlisp-compile () (type vlisp-compile))

;; Trace runtime ecrite dans WORKDIR/debug.log : permet a l'utilisateur
;; (via --debug cote bash, qui tail ce fichier en arriere-plan) de voir
;; en temps reel ou en est le runtime AutoLISP. No-op si *AUTOLISP_DEBUG*
;; est nil.
(defun autolisp-runtime-debug (msg)
  (if *AUTOLISP_DEBUG*
    (autolisp-bootstrap-append-line *AUTOLISP_DEBUGFILE* msg)))

(defun autolisp-install-vlisp-compile-shadow ( / orig-type r)
  ;; Idempotent : si le shadow est deja en place, on ne refait rien.
  (if (boundp '*autolisp-original-vlisp-compile*)
    nil
    (progn
      (vl-catch-all-apply 'vl-load-com nil)
      (setq r (vl-catch-all-apply 'autolisp--type-of-vlisp-compile nil))
      (if (vl-catch-all-error-p r)
        (setq orig-type nil)
        (setq orig-type r))
      ;; Trace minimaliste pour aider au diagnostic. On loggue seulement
      ;; aux moments interessants : premier appel (avant tout user-action)
      ;; et chaque fois que le type devient un SUBR (l'utilisateur a
      ;; charge VLIDE entretemps via (c:vlide) ou similaire).
      (autolisp-bootstrap-append-line
        (strcat *AUTOLISP_LOGDIR* "/vlide-shadow.log")
        (strcat "probe: type-of-vlisp-compile=" (vl-princ-to-string orig-type)))
      (if (and orig-type
               (or (= orig-type 'SUBR) (= orig-type 'USUBR) (= orig-type 'EXSUBR)))
        (progn
          (setq *autolisp-original-vlisp-compile* vlisp-compile)
          (defun vlisp-compile (mode src / abs-src)
            (setq abs-src (autolisp-resolve-path src))
            (apply *autolisp-original-vlisp-compile* (list mode abs-src)))
          (autolisp-bootstrap-append-line
            (strcat *AUTOLISP_LOGDIR* "/vlide-shadow.log")
            "shadow installed"))))))

(defun autolisp-bootstrap-append-line (path text / f)
  (if (and (= (type path) 'STR)
           (/= path ""))
    (progn
      (setq f (open path "a"))
      (if f
        (progn
          (write-line text f)
          (close f))))))

(defun autolisp-bootstrap-write-line (path text / f)
  (if (and (= (type path) 'STR)
           (/= path ""))
    (progn
      (setq f (open path "w"))
      (if f
        (progn
          (write-line text f)
          (close f))))))

(defun autolisp-bootstrap-render-error (err / msg)
  (cond
    ((and (= (type err) 'STR)
          (/= err ""))
     err)
    ((and (fboundp 'vl-catch-all-error-message)
          (not (vl-catch-all-error-p
                 (setq msg (vl-catch-all-apply 'vl-catch-all-error-message
                                               (list err))))))
     msg)
    (T
     "<bootstrap failure>")))

(defun autolisp-bootstrap-mark-fatal (phase err / msg)
  (setq msg (autolisp-bootstrap-render-error err))
  (autolisp-bootstrap-append-line *AUTOLISP_ERRFILE*
                                  (strcat "ERROR " phase ": " msg))
  (autolisp-bootstrap-write-line *AUTOLISP_STATUSFILE* "1")
  (autolisp-bootstrap-write-line *AUTOLISP_PROTOCOL_STATUSFILE*
                                 (strcat "FAILED " phase))
  (if *AUTOLISP_QUIT_ON_FINISH*
    (progn
      (vl-catch-all-apply 'setvar (list "FILEDIA" 0))
      (vl-catch-all-apply 'command (list "_QUIT" "_N"))))
  1)

(defun autolisp-write-line (path text / f)
  (setq f (open path "a"))
  (if f
    (progn
      (write-line text f)
      (close f))))

(defun autolisp-write-prefixed-text (path prefix text / f idx len ch acc)
  (setq f (open path "a"))
  (if f
    (progn
      (setq idx 1)
      (setq len (strlen text))
      (setq acc "")
      (while (<= idx len)
        (setq ch (substr text idx 1))
        (if (= ch "\n")
          (progn
            (write-line (strcat prefix acc) f)
            (setq acc ""))
          (setq acc (strcat acc ch)))
        (setq idx (+ idx 1)))
      (write-line (strcat prefix acc) f)
      (close f))))

(defun autolisp-reset-file (path / f)
  (setq f (open path "w"))
  (if f (close f)))

(defun autolisp-slurp-file (path / f line acc)
  (setq f (open path "r"))
  (if (not f)
    ""
    (progn
      (setq acc "")
      (while (setq line (read-line f))
        (setq line (vl-string-translate "\r" "" line))
        (if (= acc "")
          (setq acc line)
          (setq acc (strcat acc "\n" line))))
      (close f)
      acc)))

(defun autolisp-str (obj)
  (if (= (type obj) 'STR)
    obj
    (autolisp-render obj)))

(defun autolisp-render (obj / rendered)
  (setq rendered (vl-catch-all-apply 'vl-princ-to-string (list obj)))
  (if (vl-catch-all-error-p rendered)
    "<unprintable>"
    rendered))

(defun autolisp-set-status (code / f)
  (setq f (open *AUTOLISP_STATUSFILE* "w"))
  (if f
    (progn
      (write-line (itoa code) f)
      (close f)))
  code)

(defun autolisp-set-status-text (text / f)
  (setq f (open *AUTOLISP_STATUSFILE* "w"))
  (if f
    (progn
      (write-line text f)
      (close f)))
  text)

(defun autolisp-log-out (text)
  (autolisp-write-line *AUTOLISP_OUTFILE* text))

(defun autolisp-log-err (text)
  (autolisp-write-line *AUTOLISP_ERRFILE* text))

(defun autolisp-safe-getvar (name / value)
  (setq value (vl-catch-all-apply 'getvar (list name)))
  (if (vl-catch-all-error-p value)
    ""
    (autolisp-str value)))

(defun autolisp-write-runtime-info (/ f)
  (setq f (open *AUTOLISP_PROTOCOL_INFOFILE* "w"))
  (if f
    (progn
      (write-line (autolisp-safe-getvar "PRODUCT") f)
      (write-line (autolisp-safe-getvar "ACADVER") f)
      (write-line (autolisp-safe-getvar "PROGRAM") f)
      (close f)))
  nil)

(defun autolisp-stdout-prefix ()
  "<<<AUTOLISP-STDOUT>>>")

(defun autolisp-escape-string (text / idx len ch acc)
  (setq idx 1)
  (setq len (strlen text))
  (setq acc "")
  (while (<= idx len)
    (setq ch (substr text idx 1))
    (if (= ch "\\")
      (setq acc (strcat acc "\\\\"))
      (if (= ch "\"")
        (setq acc (strcat acc "\\\""))
        (setq acc (strcat acc ch))))
    (setq idx (+ idx 1)))
  acc)

(defun autolisp-readable-text (obj / acc first tail)
  (cond
    ((null obj)
     "nil")
    ((= (type obj) 'STR)
     (strcat "\"" (autolisp-escape-string obj) "\""))
    ((listp obj)
     (setq acc "(")
     (setq first T)
     (setq tail obj)
     (while tail
       (if first
         (setq first nil)
         (setq acc (strcat acc " ")))
       (setq acc (strcat acc (autolisp-readable-text (car tail))))
       (setq tail (cdr tail)))
     (strcat acc ")"))
    (T
     (autolisp-render obj))))

(defun autolisp-stdout-text (obj)
  (autolisp-readable-text obj))

(defun autolisp-emit-user-out (obj)
  (if *AUTOLISP_CAPTURE_STDOUT*
    (autolisp-write-prefixed-text *AUTOLISP_OUTFILE*
                                  (autolisp-stdout-prefix)
                                  (autolisp-stdout-text obj)))
  obj)

(defun autolisp-emit-user-line (text)
  (if *AUTOLISP_CAPTURE_STDOUT*
    (autolisp-write-prefixed-text *AUTOLISP_OUTFILE*
                                  (autolisp-stdout-prefix)
                                  text)
    text)
  text)

