find_log_file() {
  local f
  f="$(
    find "$LOGDIR" -maxdepth 1 -type f \( -name '*.log' -o -name '*.txt' \) 2>/dev/null \
      | awk 'NF' \
      | while read -r x; do
          ts=$(stat -f '%m' "$x" 2>/dev/null || stat -c '%Y' "$x" 2>/dev/null || echo 0)
          printf '%s\t%s\n' "$ts" "$x"
        done \
      | sort -nr \
      | awk 'NR==1{print $2}'
  )"
  printf '%s\n' "$f"
}

replay_from_log() {
  local logf="$1"
  [[ -n "$logf" && -f "$logf" ]] || return 0

  awk '
  BEGIN { inblock = 0; saw_output = 0 }
  /^<<<AUTOLISP-BEGIN:/ {
    kind = $0
    sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("> [%s %s]\n", a[1], a[2])
    inblock = 1
    saw_output = 0
    next
  }
  /^<<<AUTOLISP-END:/ {
    kind = $0
    sub(/^<<<AUTOLISP-END:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("=> rc=%s\n", a[3])
    inblock = 0
    next
  }
  {
    if (!inblock) next
    if ($0 ~ /^[[:space:]]*$/) next
    if (!saw_output) {
      print "OUTPUT"
      saw_output = 1
    }
    print
  }
  ' "$logf"
}

find_session_output_file() {
  local candidate

  candidate="$(find_log_file)"
  if [[ -n "$candidate" && -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
    printf '%s\n' "$candidate"
    return 0
  fi

  for candidate in \
    "$WORKDIR/direct-stdout.txt" \
    "$WORKDIR/bricscad-stdout.txt" \
    "$WORKDIR/autocad-stdout.txt"
  do
    if [[ -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

render_stdout() {
  local outfile="$1"
  local sessionfile="${2:-}"
  local verbose_mode="${3:-$CLI_VERBOSE}"

  awk -v sessionfile="$sessionfile" -v verbose_mode="$verbose_mode" '
  function append_output_line(line) {
    pending_output = pending_output line "\n"
  }
  function flush_output(    n, arr, i) {
    if (pending_output == "") return
    if (verbose_mode == "1") print "OUTPUT"
    n = split(pending_output, arr, "\n")
    if (n > 0 && arr[n] == "") n--
    for (i = 1; i <= n; i++) {
      print arr[i]
    }
    pending_output = ""
  }
  BEGIN {
    action_idx = 0
    pending_output = ""

    if (sessionfile != "") {
      inblock = 0
      while ((getline line < sessionfile) > 0) {
        if (line ~ /^<<<AUTOLISP-BEGIN:/) {
          kind = line
          sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
          sub(/>>>$/, "", kind)
          split(kind, a, ":")
          block_key = a[1] ":" a[2]
          block_lines[block_key] = ""
          inblock = 1
          continue
        }
        if (line ~ /^<<<AUTOLISP-END:/) {
          inblock = 0
          block_key = ""
          continue
        }
        if (!inblock) continue
        if (line ~ /^[[:space:]]*$/) continue
        block_lines[block_key] = block_lines[block_key] line "\n"
      }
      close(sessionfile)
    }
  }
  /^LOAD / {
    action_idx++
    pending_output = block_lines["LOAD:" action_idx]
    if (verbose_mode == "1") print
    next
  }
  /^EVAL / {
    action_idx++
    pending_output = block_lines["EXPR:" action_idx]
    if (verbose_mode == "1") print
    next
  }
  /^MAIN / {
    action_idx++
    pending_output = block_lines["MAIN:" action_idx]
    if (verbose_mode == "1") print
    next
  }
  /^<<<AUTOLISP-STDOUT>>>/ {
    append_output_line(substr($0, 22))
    next
  }
  /^LOADED / {
    flush_output()
    if (verbose_mode == "1") print
    next
  }
  /^RESULT / {
    flush_output()
    if (verbose_mode == "1") {
      print
    } else {
      sub(/^RESULT /, "", $0)
      print
    }
    next
  }
  /^MAIN-RESULT / {
    flush_output()
    if (verbose_mode == "1") {
      print
    } else {
      sub(/^MAIN-RESULT /, "", $0)
      print
    }
    next
  }
  /^TOTAL=/ {
    flush_output()
    if (verbose_mode == "1") print
    next
  }
  {
    print
  }
  END {
    flush_output()
  }
  ' "$outfile"
}

