}

find_macos_bricscad_cli() {
  if [[ -n "${BRICSCAD_EXE:-}" && -f "${BRICSCAD_EXE}" ]]; then
    printf '%s\n' "$BRICSCAD_EXE"
    return 0
  fi

  local app
  app="$(find_macos_bricscad_app)"
  if [[ -n "$app" && -x "$app/Contents/MacOS/bricscad" ]]; then
