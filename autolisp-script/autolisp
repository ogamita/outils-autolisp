#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOU'
Usage:
  autolisp-v4 [--autocad|--bricscad] [--timeout N] [--bootstrap-phase marker|core|log|full] [--bricscad-macos-mode auto|osascript|batch] [--bricscad-macos-app attach|launch] [--bricscad-macos-profile NAME] { source.lsp | -x expression }... [--dwg file.dwg] [--main C:MAIN]
  autolisp-v4 [--autocad|--bricscad] [--timeout N] [--bootstrap-phase marker|core|log|full] [--bricscad-macos-mode auto|osascript|batch] [--bricscad-macos-app attach|launch] [--bricscad-macos-profile NAME] -i|--interactive [--dwg file.dwg]

Examples:
  autolisp test.lsp
  autolisp lib1.lsp lib2.lsp --main C:RUN
  autolisp -x '(princ (+ 1 2))'
  autolisp init.lsp -x '(setq *x* 42)' test.lsp
  autolisp --interactive

Semantics:
  - Les éléments { source.lsp | -x expression } sont traités dans l'ordre.
  - Chaque source.lsp est chargé avec (load "...").
  - Chaque -x expression est évalué comme une forme AutoLISP.
  - Si au moins un fichier source.lsp est fourni, (${MAIN:-C:MAIN}) est appelé à la fin.

Outputs:
  stdout  -> contenu de OUTFILE
  stderr  -> contenu de ERRFILE
  exit    -> code lu dans STATUSFILE

Environment overrides:
  AUTOCAD_ACCORECONSOLE   Path to accoreconsole.exe (Windows)
  AUTOCAD_COM_MODE        auto | attach | launch | off   (Windows + AutoCAD only)
  AUTOCAD_EXE             Path to acad.exe / acadlt.exe  (Windows)
  BRICSCAD_EXE            Path to bricscad.exe      (Windows)
  BRICSCAD_MACOS_MODE     auto | osascript | batch  (macOS + BricsCAD only)
  BRICSCAD_MACOS_APP_MODE attach | launch           (macOS + BricsCAD + osascript only)
  BRICSCAD_MACOS_PROFILE  BricsCAD profile name     (macOS + BricsCAD batch only)
  AUTOLISP_BOOTSTRAP_PHASE marker | core | log | full
  AUTOLISP_DWG            Default DWG for AutoCAD Core Console if --dwg not provided
  BRICSCAD_COM_MODE       auto | attach | launch | off   (Windows + BricsCAD only)
  AUTOLISP_TIMEOUT        Legacy timeout override in seconds
  AUTOLISP_WAIT_SECS      wait timeout for async modes / COM bridge (default: 180)
  AUTOLISP_KEEP_WORKDIR   1 to keep temporary workdir
  AUTOLISP_VERBOSE        1 for extra diagnostics

Notes:
  - AutoCAD Core Console (accoreconsole.exe) est Windows-only dans la pratique.
  - Sous Windows + BricsCAD, le script peut utiliser un pont COM autonome généré dans le workdir.
  - Sous macOS, le fallback reste piloté par UI scripting et dépend des autorisations Accessibilité.
EOU
}

ENGINE=""
DWG=""
MAIN="C:MAIN"
TIMEOUT_SECS="${AUTOLISP_WAIT_SECS:-${AUTOLISP_TIMEOUT:-180}}"
AUTOCAD_COM_MODE="${AUTOCAD_COM_MODE:-auto}"
AUTOCAD_EXE="${AUTOCAD_EXE:-}"
BRICSCAD_EXE="${BRICSCAD_EXE:-}"
BRICSCAD_MACOS_MODE="${BRICSCAD_MACOS_MODE:-auto}"
BRICSCAD_MACOS_APP_MODE="${BRICSCAD_MACOS_APP_MODE:-launch}"
BRICSCAD_MACOS_PROFILE="${BRICSCAD_MACOS_PROFILE:-}"
BOOTSTRAP_PHASE="${AUTOLISP_BOOTSTRAP_PHASE:-full}"
INTERACTIVE=0

declare -a ACTION_KINDS=()
declare -a ACTION_VALUES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --autocad)
      ENGINE="autocad"
      shift
      ;;
    --bricscad)
      ENGINE="bricscad"
      shift
      ;;
    --timeout)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --timeout" >&2
        usage
        exit 2
      fi
      TIMEOUT_SECS="$2"
      shift 2
      ;;
    --bootstrap-phase)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bootstrap-phase" >&2
        usage
        exit 2
      fi
      BOOTSTRAP_PHASE="$2"
      shift 2
      ;;
    --bricscad-macos-mode)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bricscad-macos-mode" >&2
        usage
        exit 2
      fi
      BRICSCAD_MACOS_MODE="$2"
      shift 2
      ;;
    --bricscad-macos-app)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bricscad-macos-app" >&2
        usage
        exit 2
      fi
      BRICSCAD_MACOS_APP_MODE="$2"
      shift 2
      ;;
    --bricscad-macos-profile)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bricscad-macos-profile" >&2
        usage
        exit 2
      fi
      BRICSCAD_MACOS_PROFILE="$2"
      shift 2
      ;;
    --dwg)
      DWG="${2:-}"
      shift 2
      ;;
    --main)
      MAIN="${2:-}"
      shift 2
      ;;
    -i|--interactive)
      INTERACTIVE=1
      shift
      ;;
    -x)
      if [[ $# -lt 2 ]]; then
        echo "Missing expression after -x" >&2
        usage
        exit 2
      fi
      ACTION_KINDS+=("eval")
      ACTION_VALUES+=("$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        ACTION_KINDS+=("load")
        ACTION_VALUES+=("$1")
        shift
      done
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      ACTION_KINDS+=("load")
      ACTION_VALUES+=("$1")
      shift
      ;;
  esac
done

interactive_form_complete() {
  local form="$1"
  perl -e '
my $s = shift;
my ($depth, $in_string, $escape, $in_comment, $started) = (0, 0, 0, 0, 0);
foreach my $ch (split //, $s) {
  if ($in_comment) {
    $in_comment = 0 if $ch eq "\n";
    next;
  }
  if ($in_string) {
    $started = 1;
    if ($escape) {
      $escape = 0;
      next;
    }
    if ($ch eq "\\") {
      $escape = 1;
      next;
    }
    if ($ch eq "\"") {
      $in_string = 0;
    }
    next;
  }
  if ($ch eq ";") {
    $in_comment = 1;
    next;
  }
  if ($ch =~ /\s/) {
    next;
  }
  $started = 1;
  if ($ch eq "\"") {
    $in_string = 1;
    next;
  }
  if ($ch eq "(") {
    $depth++;
    next;
  }
  if ($ch eq ")") {
    $depth-- if $depth > 0;
    next;
  }
}
exit(($started && !$in_string && !$in_comment && $depth == 0) ? 0 : 1);
' -- "$form"
}

interactive_print_response() {
  local stdout_file="$1"
  local stderr_file="$2"
  local stdout_block result_line

  stdout_block="$(
    awk '
    BEGIN { capture = 0 }
    /^OUTPUT$/ { capture = 1; next }
    /^RESULT / { capture = 0 }
    capture { print }
    ' "$stdout_file"
  )"
  result_line="$(awk '/^RESULT /{sub(/^RESULT /, ""); print; exit}' "$stdout_file")"

  printf 'STDOUT\n'
  if [[ -n "$stdout_block" ]]; then
    printf '%s\n' "$stdout_block"
  fi

  printf 'STDERR\n'
  if [[ -s "$stderr_file" ]]; then
    cat "$stderr_file"
  fi

  printf 'RESULT\n'
  if [[ -n "$result_line" ]]; then
    printf '%s\n' "$result_line"
  fi
  printf '\n'
}

write_atomic_file() {
  local target="$1"
  local content="$2"
  local tmp
  tmp="${target}.tmp.$$.$RANDOM"
  printf '%s' "$content" >"$tmp"
  mv "$tmp" "$target"
}

read_status_file() {
  if [[ -f "$STATUSFILE" ]]; then
    awk 'NF{line=$0} END{print line}' "$STATUSFILE" 2>/dev/null || true
  fi
}

batch_runner_done_without_status() {
  local current_status="$1"
  local batch_rc=""
  if [[ "$BRICSCAD_BATCH_LAUNCHED" -eq 1 && -f "$BATCH_EXIT_FILE" ]]; then
    if [[ -z "$current_status" || "$current_status" == "__PENDING__" || "$current_status" == "99" ]]; then
      CLEANUP_WORKDIR="1"
      FORCE_REPORT_WORKDIR="1"
      batch_rc="$(awk 'NF{line=$0} END{print line}' "$BATCH_EXIT_FILE" 2>/dev/null || true)"
      echo "ERROR: BricsCAD batch process exited before writing a final status." >&2
      if [[ -n "$batch_rc" ]]; then
        echo "ERROR: BricsCAD batch exit code: $batch_rc" >&2
      fi
      echo "ERROR: likely the startup script was not executed, or (load \"$RUNLSPFILE\") failed before autolisp initialized." >&2
      if [[ -s "$WORKDIR/bricscad-stderr.txt" ]]; then
        cat "$WORKDIR/bricscad-stderr.txt" >&2
      fi
      return 0
    fi
  fi
  return 1
}

wait_for_status_value() {
  local expected="$1"
  local timeout="$TIMEOUT_SECS"
  local current
  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi
    current="$(read_status_file)"
    if [[ "$current" == "$expected" ]]; then
      return 0
    fi
    if batch_runner_done_without_status "$current"; then
      return 1
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  echo "ERROR: timeout waiting for status '$expected' after ${TIMEOUT_SECS}s" >&2
  return 124
}

run_interactive_repl() {
  local self prompt cont_prompt line buffer case_dir stdout_file stderr_file
  declare -a repl_args=()

  self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  prompt="autolisp> "
  cont_prompt="......> "
  [[ -n "$ENGINE" ]] && repl_args+=("--$ENGINE")
  repl_args+=("--timeout" "$TIMEOUT_SECS")
  [[ -n "$DWG" ]] && repl_args+=("--dwg" "$DWG")
  if [[ "$ENGINE" == "bricscad" ]]; then
    repl_args+=("--bricscad-macos-mode" "$BRICSCAD_MACOS_MODE")
    repl_args+=("--bricscad-macos-app" "$BRICSCAD_MACOS_APP_MODE")
    if [[ -n "$BRICSCAD_MACOS_PROFILE" ]]; then
      repl_args+=("--bricscad-macos-profile" "$BRICSCAD_MACOS_PROFILE")
    fi
  fi

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    case_dir="$(mktemp -d "${TMPDIR:-/tmp}/autolisp-repl.XXXXXX")"
    stdout_file="$case_dir/stdout.txt"
    stderr_file="$case_dir/stderr.txt"

    "$self" "${repl_args[@]}" -x "$buffer" >"$stdout_file" 2>"$stderr_file" || true
    interactive_print_response "$stdout_file" "$stderr_file"
    rm -rf "$case_dir"
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi
  return 0
}

run_batch_interactive_repl() {
  local prompt cont_prompt line buffer req_id payload rendered_file
  prompt="autolisp> "
  cont_prompt="......> "
  req_id=0

  if ! wait_for_status_value "READY 0"; then
    return $?
  fi

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    req_id=$((req_id + 1))
    payload=";REQ $req_id"$'\n'"$buffer"$'\n'
    write_atomic_file "$INPFILE" "$payload"

    if ! wait_for_status_value "READY $req_id"; then
      return $?
    fi

    rendered_file="$WORKDIR/interactive-rendered.txt"
    render_stdout "$OUTFILE" >"$rendered_file"
    interactive_print_response "$rendered_file" "$ERRFILE"
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi

  req_id=$((req_id + 1))
  payload=";REQ $req_id"$'\n'"'__AUTOLISP_QUIT__"$'\n'
  write_atomic_file "$INPFILE" "$payload"
  wait_for_status_value "STOP $req_id" || true
  return 0
}

if [[ "$INTERACTIVE" -eq 1 && ${#ACTION_KINDS[@]} -gt 0 ]]; then
  echo "Interactive mode does not accept source.lsp or -x inputs." >&2
  usage
  exit 2
fi

if [[ "$INTERACTIVE" -eq 1 && "$BOOTSTRAP_PHASE" != "full" ]]; then
  echo "Interactive mode requires --bootstrap-phase full." >&2
  exit 2
fi

if [[ ${#ACTION_KINDS[@]} -eq 0 ]]; then
  if [[ "$INTERACTIVE" -ne 1 ]]; then
    echo "Missing input: provide at least one source.lsp or -x expression" >&2
    usage
    exit 2
  fi
fi

OS="${AUTOLISP_OS:-$(uname -s || true)}"
IS_WINDOWS=0
case "$OS" in
  MINGW*|MSYS*|CYGWIN*) IS_WINDOWS=1 ;;
esac
IS_MACOS=0
case "$OS" in
  Darwin) IS_MACOS=1 ;;
esac

if [[ -z "${ENGINE}" ]]; then
  if [[ $IS_WINDOWS -eq 1 ]]; then
    if [[ -n "${AUTOCAD_EXE:-}" || -n "${AUTOCAD_ACCORECONSOLE:-}" ]] || compgen -G "/c/Program Files/Autodesk/*/accoreconsole.exe" >/dev/null; then
      ENGINE="autocad"
    elif [[ -n "${BRICSCAD_EXE:-}" ]] || compgen -G "/c/Program Files*/Bricsys/*/bricscad.exe" >/dev/null; then
      ENGINE="bricscad"
    else
      echo "No engine found. Use --autocad or --bricscad and set AUTOCAD_EXE / AUTOCAD_ACCORECONSOLE / BRICSCAD_EXE." >&2
      exit 3
    fi
  else
    ENGINE="bricscad"
  fi
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_AUTOLISP_WORKDIR="$SCRIPT_DIR/.autolisp-runs"
BASE_WORKDIR=""
CLEANUP_WORKDIR="${AUTOLISP_KEEP_WORKDIR:-0}"
AUTOLISP_VERBOSE="${AUTOLISP_VERBOSE:-0}"
INTERRUPTED=0
INTERRUPT_COUNT=0
MACOS_ASYNC=0
BRICSCAD_BRIDGE_MODE="direct"
BRICSCAD_COM_ATTACHED=0
BRICSCAD_COM_CREATED=0
BRICSCAD_COM_MODE="${BRICSCAD_COM_MODE:-auto}"
BRICSCAD_MACOS_EFFECTIVE_MODE=""
BRICSCAD_BATCH_PID=""
BRICSCAD_BATCH_LAUNCHED=0
FORCE_REPORT_WORKDIR=0

on_interrupt() {
  INTERRUPT_COUNT=$((INTERRUPT_COUNT + 1))
  if [[ "$INTERRUPT_COUNT" -ge 2 ]]; then
    CLEANUP_WORKDIR="1"
    echo "autolisp: second interrupt received; aborting now." >&2
    exit 130
  fi
  INTERRUPTED=1
  CLEANUP_WORKDIR="1"
  echo "autolisp: interrupt requested; keeping workdir and finishing current handshake..." >&2
}

cleanup_workdir() {
  if [[ "${CLEANUP_WORKDIR}" != "1" ]]; then
    rm -rf "$WORKDIR"
  else
    if [[ "$AUTOLISP_VERBOSE" == "1" || "$INTERRUPTED" == "1" || "$FORCE_REPORT_WORKDIR" == "1" ]]; then
      echo "autolisp: keeping workdir: $WORKDIR" >&2
    fi
  fi
}
trap cleanup_workdir EXIT
trap on_interrupt INT TERM

find_macos_bricscad_app() {
  ls -1d /Applications/BricsCAD*.app 2>/dev/null | head -n 1 || true
}

find_macos_bricscad_cli() {
  if [[ -n "${BRICSCAD_EXE:-}" && -f "${BRICSCAD_EXE}" ]]; then
    printf '%s\n' "$BRICSCAD_EXE"
    return 0
  fi

  local app
  app="$(find_macos_bricscad_app)"
  if [[ -n "$app" && -x "$app/Contents/MacOS/bricscad" ]]; then
    printf '%s\n' "$app/Contents/MacOS/bricscad"
    return 0
  fi

  return 1
}

macos_app_running() {
  local appname="$1"
  local running
  running="$(
    /usr/bin/osascript - "$appname" <<'OSA' 2>/dev/null || true
on run argv
  set appName to item 1 of argv
  tell application "System Events"
    if exists process appName then
      return "1"
    end if
  end tell
  return "0"
end run
OSA
  )"
  [[ "$running" == "1" ]]
}

escape_lisp_string() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

to_abs_path() {
  local p="$1"
  local dir base
  dir="$(cd "$(dirname "$p")" && pwd)"
  base="$(basename "$p")"
  printf '%s/%s' "$dir" "$base"
}

to_lisp_path() {
  local p="$1"
  p="${p//\\//}"
  printf '%s' "$p"
}

to_windows_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$p"
  elif [[ "$p" =~ ^/([a-zA-Z])/(.*)$ ]]; then
    local drive rest
    drive="${BASH_REMATCH[1]}"
    rest="${BASH_REMATCH[2]}"
    rest="${rest//\//\\}"
    printf '%s:\\%s' "${drive^^}" "$rest"
  else
    printf '%s' "$p"
  fi
}

to_runtime_lisp_path() {
  local p="$1"
  if [[ $IS_WINDOWS -eq 1 ]]; then
    p="$(to_windows_path "$p")"
  fi
  to_lisp_path "$p"
}

escape_vbs_string() {
  local s="$1"
  s=${s//\"/\"\"}
  printf '%s' "$s"
}

find_log_file() {
  local f
  f="$(
    find "$LOGDIR" -maxdepth 1 -type f \( -name '*.log' -o -name '*.txt' \) 2>/dev/null \
      | awk 'NF' \
      | while read -r x; do
          ts=$(stat -f '%m' "$x" 2>/dev/null || stat -c '%Y' "$x" 2>/dev/null || echo 0)
          printf '%s\t%s\n' "$ts" "$x"
        done \
      | sort -nr \
      | awk 'NR==1{print $2}'
  )"
  printf '%s\n' "$f"
}

replay_from_log() {
  local logf="$1"
  [[ -n "$logf" && -f "$logf" ]] || return 0

  awk '
  BEGIN { inblock = 0; saw_output = 0 }
  /^<<<AUTOLISP-BEGIN:/ {
    kind = $0
    sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("> [%s %s]\n", a[1], a[2])
    inblock = 1
    saw_output = 0
    next
  }
  /^<<<AUTOLISP-END:/ {
    kind = $0
    sub(/^<<<AUTOLISP-END:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("=> rc=%s\n", a[3])
    inblock = 0
    next
  }
  {
    if (!inblock) next
    if ($0 ~ /^[[:space:]]*$/) next
    if (!saw_output) {
      print "OUTPUT"
      saw_output = 1
    }
    print
  }
  ' "$logf"
}

find_session_output_file() {
  local candidate

  candidate="$(find_log_file)"
  if [[ -n "$candidate" && -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
    printf '%s\n' "$candidate"
    return 0
  fi

  for candidate in \
    "$WORKDIR/direct-stdout.txt" \
    "$WORKDIR/bricscad-stdout.txt" \
    "$WORKDIR/autocad-stdout.txt"
  do
    if [[ -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

render_stdout() {
  local outfile="$1"
  local sessionfile="${2:-}"

  awk -v sessionfile="$sessionfile" '
  function append_output_line(line) {
    pending_output = pending_output line "\n"
  }
  function flush_output(    n, arr, i) {
    if (pending_output == "") return
    print "OUTPUT"
    n = split(pending_output, arr, "\n")
    for (i = 1; i <= n; i++) {
      if (arr[i] != "") print arr[i]
    }
    pending_output = ""
  }
  BEGIN {
    action_idx = 0
    pending_output = ""

    if (sessionfile != "") {
      inblock = 0
      while ((getline line < sessionfile) > 0) {
        if (line ~ /^<<<AUTOLISP-BEGIN:/) {
          kind = line
          sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
          sub(/>>>$/, "", kind)
          split(kind, a, ":")
          block_key = a[1] ":" a[2]
          block_lines[block_key] = ""
          inblock = 1
          continue
        }
        if (line ~ /^<<<AUTOLISP-END:/) {
          inblock = 0
          block_key = ""
          continue
        }
        if (!inblock) continue
        if (line ~ /^[[:space:]]*$/) continue
        block_lines[block_key] = block_lines[block_key] line "\n"
      }
      close(sessionfile)
    }
  }
  /^LOAD / {
    action_idx++
    pending_output = block_lines["LOAD:" action_idx]
    print
    next
  }
  /^EVAL / {
    action_idx++
    pending_output = block_lines["EXPR:" action_idx]
    print
    next
  }
  /^MAIN / {
    action_idx++
    pending_output = block_lines["MAIN:" action_idx]
    print
    next
  }
  /^<<<AUTOLISP-STDOUT>>>/ {
    append_output_line(substr($0, 22))
    next
  }
  /^LOADED / || /^RESULT / || /^MAIN-RESULT / {
    flush_output()
    print
    next
  }
  {
    print
  }
  END {
    flush_output()
  }
  ' "$outfile"
}

declare -a SEARCH_DIRS=()
declare -a LOAD_PATHS=()
declare -a EVAL_PATHS=()
HAS_LOAD_ACTION=0

case "$BRICSCAD_MACOS_MODE" in
  auto|osascript|batch) ;;
  *)
    echo "Invalid BRICSCAD_MACOS_MODE: $BRICSCAD_MACOS_MODE" >&2
    exit 2
    ;;
esac

case "$BRICSCAD_MACOS_APP_MODE" in
  attach|launch) ;;
  *)
    echo "Invalid BRICSCAD_MACOS_APP_MODE: $BRICSCAD_MACOS_APP_MODE" >&2
    exit 2
    ;;
esac

case "$BOOTSTRAP_PHASE" in
  marker|core|log|full) ;;
  *)
    echo "Invalid AUTOLISP_BOOTSTRAP_PHASE: $BOOTSTRAP_PHASE" >&2
    exit 2
    ;;
esac

if [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 ]]; then
  BRICSCAD_MACOS_EFFECTIVE_MODE="$BRICSCAD_MACOS_MODE"
  if [[ "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "auto" ]]; then
    if find_macos_bricscad_cli >/dev/null 2>&1; then
      BRICSCAD_MACOS_EFFECTIVE_MODE="batch"
    else
      BRICSCAD_MACOS_EFFECTIVE_MODE="osascript"
    fi
  fi
fi

if [[ -n "${AUTOLISP_WORKDIR:-}" ]]; then
  BASE_WORKDIR="${AUTOLISP_WORKDIR}"
elif [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]]; then
  BASE_WORKDIR="${TMPDIR:-/tmp}/autolisp-runs"
else
  BASE_WORKDIR="$DEFAULT_AUTOLISP_WORKDIR"
fi
mkdir -p "$BASE_WORKDIR"
WORKDIR="$(mktemp -d "$BASE_WORKDIR/autolisp.XXXXXX")"

OUTFILE="$WORKDIR/output.txt"
ERRFILE="$WORKDIR/errors.txt"
STATUSFILE="$WORKDIR/status.txt"
INPFILE="$WORKDIR/input.lsp"
BATCH_EXIT_FILE="$WORKDIR/batch-exit.txt"
LOGDIR="$WORKDIR/logs"
: >"$OUTFILE"
: >"$ERRFILE"
echo "__PENDING__" >"$STATUSFILE"
rm -f "$INPFILE"
rm -f "$BATCH_EXIT_FILE"
mkdir -p "$LOGDIR"

LISP_OUTFILE="$(to_runtime_lisp_path "$OUTFILE")"
LISP_ERRFILE="$(to_runtime_lisp_path "$ERRFILE")"
LISP_STATUSFILE="$(to_runtime_lisp_path "$STATUSFILE")"
LISP_INPFILE="$(to_runtime_lisp_path "$INPFILE")"
LISP_LOGDIR="$(to_runtime_lisp_path "$LOGDIR")"
LISP_RENDERFILE="$(to_runtime_lisp_path "$WORKDIR/render.txt")"

for i in "${!ACTION_KINDS[@]}"; do
  kind="${ACTION_KINDS[$i]}"
  value="${ACTION_VALUES[$i]}"
  if [[ "$kind" == "load" ]]; then
    if [[ ! -f "$value" ]]; then
      echo "Not found: $value" >&2
      exit 2
    fi
    abs_src="$(to_abs_path "$value")"
    abs_src="$(to_runtime_lisp_path "$abs_src")"
    abs_dir="$(dirname "$abs_src")"
    LOAD_PATHS+=("$abs_src")
    HAS_LOAD_ACTION=1

    already_present=0
    for existing in "${SEARCH_DIRS[@]:-}"; do
      if [[ "$existing" == "$abs_dir" ]]; then
        already_present=1
        break
      fi
    done
    if [[ $already_present -eq 0 ]]; then
      SEARCH_DIRS+=("$abs_dir")
    fi
  else
    LOAD_PATHS+=("")
    eval_file="$WORKDIR/eval-$((i + 1)).lsp"
    printf '%s' "$value" >"$eval_file"
    EVAL_PATHS+=("$(to_runtime_lisp_path "$eval_file")")
  fi
done

USE_BATCH_INTERACTIVE_REPL=0
if [[ "$INTERACTIVE" -eq 1 && "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]]; then
  USE_BATCH_INTERACTIVE_REPL=1
fi
if [[ "$INTERACTIVE" -eq 1 && "$USE_BATCH_INTERACTIVE_REPL" -eq 0 ]]; then
  run_interactive_repl
  exit $?
fi

QUIT_ON_FINISH=1
if [[ "$ENGINE" == "bricscad" && $IS_WINDOWS -eq 1 && "$BRICSCAD_COM_MODE" != "off" ]]; then
  if [[ "$BRICSCAD_COM_MODE" == "attach" ]]; then
    QUIT_ON_FINISH=0
  fi
fi
if [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]]; then
  QUIT_ON_FINISH=0
fi

RUNLSPFILE="$WORKDIR/run-common.lsp"
if [[ "$BOOTSTRAP_PHASE" == "marker" ]]; then
  {
    printf '(setq f (open "%s" "w"))\n' "$(escape_lisp_string "$LISP_OUTFILE")"
    echo '(if f (progn (write-line "BOOTSTRAP MARKER" f) (close f)))'
    printf '(setq f (open "%s" "w"))\n' "$(escape_lisp_string "$LISP_STATUSFILE")"
    echo '(if f (progn (write-line "0" f) (close f)))'
  } >"$RUNLSPFILE"
elif [[ "$BOOTSTRAP_PHASE" == "core" && ${#ACTION_KINDS[@]} -eq 1 && "${ACTION_KINDS[0]}" == "eval" && "$HAS_LOAD_ACTION" -eq 0 ]]; then
  {
    printf '(setq *AUTOLISP_OUTFILE* "%s")\n' "$(escape_lisp_string "$LISP_OUTFILE")"
    printf '(setq *AUTOLISP_STATUSFILE* "%s")\n' "$(escape_lisp_string "$LISP_STATUSFILE")"
    printf '(setq *AUTOLISP_RENDERFILE* "%s")\n' "$(escape_lisp_string "$LISP_RENDERFILE")"
    cat <<'EOLISP'
(defun autolisp-slurp-file (path / f line acc)
  (setq f (open path "r"))
  (if (not f)
    ""
    (progn
      (setq acc "")
      (while (setq line (read-line f))
        (if (= acc "")
          (setq acc line)
          (setq acc (strcat acc "\n" line))))
      (close f)
      acc)))

(defun autolisp-render (obj / f)
  (setq f (open *AUTOLISP_RENDERFILE* "w"))
  (if f
    (progn
      (prin1 obj f)
      (close f)
      (autolisp-slurp-file *AUTOLISP_RENDERFILE*))
    "<unprintable>"))
EOLISP
    printf '(setq f (open *AUTOLISP_OUTFILE* "w"))\n'
    echo '(if f (close f))'
    printf '(setq f (open *AUTOLISP_STATUSFILE* "w"))\n'
    echo '(if f (progn (write-line "99" f) (close f)))'
    printf '(setq expr-text "%s")\n' "$(escape_lisp_string "${ACTION_VALUES[0]}")"
    echo '(setq expr (read expr-text))'
    echo '(setq result (eval expr))'
    printf '(setq f (open *AUTOLISP_OUTFILE* "a"))\n'
    echo '(if f (progn (write-line (strcat "EVAL " expr-text) f) (write-line (strcat "RESULT " (autolisp-render result)) f) (write-line "TOTAL=1 OK=1 FAIL=0 ERROR=0" f) (close f)))'
    printf '(setq f (open *AUTOLISP_STATUSFILE* "w"))\n'
    echo '(if f (progn (write-line "0" f) (close f)))'
  } >"$RUNLSPFILE"
else
{
  if [[ ${#SEARCH_DIRS[@]} -gt 0 ]]; then
    echo '(setq _autolisp_old_srchpath (getvar "SRCHPATH"))'
    srch_prefix=""
    for dir in "${SEARCH_DIRS[@]}"; do
      srch_prefix+="$(escape_lisp_string "$dir");"
    done
    printf '(setvar "SRCHPATH" (strcat "%s" _autolisp_old_srchpath))\n' "$srch_prefix"
  else
    echo '(setq _autolisp_old_srchpath nil)'
  fi
  printf '(setq *AUTOLISP_OUTFILE* "%s")\n' "$(escape_lisp_string "$LISP_OUTFILE")"
  printf '(setq *AUTOLISP_ERRFILE* "%s")\n' "$(escape_lisp_string "$LISP_ERRFILE")"
  printf '(setq *AUTOLISP_STATUSFILE* "%s")\n' "$(escape_lisp_string "$LISP_STATUSFILE")"
  printf '(setq *AUTOLISP_INPFILE* "%s")\n' "$(escape_lisp_string "$LISP_INPFILE")"
  printf '(setq *AUTOLISP_LOGDIR* "%s")\n' "$(escape_lisp_string "$LISP_LOGDIR")"
  printf '(setq *AUTOLISP_RENDERFILE* "%s")\n' "$(escape_lisp_string "$LISP_RENDERFILE")"
  printf '(setq *AUTOLISP_LOGNAME* "%s")\n' "autolisp-session.log"
  printf '(setq *AUTOLISP_QUIT_ON_FINISH* %s)\n' "$QUIT_ON_FINISH"
  printf '(setq *AUTOLISP_BOOTSTRAP_PHASE* "%s")\n' "$(escape_lisp_string "$BOOTSTRAP_PHASE")"
  cat <<'EOLISP'
(defun autolisp-write-line (path text / f)
  (setq f (open path "a"))
  (if f
    (progn
      (write-line text f)
      (close f))))

(defun autolisp-reset-file (path / f)
  (setq f (open path "w"))
  (if f (close f)))

(defun autolisp-slurp-file (path / f line acc)
  (setq f (open path "r"))
  (if (not f)
    ""
    (progn
      (setq acc "")
      (while (setq line (read-line f))
        (if (= acc "")
          (setq acc line)
          (setq acc (strcat acc "\n" line))))
      (close f)
      acc)))

(defun autolisp-str (obj)
  (if (= (type obj) 'STR)
    obj
    (autolisp-render obj)))

(defun autolisp-render (obj / f)
  (setq f (open *AUTOLISP_RENDERFILE* "w"))
  (if f
    (progn
      (prin1 obj f)
      (close f)
      (autolisp-slurp-file *AUTOLISP_RENDERFILE*))
    "<unprintable>"))

(defun autolisp-set-status (code / f)
  (setq f (open *AUTOLISP_STATUSFILE* "w"))
  (if f
    (progn
      (write-line (itoa code) f)
      (close f)))
  code)

(defun autolisp-set-status-text (text / f)
  (setq f (open *AUTOLISP_STATUSFILE* "w"))
  (if f
    (progn
      (write-line text f)
      (close f)))
  text)

(defun autolisp-log-out (text)
  (autolisp-write-line *AUTOLISP_OUTFILE* text))

(defun autolisp-log-err (text)
  (autolisp-write-line *AUTOLISP_ERRFILE* text))

(defun autolisp-stdout-prefix ()
  "<<<AUTOLISP-STDOUT>>>")

(defun autolisp-stdout-text (obj)
  (if (= (type obj) 'STR)
    (strcat "\"" obj "\"")
    (autolisp-str obj)))

(defun autolisp-emit-user-out (obj)
  (if *AUTOLISP_CAPTURE_STDOUT*
    (autolisp-write-line *AUTOLISP_OUTFILE*
                         (strcat (autolisp-stdout-prefix)
                                 (autolisp-stdout-text obj))))
  obj)

(defun autolisp-mark-begin (kind idx)
  nil)

(defun autolisp-mark-end (kind idx rc)
  nil)

(defun autolisp-finish (code)
  (if *AUTOLISP_LOG_STATE*
    (autolisp-log-restore *AUTOLISP_LOG_STATE*))
  (if _autolisp_old_srchpath
    (setvar "SRCHPATH" _autolisp_old_srchpath))
  (autolisp-set-status code)
  (if *AUTOLISP_QUIT_ON_FINISH*
    (quit))
  code)

(defun autolisp-run-load (idx path / r olderr)
  (autolisp-mark-begin "LOAD" idx)
  (autolisp-log-out (strcat "LOAD " path))
  (setq *AUTOLISP_CAPTURE_STDOUT* T)
  (setq *AUTOLISP_ERROR_MSG* nil)
  (setq olderr *error*)
  (setq *error* autolisp-trap-error)
  (setq r (load path))
  (setq *error* olderr)
  (setq *AUTOLISP_CAPTURE_STDOUT* nil)
  (if *AUTOLISP_ERROR_MSG*
    (progn
      (autolisp-log-err (strcat "ERROR load " path ": " *AUTOLISP_ERROR_MSG*))
      (autolisp-mark-end "LOAD" idx 1)
      nil)
    (progn
      (autolisp-log-out (strcat "LOADED " path))
      (autolisp-mark-end "LOAD" idx 0)
      T)))

(defun autolisp-trap-error (msg)
  (setq *AUTOLISP_ERROR_MSG* msg)
  nil)

(defun autolisp-run-eval-file (idx path / form-text form-read r olderr ok)
  (autolisp-mark-begin "EXPR" idx)
  (setq ok nil)
  (setq form-text (autolisp-slurp-file path))
  (if (null form-text)
    (progn
      (autolisp-log-err (strcat "ERROR read-file " path ": unable to open expression file"))
      (autolisp-mark-end "EXPR" idx 1))
    (progn
      (autolisp-log-out (strcat "EVAL " form-text))
      (setq *AUTOLISP_ERROR_MSG* nil)
      (setq olderr *error*)
      (setq *error* autolisp-trap-error)
      (setq form-read (read form-text))
      (setq *error* olderr)
      (if *AUTOLISP_ERROR_MSG*
        (progn
          (autolisp-log-err (strcat "ERROR read " form-text ": " *AUTOLISP_ERROR_MSG*))
          (autolisp-mark-end "EXPR" idx 1))
        (progn
          (setq *AUTOLISP_CAPTURE_STDOUT* T)
          (setq *AUTOLISP_ERROR_MSG* nil)
          (setq olderr *error*)
          (setq *error* autolisp-trap-error)
          (setq r (eval form-read))
          (setq *error* olderr)
          (setq *AUTOLISP_CAPTURE_STDOUT* nil)
          (if *AUTOLISP_ERROR_MSG*
            (progn
              (autolisp-log-err (strcat "ERROR eval " form-text ": " *AUTOLISP_ERROR_MSG*))
              (autolisp-mark-end "EXPR" idx 1))
            (progn
              (autolisp-log-out (strcat "RESULT " (autolisp-str r)))
              (autolisp-mark-end "EXPR" idx 0)
              (setq ok T))))))
  ok)

(defun autolisp-run-main (idx main-name / sym-read r olderr)
  (autolisp-mark-begin "MAIN" idx)
  (autolisp-log-out (strcat "MAIN " main-name))
  (setq *AUTOLISP_ERROR_MSG* nil)
  (setq olderr *error*)
  (setq *error* autolisp-trap-error)
  (setq sym-read (read main-name))
  (setq *error* olderr)
  (if *AUTOLISP_ERROR_MSG*
    (progn
      (autolisp-log-err (strcat "ERROR read-main " main-name ": " *AUTOLISP_ERROR_MSG*))
      (autolisp-mark-end "MAIN" idx 1)
      nil)
    (progn
      (setq *AUTOLISP_CAPTURE_STDOUT* T)
      (setq *AUTOLISP_ERROR_MSG* nil)
      (setq olderr *error*)
      (setq *error* autolisp-trap-error)
      (setq r (sym-read))
      (setq *error* olderr)
      (setq *AUTOLISP_CAPTURE_STDOUT* nil)
      (if *AUTOLISP_ERROR_MSG*
        (progn
          (autolisp-log-err (strcat "ERROR main " main-name ": " *AUTOLISP_ERROR_MSG*))
          (autolisp-mark-end "MAIN" idx 1)
          nil)
        (progn
          (autolisp-log-out (strcat "MAIN-RESULT " (autolisp-str r)))
          (autolisp-mark-end "MAIN" idx 0)
          T)))))

(setq *AUTOLISP_TOTAL* 0)
(setq *AUTOLISP_OK* 0)
(setq *AUTOLISP_FAIL* 0)
(setq *AUTOLISP_ERROR* 0)
(setq *AUTOLISP_CAPTURE_STDOUT* nil)
(setq *AUTOLISP_ERROR_MSG* nil)

(defun autolisp-note-ok ()
  (setq *AUTOLISP_TOTAL* (+ *AUTOLISP_TOTAL* 1))
  (setq *AUTOLISP_OK* (+ *AUTOLISP_OK* 1)))

(defun autolisp-note-fail ()
  (setq *AUTOLISP_TOTAL* (+ *AUTOLISP_TOTAL* 1))
  (setq *AUTOLISP_FAIL* (+ *AUTOLISP_FAIL* 1)))

(defun autolisp-summary-line ()
  (strcat "TOTAL=" (itoa *AUTOLISP_TOTAL*)
          " OK=" (itoa *AUTOLISP_OK*)
          " FAIL=" (itoa *AUTOLISP_FAIL*)
          " ERROR=" (itoa *AUTOLISP_ERROR*)))

(autolisp-reset-file *AUTOLISP_OUTFILE*)
(autolisp-reset-file *AUTOLISP_ERRFILE*)
(autolisp-set-status 99)
(setq *AUTOLISP_LOG_STATE* nil)
EOLISP
  if [[ "$BOOTSTRAP_PHASE" == "log" || "$BOOTSTRAP_PHASE" == "full" ]]; then
    cat <<'EOLISP'
(defun autolisp-safe-getvar (name)
  (getvar name))

(defun autolisp-safe-setvar (name value)
  (setvar name value))

(defun autolisp-log-setup (/ old-mode old-path old-name)
  (setq old-mode (autolisp-safe-getvar "LOGFILEMODE"))
  (setq old-path (autolisp-safe-getvar "LOGFILEPATH"))
  (setq old-name (autolisp-safe-getvar "LOGFILENAME"))
  (autolisp-safe-setvar "LOGFILEPATH" *AUTOLISP_LOGDIR*)
  (if *AUTOLISP_LOGNAME*
    (autolisp-safe-setvar "LOGFILENAME" *AUTOLISP_LOGNAME*))
  (autolisp-safe-setvar "LOGFILEMODE" 1)
  (list old-mode old-path old-name))

(defun autolisp-log-restore (state / old-mode old-path old-name)
  (if state
    (progn
      (setq old-mode (nth 0 state))
      (setq old-path (nth 1 state))
      (setq old-name (nth 2 state))
      (if old-path (autolisp-safe-setvar "LOGFILEPATH" old-path))
      (if old-name (autolisp-safe-setvar "LOGFILENAME" old-name))
      (if old-mode (autolisp-safe-setvar "LOGFILEMODE" old-mode)))))

(setq *AUTOLISP_LOG_STATE* (autolisp-log-setup))
EOLISP
  fi
  if [[ "$BOOTSTRAP_PHASE" == "full" ]]; then
    cat <<'EOLISP'
;; Mirror interactive output to OUTFILE so results do not depend on CAD session logs.
(defun print (obj)
  (autolisp-emit-user-out obj))

(defun princ (obj)
  (if obj
    (autolisp-emit-user-out obj)
    obj))

(defun prin1 (obj)
  (autolisp-emit-user-out obj))

(defun prompt (msg)
  (if msg
    (autolisp-emit-user-out msg)
    msg))

(defun autolisp-slurp-lines (path / f line acc)
  (setq f (open path "r"))
  (if (not f)
    nil
    (progn
      (setq acc '())
      (while (setq line (read-line f))
        (setq acc (cons line acc)))
      (close f)
      (reverse acc))))

(defun autolisp-lines->text (lines / acc)
  (setq acc "")
  (while lines
    (if (= acc "")
      (setq acc (car lines))
      (setq acc (strcat acc "\n" (car lines))))
    (setq lines (cdr lines)))
  acc)

(defun autolisp-sleep-ms (ms / r)
  (setq r (vl-catch-all-apply 'vlax-sleep (list ms)))
  (if (vl-catch-all-error-p r)
    (vl-catch-all-apply 'command (list "_DELAY" ms)))
  nil)

(defun autolisp-repl-reset-counters ()
  (setq *AUTOLISP_TOTAL* 0)
  (setq *AUTOLISP_OK* 0)
  (setq *AUTOLISP_FAIL* 0)
  (setq *AUTOLISP_ERROR* 0))

(defun autolisp-run-repl-request (/ lines req-id form-text f form-read r)
  (setq lines (autolisp-slurp-lines *AUTOLISP_INPFILE*))
  (if (null lines)
    nil
    (progn
      (setq req-id "0")
      (if (and lines (wcmatch (car lines) ";REQ *"))
        (setq req-id (substr (car lines) 6)))
      (setq form-text (autolisp-lines->text (cdr lines)))
      (autolisp-reset-file *AUTOLISP_OUTFILE*)
      (autolisp-reset-file *AUTOLISP_ERRFILE*)
      (autolisp-repl-reset-counters)
      (setq f (open *AUTOLISP_INPFILE* "r"))
      (if (null f)
        (progn
          (autolisp-log-err "ERROR open request file: unable to reopen input")
          (autolisp-note-fail)
          (autolisp-log-out (autolisp-summary-line))
          (autolisp-set-status-text (strcat "READY " req-id))
          T)
        (progn
          (read-line f)
          (setq form-read (vl-catch-all-apply 'read (list f)))
          (close f)
          (vl-file-delete *AUTOLISP_INPFILE*)
          (if (vl-catch-all-error-p form-read)
            (progn
              (autolisp-log-err (strcat "ERROR read repl request: " (vl-catch-all-error-message form-read)))
              (autolisp-note-fail)
              (autolisp-log-out (autolisp-summary-line))
              (autolisp-set-status-text (strcat "READY " req-id))
              T)
            (if (equal form-read '__AUTOLISP_QUIT__)
              (progn
                (autolisp-set-status-text (strcat "STOP " req-id))
                nil)
              (progn
                (autolisp-log-out (strcat "EVAL " form-text))
                (setq *AUTOLISP_CAPTURE_STDOUT* T)
                (setq r (vl-catch-all-apply 'eval (list form-read)))
                (setq *AUTOLISP_CAPTURE_STDOUT* nil)
                (if (vl-catch-all-error-p r)
                  (progn
                    (autolisp-log-err (strcat "ERROR eval " form-text ": " (vl-catch-all-error-message r)))
                    (autolisp-note-fail))
                  (progn
                    (autolisp-log-out (strcat "RESULT " (autolisp-str r)))
                    (autolisp-note-ok)))
                (autolisp-log-out (autolisp-summary-line))
                (autolisp-set-status-text (strcat "READY " req-id))
                T))))))))

(defun autolisp-repl-loop (/ keep-going)
  (autolisp-set-status-text "READY 0")
  (setq keep-going T)
  (while keep-going
    (while (not (findfile *AUTOLISP_INPFILE*))
      (autolisp-sleep-ms 100))
    (if (not (autolisp-run-repl-request))
      (setq keep-going nil)))
  (command "_QUIT" "_Y"))
EOLISP
  fi
  if [[ "$INTERACTIVE" -eq 1 && "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]]; then
    cat <<'EOLISP'
(autolisp-repl-loop)
EOLISP
  else
    for i in "${!ACTION_KINDS[@]}"; do
      kind="${ACTION_KINDS[$i]}"
      value="${ACTION_VALUES[$i]}"
      idx=$((i + 1))
      if [[ "$kind" == "load" ]]; then
        abs_src="${LOAD_PATHS[$i]}"
        printf '(if (autolisp-run-load %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' "$idx" "$(escape_lisp_string "$abs_src")"
      else
        eval_src="${EVAL_PATHS[$i]}"
        printf '(if (autolisp-run-eval-file %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' "$idx" "$(escape_lisp_string "$eval_src")"
      fi
    done

    if [[ "$HAS_LOAD_ACTION" -eq 1 ]]; then
      printf '(if (= *AUTOLISP_FAIL* 0) (if (autolisp-run-main %s "%s") (autolisp-note-ok) (autolisp-note-fail)))\n' "$(( ${#ACTION_KINDS[@]} + 1 ))" "$(escape_lisp_string "$MAIN")"
    fi

    cat <<'EOLISP'
(autolisp-log-out (autolisp-summary-line))
(if (> *AUTOLISP_FAIL* 0)
  (autolisp-finish 1)
  (autolisp-finish 0))
EOLISP
  fi
} >"$RUNLSPFILE"
fi

SCRFILE="$WORKDIR/run.scr"
cat >"$SCRFILE" <<EOF2
_.COMMANDLINE
(load "$(escape_lisp_string "$RUNLSPFILE")")
EOF2
if [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]]; then
  cat >>"$SCRFILE" <<'EOF2'
(command "_QUIT" "_Y")
EOF2
fi

export OUTFILE ERRFILE STATUSFILE INPFILE

write_windows_autocad_vbs() {
  local vbs="$WORKDIR/bridge-autocad.vbs"
  local win_runlsp win_err win_exe
  win_runlsp="$(to_windows_path "$RUNLSPFILE")"
  win_err="$(to_windows_path "$ERRFILE")"
  win_exe="${AUTOCAD_EXE:-}"
  if [[ -n "$win_exe" ]]; then
    win_exe="$(to_windows_path "$win_exe")"
  fi

  cat >"$vbs" <<EOFVBS
Option Explicit
Dim fso, shell, mode, exePath, runLsp, errFile
Dim app, doc, cmd, progid, created, attached, rc
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")
mode = "$(escape_vbs_string "$AUTOCAD_COM_MODE")"
exePath = "$(escape_vbs_string "$win_exe")"
runLsp = "$(escape_vbs_string "$win_runlsp")"
errFile = "$(escape_vbs_string "$win_err")"
progid = "AutoCAD.Application"
created = False
attached = False
rc = 0

Sub AppendLine(path, text)
  Dim f
  Set f = fso.OpenTextFile(path, 8, True)
  f.WriteLine text
  f.Close
End Sub

Function AttachApp()
  On Error Resume Next
  Set AttachApp = GetObject(, progid)
  If Err.Number <> 0 Then
    Err.Clear
    Set AttachApp = Nothing
  End If
  On Error GoTo 0
End Function

Function CreateApp()
  On Error Resume Next
  If exePath <> "" Then
    shell.Environment("PROCESS")("AUTOCAD_LOCATION") = exePath
  End If
  Set CreateApp = CreateObject(progid)
  If Err.Number <> 0 Then
    Err.Clear
    Set CreateApp = Nothing
  End If
  On Error GoTo 0
End Function

If mode = "attach" Or mode = "auto" Then
  Set app = AttachApp()
  If Not app Is Nothing Then attached = True
End If

If app Is Nothing Then
  If mode = "attach" Then
    AppendLine errFile, "ERROR COM attach: no running AutoCAD instance found."
    WScript.Quit 2
  End If
  If mode = "launch" Or mode = "auto" Then
    Set app = CreateApp()
    If app Is Nothing Then
      AppendLine errFile, "ERROR COM launch: unable to create AutoCAD COM application."
      WScript.Quit 3
    End If
    created = True
  End If
End If

If app Is Nothing Then
  AppendLine errFile, "ERROR COM bridge: unsupported AutoCAD COM mode."
  WScript.Quit 4
End If

On Error Resume Next
app.Visible = True
If Err.Number <> 0 Then Err.Clear
Set doc = app.ActiveDocument
If Err.Number <> 0 Then
  Err.Clear
  Set doc = Nothing
End If
If doc Is Nothing Then
  Set doc = app.Documents.Add
  If Err.Number <> 0 Then
    AppendLine errFile, "ERROR COM bridge: unable to get or create AutoCAD ActiveDocument."
    Err.Clear
    WScript.Quit 5
  End If
End If
cmd = "(load """ & Replace(runLsp, "\", "/") & """)" & vbCr
Err.Clear
Call doc.SendCommand(cmd)
If Err.Number <> 0 Then
  AppendLine errFile, "ERROR COM bridge: AutoCAD SendCommand failed: " & Err.Description
  Err.Clear
  rc = 6
End If
On Error GoTo 0
WScript.Quit rc
EOFVBS
  printf '%s' "$vbs"
}

run_windows_autocad() {
  if [[ "$AUTOCAD_COM_MODE" != "off" ]]; then
    local cscript=""
    if command -v cscript >/dev/null 2>&1; then
      cscript="$(command -v cscript)"
    elif [[ -x /c/Windows/System32/cscript.exe ]]; then
      cscript="/c/Windows/System32/cscript.exe"
    fi
    if [[ -n "$cscript" ]]; then
      local vbs
      vbs="$(write_windows_autocad_vbs)"
      "$cscript" //nologo "$vbs" >"$WORKDIR/autocad-com-stdout.txt" 2>"$WORKDIR/autocad-com-stderr.txt" || true
      wait_for_status
      return 0
    fi
    echo "cscript.exe not found; falling back to direct AutoCAD launch." >&2
  fi

  if [[ -n "$AUTOCAD_EXE" && -f "$AUTOCAD_EXE" ]]; then
    "$AUTOCAD_EXE" /b "$RUNLSPFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
    return 0
  fi

  local acc="${AUTOCAD_ACCORECONSOLE:-}"
  if [[ -z "$acc" ]]; then
    acc="$(ls -1 "/c/Program Files/Autodesk"/*/accoreconsole.exe 2>/dev/null | head -n 1 || true)"
  fi
  local dwg="${DWG:-${AUTOLISP_DWG:-}}"
  if [[ -z "$acc" || ! -f "$acc" ]]; then
    echo "Neither AutoCAD COM/direct nor accoreconsole.exe is available. Set AUTOCAD_EXE or AUTOCAD_ACCORECONSOLE." >&2
    return 3
  fi
  if [[ -z "$dwg" || ! -f "$dwg" ]]; then
    echo "AutoCAD Core Console needs a DWG. Provide --dwg file.dwg or set AUTOLISP_DWG." >&2
    return 2
  fi

  "$acc" /i "$dwg" /s "$SCRFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
}

write_windows_bricscad_vbs() {
  local vbs="$WORKDIR/bridge-bricscad.vbs"
  local win_runlsp win_status win_out win_err win_exe mode
  win_runlsp="$(to_windows_path "$RUNLSPFILE")"
  win_status="$(to_windows_path "$STATUSFILE")"
  win_out="$(to_windows_path "$OUTFILE")"
  win_err="$(to_windows_path "$ERRFILE")"
  mode="$BRICSCAD_COM_MODE"
  win_exe="${BRICSCAD_EXE:-}"
  if [[ -n "$win_exe" ]]; then
    win_exe="$(to_windows_path "$win_exe")"
  fi

  cat >"$vbs" <<EOFVBS
Option Explicit
Dim fso, shell, mode, exePath, runLsp, statusFile, outFile, errFile
Dim app, doc, cmd, created, attached, rc
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")
mode = "$(escape_vbs_string "$mode")"
exePath = "$(escape_vbs_string "$win_exe")"
runLsp = "$(escape_vbs_string "$win_runlsp")"
statusFile = "$(escape_vbs_string "$win_status")"
outFile = "$(escape_vbs_string "$win_out")"
errFile = "$(escape_vbs_string "$win_err")"
created = False
attached = False
rc = 0

Sub AppendLine(path, text)
  Dim f
  Set f = fso.OpenTextFile(path, 8, True)
  f.WriteLine text
  f.Close
End Sub

Function TryGetApp()
  On Error Resume Next
  Set TryGetApp = GetObject(, "BricscadApp.AcadApplication")
  If Err.Number <> 0 Then
    Err.Clear
    Set TryGetApp = Nothing
  End If
  On Error GoTo 0
End Function

Function TryCreateApp()
  On Error Resume Next
  If exePath <> "" Then
    shell.Environment("PROCESS")("BRICSCAD_LOCATION") = exePath
  End If
  Set TryCreateApp = CreateObject("BricscadApp.AcadApplication")
  If Err.Number <> 0 Then
    Err.Clear
    Set TryCreateApp = Nothing
  End If
  On Error GoTo 0
End Function

Set app = Nothing
If mode = "attach" Or mode = "auto" Then
  Set app = TryGetApp()
  If Not app Is Nothing Then attached = True
End If

If app Is Nothing Then
  If mode = "attach" Then
    AppendLine errFile, "ERROR COM attach: no running BricsCAD instance found."
    rc = 2
    WScript.Echo "ATTACHED=0"
    WScript.Echo "CREATED=0"
    WScript.Quit rc
  End If
  If mode = "launch" Or mode = "auto" Then
    Set app = TryCreateApp()
    If app Is Nothing Then
      AppendLine errFile, "ERROR COM launch: unable to create BricsCAD COM application."
      rc = 3
      WScript.Echo "ATTACHED=0"
      WScript.Echo "CREATED=0"
      WScript.Quit rc
    End If
    created = True
  End If
End If

If app Is Nothing Then
  AppendLine errFile, "ERROR COM bridge: unsupported mode or COM unavailable."
  rc = 4
  WScript.Echo "ATTACHED=0"
  WScript.Echo "CREATED=0"
  WScript.Quit rc
End If

On Error Resume Next
app.Visible = True
If Err.Number <> 0 Then Err.Clear
Set doc = app.ActiveDocument
If Err.Number <> 0 Then
  Err.Clear
  Set doc = Nothing
End If
If doc Is Nothing Then
  Set doc = app.Documents.Add
  If Err.Number <> 0 Then
    AppendLine errFile, "ERROR COM bridge: unable to get or create ActiveDocument."
    Err.Clear
    rc = 5
    If attached Then
      WScript.Echo "ATTACHED=1"
    Else
      WScript.Echo "ATTACHED=0"
    End If
    If created Then
      WScript.Echo "CREATED=1"
    Else
      WScript.Echo "CREATED=0"
    End If
    WScript.Quit rc
  End If
End If
cmd = "(load """ & Replace(runLsp, "\", "/") & """)" & vbCr
Err.Clear
Call doc.SendCommand(cmd)
If Err.Number <> 0 Then
  AppendLine errFile, "ERROR COM bridge: SendCommand failed: " & Err.Description
  Err.Clear
  rc = 6
Else
  rc = 0
End If
On Error GoTo 0
If attached Then
  WScript.Echo "ATTACHED=1"
Else
  WScript.Echo "ATTACHED=0"
End If
If created Then
  WScript.Echo "CREATED=1"
Else
  WScript.Echo "CREATED=0"
End If
WScript.Quit rc
EOFVBS
  printf '%s' "$vbs"
}

wait_for_status() {
  local timeout="$TIMEOUT_SECS"
  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi
    local s
    s="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    if [[ -n "$s" && "$s" != "__PENDING__" && "$s" != "99" ]]; then
      return 0
    fi
    if batch_runner_done_without_status "$s"; then
      return 1
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  echo "ERROR: timeout waiting for CAD runner completion after ${TIMEOUT_SECS}s" >&2
  if [[ "$ENGINE" == "bricscad" && $IS_WINDOWS -eq 0 && "$MACOS_ASYNC" -eq 1 ]]; then
    local status_trimmed has_output has_errors
    status_trimmed="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    has_output=0
    has_errors=0
    [[ -s "$OUTFILE" ]] && has_output=1
    [[ -s "$ERRFILE" ]] && has_errors=1
    if [[ "${status_trimmed:-}" == "__PENDING__" && "$has_output" -eq 0 && "$has_errors" -eq 0 ]]; then
      echo "HINT: on macOS + BricsCAD, select the \"2D Drafting\" workspace, not \"2D Drafting (Modern)\", then retry." >&2
    fi
  fi
  return 124
}

run_windows_bricscad() {
  local exe="${BRICSCAD_EXE:-}"
  if [[ -z "$exe" ]]; then
    exe="$(ls -1 "/c/Program Files"*/Bricsys/*/bricscad.exe 2>/dev/null | head -n 1 || true)"
  fi
  if [[ "$BRICSCAD_COM_MODE" != "off" ]]; then
    local cscript=""
    if command -v cscript >/dev/null 2>&1; then
      cscript="$(command -v cscript)"
    elif [[ -x /c/Windows/System32/cscript.exe ]]; then
      cscript="/c/Windows/System32/cscript.exe"
    fi
    if [[ -n "$cscript" ]]; then
      BRICSCAD_BRIDGE_MODE="com"
      [[ -n "$exe" ]] && export BRICSCAD_EXE="$exe"
      local vbs
      vbs="$(write_windows_bricscad_vbs)"
      "$cscript" //nologo "$vbs" >"$WORKDIR/bricscad-com-stdout.txt" 2>"$WORKDIR/bricscad-com-stderr.txt" || true
      if grep -q '^ATTACHED=1$' "$WORKDIR/bricscad-com-stdout.txt" 2>/dev/null; then
        BRICSCAD_COM_ATTACHED=1
      fi
      if grep -q '^CREATED=1$' "$WORKDIR/bricscad-com-stdout.txt" 2>/dev/null; then
        BRICSCAD_COM_CREATED=1
      fi
      wait_for_status
      return 0
    fi
    echo "cscript.exe not found; falling back to direct BricsCAD launch." >&2
  fi

  BRICSCAD_BRIDGE_MODE="direct"
  if [[ -z "$exe" || ! -f "$exe" ]]; then
    echo "bricscad.exe not found. Set BRICSCAD_EXE." >&2
    return 3
  fi
  "$exe" /B "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
}

run_macos_bricscad_fallback() {
  local app=""
  app="$(find_macos_bricscad_app)"
  if [[ -z "$app" ]]; then
    echo "BricsCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  local appname
  appname=$(basename "$app" .app)
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  if [[ "$BRICSCAD_MACOS_APP_MODE" == "launch" ]]; then
    /usr/bin/open -a "$app" >/dev/null 2>&1 || true
  elif ! macos_app_running "$appname"; then
    echo "BricsCAD is not running. Relaunch with --bricscad-macos-app launch or start BricsCAD first." >&2
    return 3
  fi
  /usr/bin/osascript - "$appname" "$lisp_cmd" <<'OSA' || true
on run argv
  set appName to item 1 of argv
  set lispCmd to item 2 of argv
  delay 1
  tell application "System Events"
    tell process appName
      set frontmost to true
    end tell
    key code 53
    key code 53
    delay 0.15
    keystroke "_.COMMANDLINE"
    key code 36
    delay 0.2
    key code 53
    delay 0.1
    keystroke lispCmd
    key code 36
  end tell
end run
OSA
}

run_macos_bricscad_batch() {
  local exe="$1"
  local -a cmd=()
  if [[ -z "$exe" || ! -f "$exe" ]]; then
    echo "BricsCAD CLI executable not found. Set BRICSCAD_EXE or install BricsCAD in /Applications." >&2
    return 3
  fi
  cmd=("$exe")
  if [[ -n "$BRICSCAD_MACOS_PROFILE" ]]; then
    cmd+=("-P" "$BRICSCAD_MACOS_PROFILE")
  fi
  cmd+=("-b" "$SCRFILE")
  (
    "${cmd[@]}" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt"
    { printf '%s\n' "$?" >"$BATCH_EXIT_FILE"; } 2>/dev/null || true
  ) &
  BRICSCAD_BATCH_PID=$!
  BRICSCAD_BATCH_LAUNCHED=1
  return 0
}

run_macos_autocad_fallback() {
  local app=""
  app="$(ls -1d /Applications/Autodesk*/AutoCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "AutoCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  /usr/bin/open -a "$app" >/dev/null 2>&1 || true
  /usr/bin/osascript - "$lisp_cmd" <<'OSA' || true
on run argv
  set lispCmd to item 1 of argv
  delay 1
  tell application "System Events"
    tell process "AutoCAD"
      set frontmost to true
    end tell
    key code 53
    key code 53
    delay 0.15
    keystroke lispCmd
    key code 36
  end tell
end run
OSA
}

run_direct_unix_cli() {
  local exe="$1"
  [[ -n "$exe" && -f "$exe" ]] || return 3
  "$exe" /b "$RUNLSPFILE" >"$WORKDIR/direct-stdout.txt" 2>"$WORKDIR/direct-stderr.txt" || true
}

case "$ENGINE" in
  autocad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_autocad || true
    else
      if [[ -n "$AUTOCAD_EXE" ]]; then
        run_direct_unix_cli "$AUTOCAD_EXE" || run_macos_autocad_fallback || true
      else
        run_macos_autocad_fallback || true
      fi
    fi
    ;;
  bricscad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_bricscad || true
    else
      if [[ $IS_MACOS -eq 1 ]]; then
        case "$BRICSCAD_MACOS_EFFECTIVE_MODE" in
          batch)
            run_macos_bricscad_batch "$(find_macos_bricscad_cli || true)" || true
            ;;
          osascript)
            run_macos_bricscad_fallback || true
            ;;
          *)
            echo "Unsupported BricsCAD macOS mode: ${BRICSCAD_MACOS_EFFECTIVE_MODE:-unset}" >&2
            ;;
        esac
      elif [[ -n "$BRICSCAD_EXE" ]]; then
        "$BRICSCAD_EXE" -b "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
      else
        echo "bricscad executable not found. Set BRICSCAD_EXE." >&2
        true
      fi
    fi
    ;;
  *)
    echo "Unknown engine: $ENGINE" >&2
    exit 2
    ;;
esac

if [[ "$USE_BATCH_INTERACTIVE_REPL" -eq 1 ]]; then
  run_batch_interactive_repl
  exit $?
fi

if [[ "$MACOS_ASYNC" -eq 1 ]]; then
  if [[ -z "${AUTOLISP_KEEP_WORKDIR:-}" ]]; then
    CLEANUP_WORKDIR="1"
  fi
fi

wait_rc=0
if ! wait_for_status; then
  wait_rc=$?
fi

if [[ "$INTERRUPTED" -eq 1 ]]; then
  exit 130
fi

LOGFILE_FOUND="$(find_log_file)"
SESSION_OUTPUT_FILE="$(find_session_output_file || true)"
render_stdout "$OUTFILE" "$SESSION_OUTPUT_FILE" || cat "$OUTFILE" || true
cat "$ERRFILE" >&2 || true

if [[ "$wait_rc" -eq 124 ]]; then
  exit 124
fi

STATUS="1"
if [[ -s "$STATUSFILE" ]]; then
  STATUS="$(awk 'NF{line=$0} END{print line}' "$STATUSFILE" | tr -d '[:space:]')"
fi
if ! [[ "$STATUS" =~ ^[0-9]+$ ]]; then
  summary="$(awk '/^TOTAL=/{line=$0} END{print line}' "$OUTFILE" 2>/dev/null || true)"
  if [[ -n "$summary" && "$summary" =~ FAIL=0[[:space:]]+ERROR=0$ ]]; then
    STATUS=0
  else
    STATUS=1
  fi
fi

exit "$STATUS"
