#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOU'
Usage:
  autolisp [--autocad|--bricscad] { source.lsp | -x expression }... [--dwg file.dwg] [--main C:MAIN]

Examples:
  autolisp test.lsp
  autolisp lib1.lsp lib2.lsp --main C:RUN
  autolisp -x '(princ (+ 1 2))'
  autolisp init.lsp -x '(setq *x* 42)' test.lsp

Semantics:
  - Les éléments { source.lsp | -x expression } sont traités dans l'ordre.
  - Chaque source.lsp est chargé avec (load "...").
  - Chaque -x expression est évalué tel quel dans le contexte AutoLISP.
  - Si au moins un fichier source.lsp est fourni, (${MAIN:-C:MAIN}) est appelé à la fin,
    comme dans la version précédente.

Outputs:
  stdout  -> contenu de OUTFILE (par défaut écrit par ton LISP)
  stderr  -> contenu de ERRFILE
  exit    -> code lu dans STATUSFILE (écrit par ton LISP)

Environment overrides:
  AUTOCAD_ACCORECONSOLE   Path to accoreconsole.exe (Windows)
  BRICSCAD_EXE            Path to bricscad.exe      (Windows)
  AUTOLISP_DWG            Default DWG for AutoCAD Core Console if --dwg not provided

Notes:
  - AutoCAD Core Console (accoreconsole.exe) est Windows-only dans la pratique.
  - BricsCAD /B est documenté côté Windows. Sur macOS, ce script tente un fallback (non garanti).
EOU
}

ENGINE=""
DWG=""
MAIN="C:MAIN"

declare -a ACTION_KINDS=()
declare -a ACTION_VALUES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --autocad)
      ENGINE="autocad"
      shift
      ;;
    --bricscad)
      ENGINE="bricscad"
      shift
      ;;
    --dwg)
      DWG="${2:-}"
      shift 2
      ;;
    --main)
      MAIN="${2:-}"
      shift 2
      ;;
    -x)
      if [[ $# -lt 2 ]]; then
        echo "Missing expression after -x" >&2
        usage
        exit 2
      fi
      ACTION_KINDS+=("eval")
      ACTION_VALUES+=("$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        ACTION_KINDS+=("load")
        ACTION_VALUES+=("$1")
        shift
      done
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      ACTION_KINDS+=("load")
      ACTION_VALUES+=("$1")
      shift
      ;;
  esac
done

if [[ ${#ACTION_KINDS[@]} -eq 0 ]]; then
  echo "Missing input: provide at least one source.lsp or -x expression" >&2
  usage
  exit 2
fi

OS="$(uname -s || true)"
IS_WINDOWS=0
case "$OS" in
  MINGW*|MSYS*|CYGWIN*) IS_WINDOWS=1 ;;
esac

# Default engine: prefer AutoCAD core console on Windows, otherwise BricsCAD on Windows,
# otherwise BricsCAD on macOS (fallback), otherwise error.
if [[ -z "${ENGINE}" ]]; then
  if [[ $IS_WINDOWS -eq 1 ]]; then
    if [[ -n "${AUTOCAD_ACCORECONSOLE:-}" ]] || compgen -G "/c/Program Files/Autodesk/*/accoreconsole.exe" >/dev/null; then
      ENGINE="autocad"
    elif [[ -n "${BRICSCAD_EXE:-}" ]] || compgen -G "/c/Program Files*/Bricsys/*/bricscad.exe" >/dev/null; then
      ENGINE="bricscad"
    else
      echo "No engine found. Use --autocad or --bricscad and set AUTOCAD_ACCORECONSOLE / BRICSCAD_EXE." >&2
      exit 3
    fi
  else
    ENGINE="bricscad"
  fi
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_AUTOLISP_WORKDIR="$SCRIPT_DIR/.autolisp-runs"
BASE_WORKDIR="${AUTOLISP_WORKDIR:-$DEFAULT_AUTOLISP_WORKDIR}"
mkdir -p "$BASE_WORKDIR"
WORKDIR="$(mktemp -d "$BASE_WORKDIR/autolisp.XXXXXX")"

CLEANUP_WORKDIR="${AUTOLISP_KEEP_WORKDIR:-0}"
AUTOLISP_VERBOSE="${AUTOLISP_VERBOSE:-0}"
INTERRUPTED=0

on_interrupt() {
  INTERRUPTED=1
  CLEANUP_WORKDIR="1"
  echo "autolisp: interrupt requested; keeping workdir and finishing current BricsCAD handshake..." >&2
}

cleanup_workdir() {
  if [[ "${CLEANUP_WORKDIR}" != "1" ]]; then
    rm -rf "$WORKDIR"
  else
    if [[ "$AUTOLISP_VERBOSE" == "1" || "$INTERRUPTED" == "1" ]]; then
      echo "autolisp: keeping workdir: $WORKDIR" >&2
    fi
  fi
}
trap cleanup_workdir EXIT
trap on_interrupt INT TERM

OUTFILE="$WORKDIR/output.txt"
ERRFILE="$WORKDIR/errors.txt"
STATUSFILE="$WORKDIR/status.txt"
: >"$OUTFILE"
: >"$ERRFILE"
echo "__PENDING__" >"$STATUSFILE"

MACOS_ASYNC=0

escape_lisp_string() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

to_abs_path() {
  local p="$1"
  local dir base
  dir="$(cd "$(dirname "$p")" && pwd)"
  base="$(basename "$p")"
  printf '%s/%s' "$dir" "$base"
}

to_lisp_path() {
  local p="$1"
  p="${p//\\//}"
  printf '%s' "$p"
}

declare -a SEARCH_DIRS=()
declare -a LOAD_PATHS=()
HAS_LOAD_ACTION=0

for i in "${!ACTION_KINDS[@]}"; do
  kind="${ACTION_KINDS[$i]}"
  value="${ACTION_VALUES[$i]}"
  if [[ "$kind" == "load" ]]; then
    if [[ ! -f "$value" ]]; then
      echo "Not found: $value" >&2
      exit 2
    fi
    abs_src="$(to_abs_path "$value")"
    abs_src="$(to_lisp_path "$abs_src")"
    abs_dir="$(dirname "$abs_src")"
    LOAD_PATHS+=("$abs_src")
    HAS_LOAD_ACTION=1

    already_present=0
    for existing in "${SEARCH_DIRS[@]:-}"; do
      if [[ "$existing" == "$abs_dir" ]]; then
        already_present=1
        break
      fi
    done
    if [[ $already_present -eq 0 ]]; then
      SEARCH_DIRS+=("$abs_dir")
    fi
  else
    LOAD_PATHS+=("")
  fi
done

RUNLSPFILE="$WORKDIR/run-common.lsp"
{
  echo '(setq _autolisp_old_srchpath (getvar "SRCHPATH"))'
  if [[ ${#SEARCH_DIRS[@]} -gt 0 ]]; then
    srch_prefix=""
    for dir in "${SEARCH_DIRS[@]}"; do
      srch_prefix+="$(escape_lisp_string "$dir");"
    done
    printf '(setvar "SRCHPATH" (strcat "%s" _autolisp_old_srchpath))\n' "$srch_prefix"
  fi
  printf '(setq *AUTOLISP_OUTFILE* "%s")\n' "$(escape_lisp_string "$OUTFILE")"
  printf '(setq *AUTOLISP_ERRFILE* "%s")\n' "$(escape_lisp_string "$ERRFILE")"
  printf '(setq *AUTOLISP_STATUSFILE* "%s")\n' "$(escape_lisp_string "$STATUSFILE")"

  for i in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$i]}"
    value="${ACTION_VALUES[$i]}"
    if [[ "$kind" == "load" ]]; then
      abs_src="${LOAD_PATHS[$i]}"
      printf '(load "%s")\n' "$(escape_lisp_string "$abs_src")"
    else
      printf '%s\n' "$value"
    fi
  done

  if [[ "$HAS_LOAD_ACTION" -eq 1 ]]; then
    printf '(%s)\n' "$MAIN"
  fi
  echo '(quit)'
} >"$RUNLSPFILE"

# A .scr that just loads the common runner.
SCRFILE="$WORKDIR/run.scr"
cat >"$SCRFILE" <<EOF2
(load "$(escape_lisp_string "$RUNLSPFILE")")
EOF2

export OUTFILE ERRFILE STATUSFILE

run_windows_autocad() {
  local acc="${AUTOCAD_ACCORECONSOLE:-}"
  if [[ -z "$acc" ]]; then
    # pick the newest-ish by simple glob preference
    acc="$(ls -1 "/c/Program Files/Autodesk"/*/accoreconsole.exe 2>/dev/null | head -n 1 || true)"
  fi
  if [[ -z "$acc" || ! -f "$acc" ]]; then
    echo "accoreconsole.exe not found. Set AUTOCAD_ACCORECONSOLE." >&2
    return 3
  fi

  local dwg="${DWG:-${AUTOLISP_DWG:-}}"
  if [[ -z "$dwg" || ! -f "$dwg" ]]; then
    echo "AutoCAD Core Console needs a DWG. Provide --dwg file.dwg or set AUTOLISP_DWG." >&2
    return 2
  fi

  # accoreconsole: /i input dwg, /s script
  # Some installations also accept /l for locale; omit by default.
  "$acc" /i "$dwg" /s "$SCRFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
}

run_windows_bricscad() {
  local exe="${BRICSCAD_EXE:-}"
  if [[ -z "$exe" ]]; then
    exe="$(ls -1 "/c/Program Files"*/Bricsys/*/bricscad.exe 2>/dev/null | head -n 1 || true)"
  fi
  if [[ -z "$exe" || ! -f "$exe" ]]; then
    echo "bricscad.exe not found. Set BRICSCAD_EXE." >&2
    return 3
  fi

  # BricsCAD: /B runs a .scr or .lsp at startup.
  "$exe" /B "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
}

run_macos_bricscad_fallback() {
  # Fallback best-effort: open the app + feed a Lisp load expression.
  # This is inherently brittle (UI focus, localization, etc.).
  # We still rely on OUTFILE/ERRFILE/STATUSFILE written by LISP.
  local app=""
  app="$(ls -1d /Applications/BricsCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "BricsCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  local appname
  appname=$(basename "$app" .app)
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  export AUTOLISP_LISP_CMD="$lisp_cmd"
  export AUTOLISP_APPNAME="$appname"
  /usr/bin/osascript <<'OSA' || true
set appName to system attribute "AUTOLISP_APPNAME"
tell application appName to activate
delay 1
tell application "System Events"
  key code 53
  key code 53
  delay 0.15
  set lispCmd to system attribute "AUTOLISP_LISP_CMD"
  keystroke lispCmd
  key code 36
end tell
OSA
}

run_macos_autocad_fallback() {
  # Similar best-effort for AutoCAD on Mac (no accoreconsole).
  local app=""
  app="$(ls -1d /Applications/Autodesk*/AutoCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "AutoCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi

  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  export AUTOLISP_LISP_CMD="$lisp_cmd"

  /usr/bin/osascript <<'OSA' || true
tell application "AutoCAD" to activate
delay 1
tell application "System Events"
  key code 53
  key code 53
  delay 0.15
  set lispCmd to system attribute "AUTOLISP_LISP_CMD"
  keystroke lispCmd
  key code 36
end tell
OSA
}

wait_for_macos_async() {
  local timeout="${AUTOLISP_WAIT_SECS:-180}"
  while [[ "$timeout" -gt 0 ]]; do
    local s
    s="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    if [[ -n "$s" && "$s" != "__PENDING__" ]]; then
      return 0
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  return 0
}

case "$ENGINE" in
  autocad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_autocad || true
    else
      run_macos_autocad_fallback || true
    fi
    ;;
  bricscad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_bricscad || true
    else
      run_macos_bricscad_fallback || true
    fi
    ;;
  *)
    echo "Unknown engine: $ENGINE" >&2
    exit 2
    ;;
esac

if [[ "$MACOS_ASYNC" -eq 1 ]]; then
  # macOS fallback is UI-driven and asynchronous; keep working files by default.
  if [[ -z "${AUTOLISP_KEEP_WORKDIR:-}" ]]; then
    CLEANUP_WORKDIR="1"
  fi
  wait_for_macos_async
fi

if [[ "$INTERRUPTED" -eq 1 ]]; then
  exit 130
fi

# Emit OUT/ERR as requested
cat "$OUTFILE" || true
cat "$ERRFILE" >&2 || true

STATUS="1"
if [[ -s "$STATUSFILE" ]]; then
  STATUS="$(awk 'NF{line=$0} END{print line}' "$STATUSFILE" | tr -d '[:space:]')"
fi
if ! [[ "$STATUS" =~ ^[0-9]+$ ]]; then
  # Fallback for macOS async mode: infer status from summary line if present.
  summary="$(awk '/^TOTAL=/{line=$0} END{print line}' "$OUTFILE" 2>/dev/null || true)"
  if [[ -n "$summary" && "$summary" =~ FAIL=0[[:space:]]+ERROR=0$ ]]; then
    STATUS=0
  else
    STATUS=1
  fi
fi
exit "$STATUS"
