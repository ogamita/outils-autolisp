# maybe_dry_run : si --dry / AUTOLISP_DRY_RUN=1, affiche la commande
# de lancement CAD et termine le script avec code 0. Appele par chaque
# run_* function juste avant l'execution effective. La commande est
# affichee shell-quotee pour pouvoir etre copiee-collee.
maybe_dry_run() {
  [[ "$DRY_RUN" -eq 1 ]] || return 0
  if (( $# > 0 )); then
