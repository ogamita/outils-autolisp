write_windows_autocad_vbs() {
  local vbs="$WORKDIR/bridge-autocad.vbs"
  local win_runlsp win_err win_status win_epure win_exe win_invocation_dir win_debug
  win_runlsp="$(to_windows_path "$RUNLSPFILE")"
  win_err="$(to_windows_path "$ERRFILE")"
  win_status="$(to_windows_path "$STATUSFILE")"
  win_debug="$(to_windows_path "$WORKDIR/debug.log")"
  win_invocation_dir="$(to_windows_path "$AUTOLISP_INVOCATION_DIR")"
  win_epure=""
  if [[ "$EPURE_REQUESTED" == "1" ]]; then
    local epure_unix
    epure_unix="$(windows_epure_control_script autocad || true)"
    if [[ -n "$epure_unix" ]]; then
      win_epure="$epure_unix"
    fi
  fi
  win_exe="${AUTOCAD_EXE:-}"
  if [[ -n "$win_exe" ]]; then
    win_exe="$(to_windows_path "$win_exe")"
  fi

  cat >"$vbs" <<EOFVBS
Option Explicit
Dim fso, shell, mode, exePath, runLsp, errFile, statusFile, debugFile, debugFlag, invocationDir, epureScript, epureRequested
Dim app, doc, cmd, progid, created, attached, rc
Dim waitSecs, waited, statusText
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")
mode = "$(escape_vbs_string "$AUTOCAD_COM_MODE")"
exePath = "$(escape_vbs_string "$win_exe")"
runLsp = "$(escape_vbs_string "$win_runlsp")"
errFile = "$(escape_vbs_string "$win_err")"
statusFile = "$(escape_vbs_string "$win_status")"
debugFile = "$(escape_vbs_string "$win_debug")"
debugFlag = "$(escape_vbs_string "$AUTOLISP_DEBUG")"
invocationDir = "$(escape_vbs_string "$win_invocation_dir")"
epureScript = "$(escape_vbs_string "$win_epure")"
epureRequested = "$(escape_vbs_string "$EPURE_REQUESTED")"

Sub VBSDebug(msg)
  Dim f
  If debugFlag <> "1" Then Exit Sub
  On Error Resume Next
  Set f = fso.OpenTextFile(debugFile, 8, True)
  If Err.Number = 0 Then
    f.WriteLine "[VBS] " & msg
    f.Close
  End If
  Err.Clear
  On Error GoTo 0
End Sub

VBSDebug "bridge start mode=" & mode & " exePath=" & exePath

' Aligne le cwd du process VBScript sur celui d'ou l'utilisateur a appele
' autolisp, AVANT CreateObject. Sur Windows, un acad.exe out-of-process
' COM server lance via activation peut heriter du cwd de l'activator dans
' certains contextes ; meme si ce n'est pas garanti, cela aide pour les
' chemins relatifs apparaissant dans (load ...), findfile, etc.
If invocationDir <> "" Then
  On Error Resume Next
  If fso.FolderExists(invocationDir) Then
    shell.CurrentDirectory = invocationDir
  End If
  Err.Clear
  On Error GoTo 0
End If
waitSecs = CLng("$(escape_vbs_string "${AUTOLISP_WAIT_SECS:-180}")")
If waitSecs < 5 Then waitSecs = 5
progid = "AutoCAD.Application"
created = False
attached = False
rc = 0

Sub AppendLine(path, text)
  Dim f
  Set f = fso.OpenTextFile(path, 8, True)
  f.WriteLine text
  f.Close
End Sub

Sub EmitFlags(att, cre)
  Dim a, c
  If att Then a = "1" Else a = "0"
  If cre Then c = "1" Else c = "0"
  WScript.StdOut.WriteLine "ATTACHED=" & a
  WScript.StdOut.WriteLine "CREATED=" & c
End Sub

Function ReadStatusText(path)
  Dim f, s
  ReadStatusText = ""
  If Not fso.FileExists(path) Then Exit Function
  On Error Resume Next
  Set f = fso.OpenTextFile(path, 1, False)
  If Err.Number <> 0 Then
    Err.Clear
    Exit Function
  End If
  If Not f.AtEndOfStream Then
    s = f.ReadAll
  Else
    s = ""
  End If
  f.Close
  On Error GoTo 0
  ReadStatusText = Trim(s)
End Function

Function StatusReady(path)
  Dim s
  s = ReadStatusText(path)
  If s = "" Then
    StatusReady = False
  ElseIf s = "__PENDING__" Then
    StatusReady = False
  ElseIf s = "99" Then
    StatusReady = False
  Else
    StatusReady = True
  End If
End Function

Sub WaitQuiescent(a, secs)
  Dim deadline, state, quiescent, supported
  deadline = Timer + secs
  supported = True
  ' Premier sleep tres court: laisse passer un eventuel splash/profil avant
  ' la premiere interrogation IsQuiescent.
  WScript.Sleep 200
  Do
    quiescent = False
    On Error Resume Next
    Set state = a.GetAcadState
    If Err.Number <> 0 Then
      Err.Clear
      supported = False
      Exit Do
    End If
    quiescent = state.IsQuiescent
    If Err.Number <> 0 Then
      Err.Clear
      supported = False
      Exit Do
    End If
    On Error GoTo 0
    If quiescent Then Exit Sub
    WScript.Sleep 500
  Loop While Timer < deadline
  On Error GoTo 0
  ' Si IsQuiescent n'est pas exploitable, on tombe en attente passive courte.
  If Not supported Then WScript.Sleep 500
End Sub

Sub WaitStatus(path, secs)
  Dim deadline, lastStatus, currentStatus
  deadline = Timer + secs
  lastStatus = ""
  VBSDebug "WaitStatus begin secs=" & secs
  Do
    currentStatus = ReadStatusText(path)
    If currentStatus <> lastStatus Then
      VBSDebug "WaitStatus status='" & currentStatus & "'"
      lastStatus = currentStatus
    End If
    If StatusReady(path) Then
      VBSDebug "WaitStatus ready"
      Exit Sub
    End If
    WScript.Sleep 500
  Loop While Timer < deadline
  VBSDebug "WaitStatus timeout"
End Sub

Function AttachApp()
  On Error Resume Next
  Set AttachApp = GetObject(, progid)
  If Err.Number <> 0 Then
    Err.Clear
    Set AttachApp = Nothing
  End If
  On Error GoTo 0
End Function

Function CreateApp()
  On Error Resume Next
  If exePath <> "" Then
    shell.Environment("PROCESS")("AUTOCAD_LOCATION") = exePath
  End If
  Set CreateApp = CreateObject(progid)
  If Err.Number <> 0 Then
    Err.Clear
    Set CreateApp = Nothing
  End If
  On Error GoTo 0
End Function

' Initialise app/doc explicitement: sinon ces variants restent Empty quand
' mode = "launch" (le bloc attach/auto ne les Set pas), et "If app Is
' Nothing" plante avec "Objet requis" car Empty n'est pas un objet.
Set app = Nothing
Set doc = Nothing

If mode = "attach" Or mode = "auto" Then
  VBSDebug "trying GetObject AttachApp"
  Set app = AttachApp()
  If Not app Is Nothing Then
    attached = True
    VBSDebug "attached to existing instance"
  End If
End If

If app Is Nothing Then
  If mode = "attach" Then
    AppendLine errFile, "ERROR COM attach: no running AutoCAD instance found."
    VBSDebug "attach failed: no running instance"
    EmitFlags False, False
    WScript.Quit 2
  End If
  If mode = "launch" Or mode = "auto" Then
    VBSDebug "calling CreateObject (this can take 10-30s)"
    Set app = CreateApp()
    If app Is Nothing Then
      AppendLine errFile, "ERROR COM launch: unable to create AutoCAD COM application."
      VBSDebug "CreateObject failed"
      EmitFlags False, False
      WScript.Quit 3
    End If
    created = True
    VBSDebug "CreateObject ok, acad.exe should be running"
  End If
End If

If app Is Nothing Then
  AppendLine errFile, "ERROR COM bridge: unsupported AutoCAD COM mode."
  EmitFlags False, False
  WScript.Quit 4
End If

On Error Resume Next
app.Visible = True
If Err.Number <> 0 Then Err.Clear
On Error GoTo 0

If epureRequested = "1" Then
  On Error Resume Next
  app.Preferences.Profiles.ActiveProfile = "Epure"
  If Err.Number <> 0 Then
    AppendLine errFile, "WARN COM bridge: cannot activate AutoCAD profile 'Epure' (" & Err.Description & "); using current profile."
    Err.Clear
  End If
  On Error GoTo 0
End If

WaitQuiescent app, waitSecs

On Error Resume Next
Set doc = app.ActiveDocument
If Err.Number <> 0 Then
  Err.Clear
  Set doc = Nothing
End If
If doc Is Nothing Then
  Set doc = app.Documents.Add
  If Err.Number <> 0 Then
    AppendLine errFile, "ERROR COM bridge: unable to get or create AutoCAD ActiveDocument: " & Err.Description
    Err.Clear
    If created Then
      app.Quit
    End If
    EmitFlags attached, created
    WScript.Quit 5
  End If
End If
On Error GoTo 0

If epureScript <> "" Then
  cmd = "._SCRIPT " & Chr(34) & Replace(epureScript, "\", "/") & Chr(34) & vbCr
  On Error Resume Next
  Call doc.SendCommand(cmd)
  If Err.Number <> 0 Then
    AppendLine errFile, "WARN COM bridge: EPURE _SCRIPT send failed: " & Err.Description
    Err.Clear
  End If
  On Error GoTo 0
End If

cmd = "(load """ & Replace(runLsp, "\", "/") & """)" & vbCr
VBSDebug "SendCommand " & cmd
On Error Resume Next
Call doc.SendCommand(cmd)
If Err.Number <> 0 Then
  AppendLine errFile, "ERROR COM bridge: AutoCAD SendCommand failed: " & Err.Description
  VBSDebug "SendCommand failed: " & Err.Description
  Err.Clear
  rc = 6
End If
On Error GoTo 0

' SendCommand est asynchrone : on attend que le runtime LISP ait ecrit
' STATUSFILE avant d'envisager app.Quit (sinon on tuerait acad.exe en
' plein chargement). On distingue le succes (status final ecrit) du
' timeout (statut reste a __PENDING__/99) : en cas de timeout, on
' n'appelle PAS app.Quit, sinon on interromprait le runtime LISP encore
' en cours. Le wrapper bash detecte ce cas et tue acad.exe via
' kill_autocad_com_process.
Dim statusReadyFlag
statusReadyFlag = False
If rc = 0 Then
  WaitStatus statusFile, waitSecs
  statusReadyFlag = StatusReady(statusFile)
End If

If created And statusReadyFlag Then
  VBSDebug "calling app.Quit (created=True, status ready)"
  On Error Resume Next
  app.Quit
  If Err.Number <> 0 Then Err.Clear
  On Error GoTo 0
End If

VBSDebug "bridge exit rc=" & rc & " attached=" & attached & " created=" & created
EmitFlags attached, created
WScript.Quit rc
EOFVBS
  printf '%s' "$vbs"
}

run_windows_autocad() {
  local win_scrfile=""
  local epure_control=""
  local workdir=""
  autolisp_debug "run_windows_autocad: AUTOCAD_COM_MODE=$AUTOCAD_COM_MODE AUTOCAD_EXE=${AUTOCAD_EXE:-<unset>} EPURE_REQUESTED=$EPURE_REQUESTED"
  if [[ "$AUTOCAD_COM_MODE" != "off" ]]; then
    local cscript=""
    if command -v cscript >/dev/null 2>&1; then
      cscript="$(command -v cscript)"
    elif [[ -x /c/Windows/System32/cscript.exe ]]; then
      cscript="/c/Windows/System32/cscript.exe"
    fi
    autolisp_debug "cscript=${cscript:-<not found>}"
    if [[ -n "$cscript" ]]; then
      local vbs cscript_rc cscript_pid
      vbs="$(write_windows_autocad_vbs)"
      maybe_dry_run "$cscript" //nologo "$vbs"
      "$cscript" //nologo "$vbs" >"$WORKDIR/autocad-com-stdout.txt" 2>"$WORKDIR/autocad-com-stderr.txt" || true
      autolisp_debug "VBS bridge written: $vbs ($(wc -c <"$vbs" 2>/dev/null || echo ?) bytes)"
      autolisp_debug "run cscript+vbs: $(autolisp_debug_format_cmd "$cscript" //nologo "$vbs")"
      # Snapshot des PIDs acad.exe deja vivants AVANT le lancement du pont,
      # de sorte qu'on puisse identifier les instances que CE wrapper a
      # creees (par difference). WMI n'est pas accessible cote VBS sur
      # certains postes (policy enterprise), donc cette approche bash
      # via tasklist sert de capture fiable.
      snapshot_acad_pids "$WORKDIR/acad-pids-before.txt"
      # cscript est lance en arriere-plan + poll non bloquant. Le `wait`
      # builtin de bash 5.2 sur MSYS2 ne reveille pas wait sur SIGINT
      # quand on attend un process Windows natif (cscript.exe), donc on
      # boucle a la main : sleep court + verification du flag INTERRUPTED
      # (mis a 1 par le trap). Cela permet d'interrompre le pont COM
      # bloque dans sa WaitStatus interne sans devoir patienter
      # TIMEOUT_SECS.
      "$cscript" //nologo "$vbs" >"$WORKDIR/autocad-com-stdout.txt" 2>"$WORKDIR/autocad-com-stderr.txt" &
      cscript_pid=$!
      printf '%s\n' "$cscript_pid" >"$WORKDIR/cscript-pid.txt"
      autolisp_debug "cscript started in background pid=$cscript_pid"
      while kill -0 "$cscript_pid" 2>/dev/null; do
        # Met a jour la liste des acad.exe que le pont a fait apparaitre,
        # pour que le trap puisse les tuer en cas d'interrupt.
        update_com_launched_acad_pids
        if [[ "$INTERRUPTED" -eq 1 ]]; then
          autolisp_debug "INTERRUPTED detected during cscript wait; killing bridge"
          kill_autocad_com_process || true
          break
        fi
        sleep 0.5
      done
      cscript_rc=0
      wait "$cscript_pid" 2>/dev/null || cscript_rc=$?
      rm -f "$WORKDIR/cscript-pid.txt"
      # En sortie normale (app.Quit reussi cote VBS), les acad.exe que
      # nous avons lances ont disparu : recalcule la liste, ce qui
      # videra le fichier marqueur.
      update_com_launched_acad_pids
      autolisp_debug "cscript exit rc=$cscript_rc"
      if autolisp_is_debug; then
        autolisp_debug "VBS stdout (autocad-com-stdout.txt):"
        sed 's/^/[DEBUG] | /' "$WORKDIR/autocad-com-stdout.txt" >&3 2>/dev/null || true
        if [[ -s "$WORKDIR/autocad-com-stderr.txt" ]]; then
          autolisp_debug "VBS stderr (autocad-com-stderr.txt):"
          sed 's/^/[DEBUG] | /' "$WORKDIR/autocad-com-stderr.txt" >&3 2>/dev/null || true
        fi
      fi
      # cscript ne propage pas toujours les erreurs VBScript runtime via
      # son code de sortie (rc=0 alors qu'une erreur fatale a ete emise sur
      # stderr). Si on detecte un marqueur d'erreur VBScript, on ecrit un
      # statut d'erreur immediat pour que wait_for_status sorte vite, au
      # lieu de patienter TIMEOUT_SECS sur __PENDING__.
      if [[ -s "$WORKDIR/autocad-com-stderr.txt" ]] \
         && grep -qE 'Microsoft VBScript|Erreur d.x.cution Microsoft VBScript' "$WORKDIR/autocad-com-stderr.txt"; then
        autolisp_debug "VBScript runtime error detected; failing fast"
        {
          printf 'ERROR COM bridge: VBScript runtime error (cscript exit %d).\n' "$cscript_rc"
          cat "$WORKDIR/autocad-com-stderr.txt"
        } >>"$ERRFILE"
        echo "2" >"$STATUSFILE"
      elif [[ "$cscript_rc" -ne 0 ]]; then
        autolisp_debug "cscript exit non-zero ($cscript_rc); failing fast"
        printf 'ERROR COM bridge: cscript exited %d.\n' "$cscript_rc" >>"$ERRFILE"
        echo "$cscript_rc" >"$STATUSFILE"
      else
        # cscript a quitte proprement. Si STATUSFILE est encore pending/99,
        # c'est que WaitStatus du VBS a timeoute (TIMEOUT_SECS atteints sans
        # final status). On marque 124 et on tue acad.exe immediatement, sinon
        # les deux wait_for_status bash suivants ajoutent jusqu'a 2x TIMEOUT_SECS
        # de plus pour rien.
        local current_status
        current_status="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
        if [[ -z "$current_status" || "$current_status" == "__PENDING__" || "$current_status" == "99" ]]; then
          autolisp_debug "VBS WaitStatus timed out (STATUSFILE='$current_status'); marking 124 and killing acad.exe"
          printf 'ERROR COM bridge: timeout after %ds waiting for LISP runtime to finish.\n' "$TIMEOUT_SECS" >>"$ERRFILE"
          echo "124" >"$STATUSFILE"
          kill_autocad_com_process || true
        fi
      fi
      autolisp_debug "calling wait_for_status (timeout ${TIMEOUT_SECS}s)"
      wait_for_status
      autolisp_debug "wait_for_status rc=$?"
      return 0
    fi
    echo "cscript.exe not found; falling back to direct AutoCAD launch." >&2
  fi

  if [[ -n "$AUTOCAD_EXE" && -f "$AUTOCAD_EXE" ]]; then
    if [[ "$EPURE_REQUESTED" == "1" ]]; then
      epure_control="$(windows_epure_control_script autocad || true)"
      if [[ -z "$epure_control" ]]; then
        echo "EPURE bootstrap script not found in %APPDATA%\\sncf\\epure\\epure 2022." >&2
        return 2
      fi
      win_scrfile="$(to_windows_path "$SCRFILE")"
      workdir="$(windows_cad_workdir "$AUTOCAD_EXE")"
      maybe_dry_run "$AUTOCAD_EXE" /p Epure /b "$win_scrfile"
      autolisp_debug "direct acad.exe + EPURE: workdir=$workdir scrfile=$win_scrfile"
      autolisp_debug "run acad.exe /p Epure /b: $(autolisp_debug_format_cmd "$AUTOCAD_EXE" /p Epure /b "$win_scrfile")"
      (
        cd "$workdir"
        "$AUTOCAD_EXE" /p Epure /b "$win_scrfile" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt"
      ) || true
      autolisp_debug "acad.exe /p Epure /b exit rc=$?"
      return 0
    fi
    maybe_dry_run "$AUTOCAD_EXE" /b "$RUNLSPFILE"
    autolisp_debug "run acad.exe /b: $(autolisp_debug_format_cmd "$AUTOCAD_EXE" /b "$RUNLSPFILE")"
    "$AUTOCAD_EXE" /b "$RUNLSPFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
    autolisp_debug "acad.exe /b exit rc=$?"
    return 0
  fi

  if [[ "$EPURE_REQUESTED" == "1" ]]; then
    echo "--epure on AutoCAD requires AUTOCAD_EXE (acad.exe)." >&2
    return 2
  fi

  local acc="${AUTOCAD_ACCORECONSOLE:-}"
  if [[ -z "$acc" ]]; then
    acc="$(ls -1 "/c/Program Files/Autodesk"/*/accoreconsole.exe 2>/dev/null | head -n 1 || true)"
  fi
  local dwg="${DWG:-${AUTOLISP_DWG:-}}"
  autolisp_debug "accoreconsole fallback: acc=${acc:-<not found>} dwg=${dwg:-<unset>}"
  if [[ -z "$acc" || ! -f "$acc" ]]; then
    echo "Neither AutoCAD COM/direct nor accoreconsole.exe is available. Set AUTOCAD_EXE or AUTOCAD_ACCORECONSOLE." >&2
    return 3
  fi
  if [[ -z "$dwg" || ! -f "$dwg" ]]; then
    echo "AutoCAD Core Console needs a DWG. Provide --dwg file.dwg or set AUTOLISP_DWG." >&2
    return 2
  fi

  maybe_dry_run "$acc" /i "$dwg" /s "$SCRFILE"
  autolisp_debug "run accoreconsole: $(autolisp_debug_format_cmd "$acc" /i "$dwg" /s "$SCRFILE")"
  "$acc" /i "$dwg" /s "$SCRFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
  autolisp_debug "accoreconsole exit rc=$?"
}

write_windows_bricscad_vbs() {
  local vbs="$WORKDIR/bridge-bricscad.vbs"
  local win_runlsp win_status win_out win_err win_exe mode
  win_runlsp="$(to_windows_path "$RUNLSPFILE")"
  win_status="$(to_windows_path "$STATUSFILE")"
  win_out="$(to_windows_path "$OUTFILE")"
  win_err="$(to_windows_path "$ERRFILE")"
  mode="$BRICSCAD_COM_MODE"
  win_exe="${BRICSCAD_EXE:-}"
  if [[ -n "$win_exe" ]]; then
    win_exe="$(to_windows_path "$win_exe")"
  fi

  cat >"$vbs" <<EOFVBS
Option Explicit
Dim fso, shell, mode, exePath, runLsp, statusFile, outFile, errFile
Dim app, doc, cmd, created, attached, rc
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")
mode = "$(escape_vbs_string "$mode")"
exePath = "$(escape_vbs_string "$win_exe")"
runLsp = "$(escape_vbs_string "$win_runlsp")"
statusFile = "$(escape_vbs_string "$win_status")"
outFile = "$(escape_vbs_string "$win_out")"
errFile = "$(escape_vbs_string "$win_err")"
created = False
attached = False
rc = 0

Sub AppendLine(path, text)
  Dim f
  Set f = fso.OpenTextFile(path, 8, True)
  f.WriteLine text
  f.Close
End Sub

Function TryGetApp()
  On Error Resume Next
  Set TryGetApp = GetObject(, "BricscadApp.AcadApplication")
  If Err.Number <> 0 Then
    Err.Clear
    Set TryGetApp = Nothing
  End If
  On Error GoTo 0
End Function

Function TryCreateApp()
  On Error Resume Next
  If exePath <> "" Then
    shell.Environment("PROCESS")("BRICSCAD_LOCATION") = exePath
  End If
  Set TryCreateApp = CreateObject("BricscadApp.AcadApplication")
  If Err.Number <> 0 Then
    Err.Clear
    Set TryCreateApp = Nothing
  End If
  On Error GoTo 0
End Function

Set app = Nothing
If mode = "attach" Or mode = "auto" Then
  Set app = TryGetApp()
  If Not app Is Nothing Then attached = True
End If

If app Is Nothing Then
  If mode = "attach" Then
    AppendLine errFile, "ERROR COM attach: no running BricsCAD instance found."
    rc = 2
    WScript.Echo "ATTACHED=0"
    WScript.Echo "CREATED=0"
    WScript.Quit rc
  End If
  If mode = "launch" Or mode = "auto" Then
    Set app = TryCreateApp()
    If app Is Nothing Then
      AppendLine errFile, "ERROR COM launch: unable to create BricsCAD COM application."
      rc = 3
      WScript.Echo "ATTACHED=0"
      WScript.Echo "CREATED=0"
      WScript.Quit rc
    End If
    created = True
  End If
End If

If app Is Nothing Then
  AppendLine errFile, "ERROR COM bridge: unsupported mode or COM unavailable."
  rc = 4
  WScript.Echo "ATTACHED=0"
  WScript.Echo "CREATED=0"
  WScript.Quit rc
End If

On Error Resume Next
app.Visible = True
If Err.Number <> 0 Then Err.Clear
Set doc = app.ActiveDocument
If Err.Number <> 0 Then
  Err.Clear
  Set doc = Nothing
End If
If doc Is Nothing Then
  Set doc = app.Documents.Add
  If Err.Number <> 0 Then
    AppendLine errFile, "ERROR COM bridge: unable to get or create ActiveDocument."
    Err.Clear
    rc = 5
    If attached Then
      WScript.Echo "ATTACHED=1"
    Else
      WScript.Echo "ATTACHED=0"
    End If
    If created Then
      WScript.Echo "CREATED=1"
    Else
      WScript.Echo "CREATED=0"
    End If
    WScript.Quit rc
  End If
End If
cmd = "(load """ & Replace(runLsp, "\", "/") & """)" & vbCr
Err.Clear
Call doc.SendCommand(cmd)
If Err.Number <> 0 Then
  AppendLine errFile, "ERROR COM bridge: SendCommand failed: " & Err.Description
  Err.Clear
  rc = 6
Else
  rc = 0
End If
On Error GoTo 0
If attached Then
  WScript.Echo "ATTACHED=1"
Else
  WScript.Echo "ATTACHED=0"
End If
If created Then
  WScript.Echo "CREATED=1"
Else
  WScript.Echo "CREATED=0"
End If
WScript.Quit rc
EOFVBS
  printf '%s' "$vbs"
}

wait_for_status() {
  local timeout="$TIMEOUT_SECS"
  local prev_status=""
  autolisp_debug "wait_for_status start timeout=$TIMEOUT_SECS STATUSFILE=$STATUSFILE"
  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      autolisp_debug "wait_for_status: INTERRUPTED"
      return 130
    fi
    local s
    s="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    if autolisp_is_debug && [[ "$s" != "$prev_status" ]]; then
      autolisp_debug "wait_for_status: status='${s:-<empty>}' (remaining ${timeout}s)"
      prev_status="$s"
    fi
    if [[ -n "$s" && "$s" != "__PENDING__" && "$s" != "99" ]]; then
      autolisp_debug "wait_for_status: ready status='$s'"
      return 0
    fi
    if batch_startup_stalled "$s"; then
      autolisp_debug "wait_for_status: batch_startup_stalled"
      return 124
    fi
    if batch_runner_done_without_status "$s"; then
      autolisp_debug "wait_for_status: batch_runner_done_without_status"
      return 1
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  autolisp_debug "wait_for_status: timeout reached"
  autolisp_error "timeout waiting for CAD runner completion after ${TIMEOUT_SECS}s"
  if [[ "$ENGINE" == "bricscad" && $IS_WINDOWS -eq 0 && "$MACOS_ASYNC" -eq 1 ]]; then
    local status_trimmed has_output has_errors
    status_trimmed="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    has_output=0
    has_errors=0
    [[ -s "$OUTFILE" ]] && has_output=1
    [[ -s "$ERRFILE" ]] && has_errors=1
    if [[ "${status_trimmed:-}" == "__PENDING__" && "$has_output" -eq 0 && "$has_errors" -eq 0 ]]; then
      autolisp_hint "on macOS + BricsCAD, select the \"2D Drafting\" workspace, not \"2D Drafting (Modern)\", then retry."
    fi
  fi
  return 124
}

run_windows_bricscad() {
  local exe="${BRICSCAD_EXE:-}"
  local win_scrfile=""
  local workdir=""
  local epure_control=""
  local -a cmd=()
  if [[ -z "$exe" ]]; then
    exe="$(ls -1 "/c/Program Files"*/Bricsys/*/bricscad.exe 2>/dev/null | head -n 1 || true)"
  fi
  if [[ "$BRICSCAD_COM_MODE" != "off" ]]; then
    local cscript=""
    if command -v cscript >/dev/null 2>&1; then
      cscript="$(command -v cscript)"
    elif [[ -x /c/Windows/System32/cscript.exe ]]; then
      cscript="/c/Windows/System32/cscript.exe"
    fi
    if [[ -n "$cscript" ]]; then
      BRICSCAD_BRIDGE_MODE="com"
      [[ -n "$exe" ]] && export BRICSCAD_EXE="$exe"
      local vbs
      vbs="$(write_windows_bricscad_vbs)"
      "$cscript" //nologo "$vbs" >"$WORKDIR/bricscad-com-stdout.txt" 2>"$WORKDIR/bricscad-com-stderr.txt" || true
      if grep -q '^ATTACHED=1$' "$WORKDIR/bricscad-com-stdout.txt" 2>/dev/null; then
        BRICSCAD_COM_ATTACHED=1
      fi
      if grep -q '^CREATED=1$' "$WORKDIR/bricscad-com-stdout.txt" 2>/dev/null; then
        BRICSCAD_COM_CREATED=1
      fi
      wait_for_status
      return 0
    fi
    echo "cscript.exe not found; falling back to direct BricsCAD launch." >&2
  fi

  BRICSCAD_BRIDGE_MODE="direct"
  if [[ -z "$exe" || ! -f "$exe" ]]; then
    echo "bricscad.exe not found. Set BRICSCAD_EXE." >&2
    return 3
  fi
  win_scrfile="$(to_windows_path "$SCRFILE")"
  cmd=("$exe")
  if [[ "$EPURE_REQUESTED" == "1" ]]; then
    epure_control="$(windows_epure_control_script bricscad || true)"
    if [[ -z "$epure_control" ]]; then
      echo "EPURE bootstrap script not found in %APPDATA%\\sncf\\epure\\epure 2022_b." >&2
      return 2
    fi
    workdir="$(windows_cad_workdir "$exe")"
    cmd+=(/P Epure)
  fi
  cmd+=(/B "$win_scrfile")
  maybe_dry_run "${cmd[@]}"

  if [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]]; then
    printf '%q ' "${cmd[@]}" >"$BRICSCAD_BATCH_COMMAND_FILE"
    printf '\n' >>"$BRICSCAD_BATCH_COMMAND_FILE"
    BRICSCAD_BATCH_LAUNCHED=1
    BRICSCAD_BATCH_REAPED=0
    BRICSCAD_BATCH_COMPLETED=0
    BRICSCAD_BATCH_RC=""
    BRICSCAD_BATCH_PID=""
    BRICSCAD_BATCH_CHILD_PID=""
    BRICSCAD_BATCH_START_TS="$(date +%s 2>/dev/null || echo 0)"
    (
      if [[ -n "$workdir" ]]; then
        cd "$workdir"
      fi
      "${cmd[@]}" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt"
    ) &
    BRICSCAD_BATCH_PID=$!
    BRICSCAD_BATCH_CHILD_PID="$BRICSCAD_BATCH_PID"
    return 0
  fi
  if [[ -n "$workdir" ]]; then
    (
      cd "$workdir"
      "${cmd[@]}" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt"
    ) || true
  else
    "${cmd[@]}" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
  fi
}

run_macos_bricscad_fallback() {
  local app=""
  if [[ -n "${BRICSCAD_EXE:-}" && -x "${BRICSCAD_EXE}" && "${BRICSCAD_EXE}" != *.app && "${BRICSCAD_EXE}" != */Contents/MacOS/* ]]; then
    if [[ "$USE_REMOTE_PROTOCOL" -eq 1 ]]; then
      maybe_dry_run "${BRICSCAD_EXE}" -B "$SCRFILE"
      MACOS_ASYNC=1
      BRICSCAD_BATCH_LAUNCHED=1
      BRICSCAD_BATCH_REAPED=0
      BRICSCAD_BATCH_COMPLETED=0
      BRICSCAD_BATCH_RC=""
      BRICSCAD_BATCH_START_TS="$(date +%s 2>/dev/null || echo 0)"
      "${BRICSCAD_EXE}" -B "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" &
      BRICSCAD_BATCH_PID=$!
      BRICSCAD_BATCH_CHILD_PID="$BRICSCAD_BATCH_PID"
    else
      maybe_dry_run "${BRICSCAD_EXE}" "$RUNLSPFILE"
      "${BRICSCAD_EXE}" "$RUNLSPFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
    fi
    return 0
  fi
  app="$(find_macos_bricscad_app)"
  if [[ -z "$app" ]]; then
    echo "BricsCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  local appname
  appname=$(basename "$app" .app)
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf '# --dry: would drive %s via UI scripting (osascript), evaluating: %s\n' "$appname" "$lisp_cmd"
    if [[ "$CAD_BACKEND" == "launch" ]]; then
      printf '/usr/bin/open -a %q\n' "$app"
    fi
    exit 0
  fi
  if [[ "$CAD_BACKEND" == "launch" ]]; then
    /usr/bin/open -a "$app" >/dev/null 2>&1 || true
  elif ! macos_app_running "$appname"; then
    echo "BricsCAD is not running. Relaunch with --backend launch or start BricsCAD first." >&2
    return 3
  fi
/usr/bin/osascript \
    - "$appname" "$lisp_cmd" \
    "${AUTOLISP_MACOS_BRICSCAD_RESET_ESCAPES:-6}" \
    "${AUTOLISP_MACOS_BRICSCAD_RESET_DELAY_SECS:-0.25}" \
    "${AUTOLISP_MACOS_BRICSCAD_COMMAND_DELAY_SECS:-0.4}" <<'OSA' || true
on resetBricscadUI(appName, resetEscapes, resetDelay, commandDelay)
  tell application appName to activate
  tell application "System Events"
    tell process appName
      set frontmost to true
      if (count of windows) > 0 then
        try
          perform action "AXRaise" of window 1
        end try
      end if
    end tell
    delay commandDelay
    repeat resetEscapes times
      key code 53
      delay resetDelay
    end repeat
    keystroke "_.COMMANDLINE"
    key code 36
    delay commandDelay
    repeat 2 times
      key code 53
      delay resetDelay
    end repeat
    delay commandDelay
  end tell
end resetBricscadUI

on run argv
  set appName to item 1 of argv
  set lispCmd to item 2 of argv
  set resetEscapes to (item 3 of argv) as integer
  set resetDelay to (item 4 of argv) as real
  set commandDelay to (item 5 of argv) as real

  delay 1
  resetBricscadUI(appName, resetEscapes, resetDelay, commandDelay)
  tell application "System Events"
    keystroke lispCmd
    key code 36
  end tell
end run
OSA
}

run_macos_bricscad_batch() {
  local exe="$1"
  local app=""
  local -a cmd=()
  local -a open_cmd=()
  local -a launch_cmd=()
  local rc=0
  if [[ -z "$exe" || ! -f "$exe" ]]; then
    echo "BricsCAD CLI executable not found. Set BRICSCAD_EXE or install BricsCAD in /Applications." >&2
    return 3
  fi
  cmd=("$exe")
  # Sans drawing argument, BricsCAD reste bloque sur la dialog "Nouveau
  # dessin" et n'execute pas le -B script.scr -> autolisp time out a
  # 15s. On passe un template (DWT) pour court-circuiter cette dialog.
  local template_dwg=""
  template_dwg="$(find_macos_bricscad_template || true)"
  if [[ -n "$template_dwg" ]]; then
    cmd+=("$template_dwg")
  fi
  if [[ -n "$BRICSCAD_MACOS_PROFILE" ]]; then
    cmd+=("-P" "$BRICSCAD_MACOS_PROFILE")
  fi
  cmd+=("-B" "$SCRFILE")
  maybe_dry_run "${cmd[@]}"
  if [[ "$EXPERIMENTAL_MACOS_BATCH_OPEN" == "1" && "$USE_REMOTE_PROTOCOL" -eq 1 && "$CAD_BACKEND" == "launch" && "$exe" == */Contents/MacOS/bricscad ]]; then
    app="$(find_macos_bricscad_app)"
    if [[ -n "$app" ]]; then
      open_cmd=(/usr/bin/open -n -a "$app" --args)
      if [[ -n "$template_dwg" ]]; then
        open_cmd+=("$template_dwg")
      fi
      if [[ -n "$BRICSCAD_MACOS_PROFILE" ]]; then
        open_cmd+=("-P" "$BRICSCAD_MACOS_PROFILE")
      fi
      open_cmd+=("-B" "$SCRFILE")
      printf '%q ' "${open_cmd[@]}" >"$BRICSCAD_BATCH_COMMAND_FILE"
      printf '\n' >>"$BRICSCAD_BATCH_COMMAND_FILE"
      MACOS_ASYNC=1
      BRICSCAD_BATCH_LAUNCHED=1
      BRICSCAD_BATCH_REAPED=1
      BRICSCAD_BATCH_COMPLETED=0
      BRICSCAD_BATCH_RC=""
      BRICSCAD_BATCH_PID=""
      BRICSCAD_BATCH_CHILD_PID=""
      BRICSCAD_BATCH_START_TS="$(date +%s 2>/dev/null || echo 0)"
      "${open_cmd[@]}" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || rc=$?
      if [[ "$rc" -ne 0 ]]; then
        BRICSCAD_BATCH_RC="$rc"
        BRICSCAD_BATCH_COMPLETED=1
        return 0
      fi
      BRICSCAD_BATCH_PID="$(find_bricscad_batch_pid || true)"
      emit_bricscad_launch_message "$BRICSCAD_BATCH_PID" "$exe"
      return 0
    fi
  fi
  if [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]]; then
    printf '%q ' "${cmd[@]}" >"$BRICSCAD_BATCH_COMMAND_FILE"
    printf '\n' >>"$BRICSCAD_BATCH_COMMAND_FILE"
    BRICSCAD_BATCH_LAUNCHED=1
    BRICSCAD_BATCH_REAPED=0
    BRICSCAD_BATCH_COMPLETED=0
    BRICSCAD_BATCH_RC=""
    BRICSCAD_BATCH_PID=""
    BRICSCAD_BATCH_CHILD_PID=""
    BRICSCAD_BATCH_START_TS="$(date +%s 2>/dev/null || echo 0)"
    "${cmd[@]}" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" &
    BRICSCAD_BATCH_PID=$!
    BRICSCAD_BATCH_CHILD_PID="$BRICSCAD_BATCH_PID"
    emit_bricscad_launch_message "$BRICSCAD_BATCH_PID" "$exe"
    return 0
  fi
  launch_cmd=("${cmd[@]}")
  if [[ -x /usr/bin/script ]]; then
    launch_cmd=(/usr/bin/script -q "$WORKDIR/bricscad-typescript.txt" "${cmd[@]}")
  fi
  printf '%q ' "${launch_cmd[@]}" >"$BRICSCAD_BATCH_COMMAND_FILE"
  printf '\n' >>"$BRICSCAD_BATCH_COMMAND_FILE"
  "${launch_cmd[@]}" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" &
  BRICSCAD_BATCH_PID=$!
  BRICSCAD_BATCH_CHILD_PID="$BRICSCAD_BATCH_PID"
  BRICSCAD_BATCH_LAUNCHED=1
  BRICSCAD_BATCH_REAPED=0
  BRICSCAD_BATCH_COMPLETED=0
  BRICSCAD_BATCH_RC=""
  BRICSCAD_BATCH_START_TS="$(date +%s 2>/dev/null || echo 0)"
  emit_bricscad_launch_message "$BRICSCAD_BATCH_PID" "$exe"
  return 0
}

kill_bricscad_batch_process() {
  local pid=""
  local pids=""

  if [[ "$BRICSCAD_BATCH_LAUNCHED" -ne 1 ]]; then
    return 0
  fi

  # Sur macOS, BricsCAD peut survivre apres un (command "_QUIT" ...) parce
  # que l'app reste vivante meme sans document (convention macOS). On tue
  # explicitement tout process bricscad dont l'argv contient notre SCRFILE
  # -- pas seulement le premier match, au cas ou il y aurait plusieurs
  # instances (rare mais possible avec relances apres erreur).
  if [[ -n "${SCRFILE:-}" ]]; then
    pids="$(ps -axo pid=,command= 2>/dev/null \
              | awk -v scr="$SCRFILE" 'index($0, scr) { gsub(/^[[:space:]]+/, ""); split($0, f, /[[:space:]]+/); print f[1] }')"
  fi
  # Ajoute le PID tracke si pas deja dans la liste (resilient si SCRFILE
  # est passe en var d'env plutot qu'en argv visible dans ps).
  if [[ -n "${BRICSCAD_BATCH_PID:-}" ]]; then
    case " $pids " in *" $BRICSCAD_BATCH_PID "*) ;; *) pids="$pids $BRICSCAD_BATCH_PID" ;; esac
  fi

  for pid in $pids; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    kill -0 "$pid" 2>/dev/null || continue
    kill -TERM "$pid" 2>/dev/null || true
  done

  sleep 1

  for pid in $pids; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    if kill -0 "$pid" 2>/dev/null; then
      kill -KILL "$pid" 2>/dev/null || true
    fi
  done

  reap_bricscad_batch_process || true
}

run_macos_autocad_fallback() {
  local app=""
  app="$(ls -1d /Applications/Autodesk*/AutoCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "AutoCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf '# --dry: would drive AutoCAD via UI scripting (osascript), evaluating: %s\n' "$lisp_cmd"
    printf '/usr/bin/open -a %q\n' "$app"
    exit 0
  fi
  /usr/bin/open -a "$app" >/dev/null 2>&1 || true
  /usr/bin/osascript - "$lisp_cmd" <<'OSA' || true
on run argv
  set lispCmd to item 1 of argv
  delay 1
  tell application "System Events"
    tell process "AutoCAD"
      set frontmost to true
    end tell
    key code 53
    key code 53
    delay 0.15
    keystroke lispCmd
    key code 36
  end tell
end run
OSA
}

run_direct_unix_cli() {
  local exe="$1"
  [[ -n "$exe" && -f "$exe" ]] || return 3
  maybe_dry_run "$exe" /b "$RUNLSPFILE"
  "$exe" /b "$RUNLSPFILE" >"$WORKDIR/direct-stdout.txt" 2>"$WORKDIR/direct-stderr.txt" || true
}

autolisp_debug "engine dispatch: ENGINE=$ENGINE IS_WINDOWS=$IS_WINDOWS IS_MACOS=$IS_MACOS"
case "$ENGINE" in
  autocad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      autolisp_debug "-> run_windows_autocad"
      run_windows_autocad || true
      autolisp_debug "<- run_windows_autocad"
    else
      if [[ -n "$AUTOCAD_EXE" ]]; then
        autolisp_debug "-> run_direct_unix_cli AUTOCAD_EXE=$AUTOCAD_EXE"
        run_direct_unix_cli "$AUTOCAD_EXE" || run_macos_autocad_fallback || true
      else
        autolisp_debug "-> run_macos_autocad_fallback (no AUTOCAD_EXE)"
        run_macos_autocad_fallback || true
      fi
    fi
    ;;
  bricscad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      autolisp_debug "-> run_windows_bricscad"
      run_windows_bricscad || true
      autolisp_debug "<- run_windows_bricscad"
    else
      if [[ $IS_MACOS -eq 1 ]]; then
        case "$BRICSCAD_MACOS_EFFECTIVE_MODE" in
          batch)
            run_macos_bricscad_batch "$(find_macos_bricscad_cli || true)" || true
            ;;
          automation)
            run_macos_bricscad_fallback || true
            ;;
          *)
            echo "Unsupported BricsCAD macOS mode: ${BRICSCAD_MACOS_EFFECTIVE_MODE:-unset}" >&2
            ;;
        esac
      elif [[ -n "$BRICSCAD_EXE" ]]; then
        maybe_dry_run "$BRICSCAD_EXE" -b "$SCRFILE"
        "$BRICSCAD_EXE" -b "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
      else
        echo "bricscad executable not found. Set BRICSCAD_EXE." >&2
        true
      fi
    fi
    ;;
  *)
    echo "Unknown engine: $ENGINE" >&2
    exit 2
    ;;
esac

if [[ "$MACOS_ASYNC" -eq 1 ]]; then
  if [[ -z "${AUTOLISP_KEEP_WORKDIR:-}" ]]; then
    CLEANUP_WORKDIR="1"
  fi
fi

wait_rc=0
if [[ "$USE_REMOTE_PROTOCOL" -eq 1 ]]; then
  if [[ "$INTERACTIVE" -eq 1 && "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]]; then
    if ! wait_protocol_interactive_helper; then
      wait_rc=$?
    fi
  elif [[ "$INTERACTIVE" -eq 1 ]]; then
    run_protocol_interactive_repl
    exit $?
  elif ! run_protocol_noninteractive; then
    wait_rc=$?
  fi
elif [[ "$USE_BATCH_INTERACTIVE_REPL" -eq 1 ]]; then
  run_batch_interactive_repl
  exit $?
else
  if ! wait_for_status; then
    wait_rc=$?
  fi

  if [[ "$wait_rc" -eq 0 ]]; then
    if ! wait_for_batch_process_exit; then
      wait_rc=$?
    fi
  fi
fi

if [[ "$wait_rc" -ne 0 ]]; then
  kill_bricscad_batch_process || true
  kill_autocad_com_process || true
fi

stop_protocol_foreground_relay

if [[ "$INTERRUPTED" -eq 1 ]]; then
  exit 130
fi

if [[ "$USE_REMOTE_PROTOCOL" -eq 1 && "$INTERACTIVE" -eq 1 ]]; then
  if [[ "$wait_rc" -eq 124 ]]; then
    exit 124
  fi
  exit "$wait_rc"
fi

if [[ ! -f "${PROTOCOL_STREAM_MARKER:-}" && "$PROTOCOL_STREAMED_OUTPUT" -eq 0 ]]; then
  LOGFILE_FOUND="$(find_log_file)"
  SESSION_OUTPUT_FILE="$(find_session_output_file || true)"
  render_stdout "$OUTFILE" "$SESSION_OUTPUT_FILE" "$CLI_VERBOSE" || cat "$OUTFILE" || true
  cat "$ERRFILE" >&2 || true
fi

if [[ "$wait_rc" -eq 124 ]]; then
  exit 124
fi

STATUS="1"
if [[ -s "$STATUSFILE" ]]; then
  STATUS="$(awk 'NF{line=$0} END{print line}' "$STATUSFILE" | tr -d '[:space:]')"
fi
if ! [[ "$STATUS" =~ ^[0-9]+$ ]]; then
  summary="$(awk '/^TOTAL=/{line=$0} END{print line}' "$OUTFILE" 2>/dev/null || true)"
  if [[ -n "$summary" && "$summary" =~ FAIL=0[[:space:]]+ERROR=0$ ]]; then
    STATUS=0
  else
    STATUS=1
  fi
fi

exit "$STATUS"
