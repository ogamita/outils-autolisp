#!/usr/bin/env bash
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
# Repertoire d'ou l'utilisateur a appele autolisp. Capture des le debut, AVANT
# que le script ne fasse des `cd` internes. Ce chemin est expose au runtime
# LISP via *AUTOLISP_INVOCATION_DIR* et utilise pour resoudre les chemins
# relatifs (acad.exe lance via COM a son propre cwd, generalement son dossier
# d'install -- pas celui du shell appelant).
AUTOLISP_INVOCATION_DIR="$(pwd -P 2>/dev/null || pwd)"
# Shell-side helpers for the future remote I/O protocol.
. "$SELF_DIR/lib/autolisp-remote-io.sh"
VERSION_FILE="$SELF_DIR/VERSION.TXT"
if [[ -f "$VERSION_FILE" ]]; then
  # shellcheck source=/dev/null
  . "$VERSION_FILE"
fi

autolisp_version_string() {
  printf 'autolisp %s.%s.%s\n' "${VERSION_MAJOR:-0}" "${VERSION_MINOR:-0}" "${VERSION_PATCH:-0}"
}

usage() {
  cat <<'EOU'
Usage:
  autolisp -V|--version | -h|--help
  autolisp [options]... { [-l|--load] source.lsp | -x|--eval expression | -i|--interactive | --main C:MAIN | --quit }...

  Les options d'action peuvent être mélangées à volonté et sont traitées dans l'ordre.

Examples:
  autolisp test.lsp
  autolisp -l lib1.lsp -l lib2.lsp --main C:RUN
  autolisp --bricscad --epure test.lsp
  autolisp -x '(princ (+ 1 2))'
  autolisp --eval '(setq *x* 42)' test.lsp
  autolisp -i
  autolisp --autocad --mode automation \
           -x '(vlisp-compile (quote lsa) "src-vlx/schmsplus.prj")' \
           --quit

Semantics:
  - Les actions { [-l|--load] source.lsp | -x|--eval expression } sont traitées dans l'ordre.
  - Chaque source.lsp est chargé avec (load "...").
  - Chaque -x|--eval expression est évaluée comme une forme AutoLISP.
  - Si au moins un fichier source.lsp est fourni, (${MAIN:-C:MAIN}) est appelé à la fin.
  - --quit termine le moteur et autolisp ; les options suivantes sont ignorées.

Outputs:
  stdout  -> contenu de OUTFILE
  stderr  -> contenu de ERRFILE
  exit    -> code lu dans STATUSFILE

Generic options:
  -V, --version           Affiche la version puis quitte.
  -h, --help              Affiche ce message d'aide puis quitte.
  -q, --quiet             Supprime les messages d'information non essentiels.
  -v, --verbose           Affiche les labels structurés et davantage de diagnostics.
  -d, --debug             Trace chaque étape interne (sondes [DEBUG] sur stderr,
                          y compris les commandes externes lancées).
  -norc, --no-init        Inhibe le chargement de ~/.autolisp{,rc}{,.lsp}.
  --dry, --dry-run        Affiche la commande qui aurait été exécutée (CAD launch)
                          puis quitte sans rien lancer.

Action options (processed in order):
  -l, --load FILE         Charger un fichier AutoLISP (load).
  -x, --eval EXPRESSION   Évaluer une forme AutoLISP.
  -i, --interactive       Active le mode REPL.
  --main C:MAIN           Nom de la commande appelée après les actions.
  --quit                  Force la sortie ; ignore les options suivantes.

Engine options:
  --autocad               Force le moteur AutoCAD.
  --bricscad              Force le moteur BricsCAD.
  --dwg FILE              DWG fourni au Core Console AutoCAD.

Specific options:
  --epure                 Sous Windows, charge EPURE avant le script principal.
                          BricsCAD: lance /P Epure avec le bootstrap
                          %APPDATA%\sncf\epure\epure 2022_b\control_path_epure_2022.scr
                          AutoCAD: lance /p Epure avec le bootstrap
                          %APPDATA%\sncf\epure\epure 2022\control_path_epure_2022.scr
                          Avec AutoCAD, cette option requiert AUTOCAD_EXE.

Technical options:
  --timeout N             Durée maximale d'attente du runtime CAD.
  --bootstrap-phase PHASE marker | core | log | full
  --mode MODE             automation | batch
                          Sur Windows + AutoCAD : automation active le
                            pont COM AutoCAD.Application (acad.exe
                            visible) ; batch lance acad.exe /b sans
                            COM, ou accoreconsole.exe en fallback.
                          Sur Windows + BricsCAD : automation active le
                            pont COM BricsCAD.Application ; batch lance
                            bricscad.exe /b sans COM.
                          Sur macOS + BricsCAD : automation = AppleScript
                            UI-bridge ; batch = bricscad headless.
  --backend BACKEND       attach | launch (mode automation)
  --bricscad-macos-profile NAME   Profil BricsCAD pour le mode batch macOS.

Environment overrides:
  AUTOCAD_ACCORECONSOLE   Path to accoreconsole.exe (Windows)
  AUTOCAD_COM_MODE        auto | attach | launch | off   (Windows + AutoCAD only)
  AUTOCAD_EXE             Path to acad.exe / acadlt.exe  (Windows)
  BRICSCAD_EXE            Path to bricscad.exe      (Windows)
  AUTOLISP_MODE           auto | automation | batch
  AUTOLISP_BACKEND        attach | launch
  BRICSCAD_MACOS_PROFILE  BricsCAD profile name     (macOS + BricsCAD batch only)
  AUTOLISP_BRICSCAD_TEMPLATE   Explicit template DWG/DWT for BricsCAD macOS
                          batch ; passe en argument avant -B SCRFILE pour
                          eviter la dialog "Nouveau dessin". Defaut :
                          recherche dans ~/Library/Application Support/
                          Bricsys/BricsCAD/V*/en_US/Templates/Default-*.dwt
  AUTOLISP_BRICSCAD_BATCH_EXIT_TIMEOUT   secondes a attendre que BricsCAD
                          exit apres l'envoi de QUIT. Si depasse, le
                          script kill explicitement le process (sur
                          macOS, _QUIT ne tue souvent pas l'app). Defaut 10s.
  AUTOLISP_BOOTSTRAP_PHASE marker | core | log | full
  AUTOLISP_DWG            Default DWG for AutoCAD Core Console if --dwg not provided
  BRICSCAD_COM_MODE       auto | attach | launch | off   (Windows + BricsCAD only)
  AUTOLISP_EPURE         1 to launch CAD with EPURE on Windows
  AUTOLISP_TIMEOUT        Legacy timeout override in seconds
  AUTOLISP_WAIT_SECS      wait timeout for async modes / COM bridge (default: 180)
  AUTOLISP_KEEP_WORKDIR   1 to keep temporary workdir
  AUTOLISP_VERBOSE        1 for extra diagnostics
  AUTOLISP_QUIET          1 to suppress informational messages
  AUTOLISP_DRY_RUN        1 -> idem --dry (print CAD launch cmd, exit)
  AUTOLISP_DEBUG          1 to trace each step (idem -d|--debug)
  AUTOLISP_NO_INIT        1 to inhibit ~/.autolisp{,rc}{,.lsp,...} (idem -norc)

Notes:
  - AutoCAD Core Console (accoreconsole.exe) est Windows-only dans la pratique.
  - --epure n'a d'effet que sous Windows.
  - Sous Windows + BricsCAD, le script peut utiliser un pont COM autonome généré dans le workdir.
  - Sous macOS, le fallback reste piloté par UI scripting et dépend des autorisations Accessibilité.
EOU
}

ENGINE=""
DWG=""
MAIN="C:MAIN"
MAIN_REQUESTED=0
TIMEOUT_SECS="${AUTOLISP_WAIT_SECS:-${AUTOLISP_TIMEOUT:-180}}"
AUTOCAD_COM_MODE="${AUTOCAD_COM_MODE:-auto}"
AUTOCAD_EXE="${AUTOCAD_EXE:-}"
BRICSCAD_EXE="${BRICSCAD_EXE:-C:/Program Files/Bricsys/BricsCAD V25 fr_FR/bricscad.exe}"
CAD_MODE="${AUTOLISP_MODE:-auto}"
CAD_BACKEND="${AUTOLISP_BACKEND:-launch}"
BRICSCAD_MACOS_PROFILE="${BRICSCAD_MACOS_PROFILE:-}"
EPURE_REQUESTED="${AUTOLISP_EPURE:-0}"
AUTOLISP_REMOTE_IO_MODE="${AUTOLISP_REMOTE_IO_MODE:-auto}"
BOOTSTRAP_PHASE="${AUTOLISP_BOOTSTRAP_PHASE:-full}"
INTERACTIVE=0
CLI_VERBOSE=0
CLI_QUIET=0
CLI_DEBUG=0
AUTOLISP_DEBUG="${AUTOLISP_DEBUG:-0}"
VERSION_ONLY=0
NO_INIT="${AUTOLISP_NO_INIT:-0}"
QUIT_REQUESTED=0
DRY_RUN="${AUTOLISP_DRY_RUN:-0}"

declare -a ACTION_KINDS=()
declare -a ACTION_VALUES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --autocad)
      ENGINE="autocad"
      shift
      ;;
    --bricscad)
      ENGINE="bricscad"
      shift
      ;;
    --timeout)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --timeout" >&2
        usage
        exit 2
      fi
      TIMEOUT_SECS="$2"
      shift 2
      ;;
    --bootstrap-phase)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bootstrap-phase" >&2
        usage
        exit 2
      fi
      BOOTSTRAP_PHASE="$2"
      shift 2
      ;;
    --mode)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --mode" >&2
        usage
        exit 2
      fi
      CAD_MODE="$2"
      shift 2
      ;;
    --backend)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --backend" >&2
        usage
        exit 2
      fi
      CAD_BACKEND="$2"
      shift 2
      ;;
    --bricscad-macos-profile)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --bricscad-macos-profile" >&2
        usage
        exit 2
      fi
      BRICSCAD_MACOS_PROFILE="$2"
      shift 2
      ;;
    --epure)
      EPURE_REQUESTED=1
      shift
      ;;
    -V|--version)
      VERSION_ONLY=1
      shift
      ;;
    -norc|--no-init)
      NO_INIT=1
      shift
      ;;
    --dry|--dry-run)
      DRY_RUN=1
      shift
      ;;
    --quit)
      QUIT_REQUESTED=1
      shift
      break
      ;;
    --dwg)
      DWG="${2:-}"
      shift 2
      ;;
    --main)
      MAIN="${2:-}"
      MAIN_REQUESTED=1
      shift 2
      ;;
    -i|--interactive)
      INTERACTIVE=1
      shift
      ;;
    -v|--verbose)
      CLI_VERBOSE=1
      shift
      ;;
    -q|--quiet)
      CLI_QUIET=1
      shift
      ;;
    -d|--debug)
      CLI_DEBUG=1
      shift
      ;;
    -x|--eval)
      if [[ $# -lt 2 ]]; then
        echo "Missing expression after $1" >&2
        usage
        exit 2
      fi
      ACTION_KINDS+=("eval")
      ACTION_VALUES+=("$2")
      shift 2
      ;;
    -l|--load)
      if [[ $# -lt 2 ]]; then
        echo "Missing file after $1" >&2
        usage
        exit 2
      fi
      ACTION_KINDS+=("load")
      ACTION_VALUES+=("$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        ACTION_KINDS+=("load")
        ACTION_VALUES+=("$1")
        shift
      done
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      ACTION_KINDS+=("load")
      ACTION_VALUES+=("$1")
      shift
      ;;
  esac
done

if [[ "$VERSION_ONLY" -eq 1 ]]; then
  autolisp_version_string
  exit 0
fi

# Recherche du fichier d'initialisation: ~/.autolisp{,rc}{,.lsp,.fas,.vlx,.des}.
# Conformément à la spécification, on retient le premier fichier existant en
# parcourant les variantes dans l'ordre. Pour chaque souche, un fichier compilé
# n'est préféré que s'il est plus récent que la variante .lsp correspondante.
find_rc_file() {
  local stem candidates_compiled best_compiled lsp ext compiled
  for stem in "$HOME/.autolisp" "$HOME/.autolisprc"; do
    if [[ -f "$stem" ]]; then
      printf '%s\n' "$stem"
      return 0
    fi
    lsp="$stem.lsp"
    best_compiled=""
    for ext in fas des vlx; do
      compiled="$stem.$ext"
      [[ -f "$compiled" ]] || continue
      if [[ -f "$lsp" && ! "$compiled" -nt "$lsp" ]]; then
        continue
      fi
      if [[ -z "$best_compiled" || "$compiled" -nt "$best_compiled" ]]; then
        best_compiled="$compiled"
      fi
    done
    if [[ -n "$best_compiled" ]]; then
      printf '%s\n' "$best_compiled"
      return 0
    fi
    if [[ -f "$lsp" ]]; then
      printf '%s\n' "$lsp"
      return 0
    fi
  done
  return 1
}

if [[ "$NO_INIT" -eq 0 ]]; then
  RC_FILE="$(find_rc_file || true)"
  if [[ -n "$RC_FILE" ]]; then
    if (( ${#ACTION_KINDS[@]} > 0 )); then
      ACTION_KINDS=("load" "${ACTION_KINDS[@]}")
      ACTION_VALUES=("$RC_FILE" "${ACTION_VALUES[@]}")
    else
      ACTION_KINDS=("load")
      ACTION_VALUES=("$RC_FILE")
    fi
  fi
fi

interactive_form_complete() {
  local form="$1"
  perl -e '
my $s = shift;
my ($depth, $in_string, $escape, $in_comment, $started) = (0, 0, 0, 0, 0);
foreach my $ch (split //, $s) {
  if ($in_comment) {
    $in_comment = 0 if $ch eq "\n";
    next;
  }
  if ($in_string) {
    $started = 1;
    if ($escape) {
      $escape = 0;
      next;
    }
    if ($ch eq "\\") {
      $escape = 1;
      next;
    }
    if ($ch eq "\"") {
      $in_string = 0;
    }
    next;
  }
  if ($ch eq ";") {
    $in_comment = 1;
    next;
  }
  if ($ch =~ /\s/) {
    next;
  }
  $started = 1;
  if ($ch eq "\"") {
    $in_string = 1;
    next;
  }
  if ($ch eq "(") {
    $depth++;
    next;
  }
  if ($ch eq ")") {
    $depth-- if $depth > 0;
    next;
  }
}
exit(($started && !$in_string && !$in_comment && $depth == 0) ? 0 : 1);
' -- "$form"
}

interactive_print_response() {
  local stdout_file="$1"
  local stderr_file="$2"
  local stdout_block result_line emitted=0

  stdout_block="$(
    awk '
    BEGIN { capture = 0 }
    /^OUTPUT$/ { capture = 1; next }
    /^RESULT / { capture = 0 }
    capture { print }
    ' "$stdout_file"
  )"
  result_line="$(awk '/^RESULT /{sub(/^RESULT /, ""); print; exit}' "$stdout_file")"

  if autolisp_is_verbose; then
    printf 'STDOUT\n'
    if [[ -n "$stdout_block" ]]; then
      printf '%s\n' "$stdout_block"
    fi

    printf 'STDERR\n'
    if [[ -s "$stderr_file" ]]; then
      cat "$stderr_file"
    fi

    printf 'RESULT\n'
    if [[ -n "$result_line" ]]; then
      printf '%s\n' "$result_line"
    fi
    printf '\n'
    return 0
  fi

  if [[ -n "$stdout_block" ]]; then
    printf '%s\n' "$stdout_block"
    emitted=1
  fi

  if [[ -s "$stderr_file" ]]; then
    cat "$stderr_file"
    emitted=1
  fi

  if [[ -n "$result_line" ]]; then
    printf '%s\n' "$result_line"
    emitted=1
  fi

  if [[ "$emitted" -eq 1 ]]; then
    printf '\n'
  fi
}

write_atomic_file() {
  autolisp_protocol_write_atomic_file "$1" "$2"
}

read_status_file() {
  if [[ -f "$STATUSFILE" ]]; then
    awk 'NF{line=$0} END{print line}' "$STATUSFILE" 2>/dev/null || true
  fi
}

batch_runner_done_without_status() {
  local current_status="$1"
  local batch_rc=""
  if [[ "$BRICSCAD_BATCH_COMPLETED" -eq 1 ]]; then
    if [[ -z "$current_status" || "$current_status" == "__PENDING__" || "$current_status" == "99" ]]; then
      CLEANUP_WORKDIR="1"
      FORCE_REPORT_WORKDIR="1"
      batch_rc="$BRICSCAD_BATCH_RC"
      autolisp_error "BricsCAD batch process exited before writing a final status."
      if [[ -n "$batch_rc" ]]; then
        autolisp_error "BricsCAD batch exit code: $batch_rc"
      fi
      autolisp_hint "the startup script may not have run, or (load \"$RUNLSPFILE\") failed before autolisp initialized."
      autolisp_verbose_dump_file "$WORKDIR/bricscad-stderr.txt"
      return 0
    fi
  fi
  if [[ "$BRICSCAD_BATCH_LAUNCHED" -eq 1 ]]; then
    if ! bricscad_batch_process_running; then
      reap_bricscad_batch_process || true
      if [[ -z "$current_status" || "$current_status" == "__PENDING__" || "$current_status" == "99" ]]; then
        CLEANUP_WORKDIR="1"
        FORCE_REPORT_WORKDIR="1"
        batch_rc="$BRICSCAD_BATCH_RC"
        autolisp_error "BricsCAD batch process exited before writing a final status."
        if [[ -n "$batch_rc" ]]; then
          autolisp_error "BricsCAD batch exit code: $batch_rc"
        fi
        autolisp_hint "the startup script may not have run, or (load \"$RUNLSPFILE\") failed before autolisp initialized."
        autolisp_verbose_dump_file "$WORKDIR/bricscad-stderr.txt"
        return 0
      fi
    fi
  fi
  return 1
}

batch_startup_stalled() {
  local current_status="$1"
  local now elapsed

  [[ "$ENGINE" == "bricscad" && $IS_MACOS -eq 1 && "$BRICSCAD_MACOS_EFFECTIVE_MODE" == "batch" ]] || return 1
  [[ "$BRICSCAD_BATCH_LAUNCHED" -eq 1 && "$BRICSCAD_BATCH_START_TS" -gt 0 ]] || return 1
  [[ "$current_status" == "__PENDING__" ]] || return 1
  [[ ! -s "$OUTFILE" && ! -s "$ERRFILE" ]] || return 1
  bricscad_batch_process_running || return 1

  now="$(date +%s 2>/dev/null || echo 0)"
  [[ "$now" =~ ^[0-9]+$ ]] || return 1
  elapsed=$((now - BRICSCAD_BATCH_START_TS))
  [[ "$elapsed" -ge "$BRICSCAD_BATCH_STARTUP_TIMEOUT_SECS" ]] || return 1

  CLEANUP_WORKDIR="1"
  FORCE_REPORT_WORKDIR="1"
  autolisp_error "BricsCAD batch launch stayed pending for ${BRICSCAD_BATCH_STARTUP_TIMEOUT_SECS}s without running the startup script."
  autolisp_hint "on this macOS setup, BricsCAD likely ignored the requested startup file before AutoLISP initialized."
  if [[ -n "$BRICSCAD_BATCH_COMMAND_FILE" && -f "$BRICSCAD_BATCH_COMMAND_FILE" ]]; then
    autolisp_verbose_note "DETAIL: status.txt stayed '__PENDING__' and no output or error file was produced."
    autolisp_verbose_note "DETAIL: attempted launch command:"
    autolisp_verbose_dump_file "$BRICSCAD_BATCH_COMMAND_FILE"
  fi
  kill_bricscad_batch_process || true
  return 0
}

wait_for_status_value() {
  local expected="$1"
  local timeout="$TIMEOUT_SECS"
  local current
  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi
    current="$(read_status_file)"
    if [[ "$current" == "$expected" ]]; then
      return 0
    fi
    if batch_startup_stalled "$current"; then
      return 124
    fi
    if batch_runner_done_without_status "$current"; then
      return 1
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  autolisp_error "timeout waiting for status '$expected' after ${TIMEOUT_SECS}s"
  return 124
}

wait_for_protocol_ready() {
  local timeout="$TIMEOUT_SECS"
  local protocol_status legacy_status

  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi

    protocol_status="$(autolisp_protocol_read_status)"
    case "$protocol_status" in
      READY*|WAITING-INPUT*)
        return 0
        ;;
      FAILED*)
        autolisp_error "protocol runtime failed during startup: $protocol_status"
        return 1
        ;;
    esac

    legacy_status="$(read_status_file)"
    if batch_startup_stalled "$legacy_status"; then
      return 124
    fi
    if batch_runner_done_without_status "$legacy_status"; then
      return 1
    fi

    sleep 1
    timeout=$((timeout - 1))
  done

  autolisp_error "timeout waiting for protocol runtime readiness after ${TIMEOUT_SECS}s"
  return 124
}

wait_for_protocol_status_prefix() {
  local expected_prefix="$1"
  local timeout="$TIMEOUT_SECS"
  local protocol_status legacy_status

  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi

    protocol_status="$(autolisp_protocol_read_status)"
    case "$protocol_status" in
      "$expected_prefix"|"$expected_prefix "*) return 0 ;;
      FAILED*)
        autolisp_error "protocol runtime failed: $protocol_status"
        return 1
        ;;
    esac

    legacy_status="$(read_status_file)"
    if batch_startup_stalled "$legacy_status"; then
      return 124
    fi
    if batch_runner_done_without_status "$legacy_status"; then
      return 1
    fi

    sleep 1
    timeout=$((timeout - 1))
  done

  autolisp_error "timeout waiting for protocol status '$expected_prefix' after ${TIMEOUT_SECS}s"
  return 124
}

wait_for_batch_process_exit() {
  # Apres que le lisp ait ecrit son status final, on attend que BricsCAD
  # exit de lui-meme. Sur macOS, (command "_QUIT" "_Y") ne tue pas l'app
  # (convention macOS : l'app reste vivante meme sans doc) -> on kill
  # explicitement le process apres une courte attente. Le travail est
  # deja termine cote lisp, donc le kill ne perd rien.
  #
  # Le timeout post-finish est court (defaut 10s) -- distinct du timeout
  # de chargement TIMEOUT_SECS qui peut etre 180s.
  local timeout="$BRICSCAD_BATCH_EXIT_TIMEOUT_SECS"
  [[ "$BRICSCAD_BATCH_LAUNCHED" -eq 1 ]] || return 0

  while [[ "$timeout" -gt 0 ]]; do
    if ! bricscad_batch_process_running; then
      reap_bricscad_batch_process || true
      return 0
    fi
    sleep 1
    timeout=$((timeout - 1))
  done

  autolisp_error "BricsCAD batch process did not exit after writing its final status within ${BRICSCAD_BATCH_EXIT_TIMEOUT_SECS}s; killing it."
  kill_bricscad_batch_process || true
  reap_bricscad_batch_process || true
  return 0
}

PROTOCOL_REQUEST_SEQ=0
PROTOCOL_REQUEST_SEQFILE=""
PROTOCOL_CLIENT_REQ_ID=0
PROTOCOL_STREAM_OUT_LINES=0
PROTOCOL_STREAM_ERR_LINES=0
PROTOCOL_STREAM_OUTPUT_OPEN=0
PROTOCOL_STREAMED_OUTPUT=0
PROTOCOL_FOREGROUND_RELAY_PID=""
PROTOCOL_LAST_REQUEST_QUIT=0
PROTOCOL_INTERACTIVE_HELPER_PID=""
PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN=0

protocol_new_request_slot() {
  local seq=0

  if [[ -n "$PROTOCOL_REQUEST_SEQFILE" && -f "$PROTOCOL_REQUEST_SEQFILE" ]]; then
    seq="$(awk 'NF{line=$0} END{print line}' "$PROTOCOL_REQUEST_SEQFILE" 2>/dev/null || echo 0)"
  fi
  if ! [[ "$seq" =~ ^[0-9]+$ ]]; then
    seq=0
  fi
  seq=$((seq + 1))
  if [[ -n "$PROTOCOL_REQUEST_SEQFILE" ]]; then
    printf '%s\n' "$seq" >"$PROTOCOL_REQUEST_SEQFILE"
  fi
  printf -v PROTOCOL_REQUEST_TAG '%03d' "$seq"
}

build_protocol_eval_request() {
  local form_text="$1"
  local eval_file request_file lisp_eval_file

  protocol_new_request_slot
  eval_file="$WORKDIR/protocol-eval-$PROTOCOL_REQUEST_TAG.lsp"
  request_file="$WORKDIR/protocol-request-$PROTOCOL_REQUEST_TAG.lsp"
  lisp_eval_file="$(to_runtime_lisp_path "$eval_file")"

  printf '%s' "$form_text" >"$eval_file"
  {
    printf '(autolisp-request-reset)\n'
    printf '(if (autolisp-run-eval-file 1 "%s") (autolisp-note-ok) (autolisp-note-fail))\n' \
      "$(escape_lisp_string "$lisp_eval_file")"
    printf '(autolisp-request-exit-code)\n'
  } >"$request_file"

  printf '%s\n' "$request_file"
}

build_protocol_actions_request() {
  local request_file idx kind abs_src eval_src

  protocol_new_request_slot
  request_file="$WORKDIR/protocol-request-$PROTOCOL_REQUEST_TAG.lsp"

  {
    printf '(autolisp-request-reset)\n'
    for idx in "${!ACTION_KINDS[@]}"; do
      kind="${ACTION_KINDS[$idx]}"
      if [[ "$kind" == "load" ]]; then
        abs_src="${LOAD_PATHS[$idx]}"
        printf '(if (autolisp-run-load %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' \
          "$((idx + 1))" "$(escape_lisp_string "$abs_src")"
      else
        eval_src="${EVAL_PATHS[$idx]}"
        printf '(if (autolisp-run-eval-file %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' \
          "$((idx + 1))" "$(escape_lisp_string "$eval_src")"
      fi
    done
    if [[ "$HAS_LOAD_ACTION" -eq 1 ]]; then
      printf '(if (= *AUTOLISP_FAIL* 0) (if (autolisp-run-main %s "%s") (autolisp-note-ok) (autolisp-note-fail)))\n' \
        "$(( ${#ACTION_KINDS[@]} + 1 ))" "$(escape_lisp_string "$MAIN")"
    fi
    printf '(autolisp-request-exit-code)\n'
  } >"$request_file"

  printf '%s\n' "$request_file"
}

build_protocol_main_request() {
  local request_file

  protocol_new_request_slot
  request_file="$WORKDIR/protocol-request-$PROTOCOL_REQUEST_TAG.lsp"

  {
    printf '(autolisp-request-reset)\n'
    printf '(if (= *AUTOLISP_FAIL* 0) (if (autolisp-run-main %s "%s") (autolisp-note-ok) (autolisp-note-fail)))\n' \
      "$(( ${#ACTION_KINDS[@]} + 1 ))" "$(escape_lisp_string "$MAIN")"
    printf '(autolisp-request-exit-code)\n'
  } >"$request_file"

  printf '%s\n' "$request_file"
}

build_protocol_noninteractive_startup_payload() {
  local request_file payload_file lisp_request_file

  request_file="$(build_protocol_actions_request)"
  payload_file="$WORKDIR/protocol-startup.lsp"
  lisp_request_file="$(to_runtime_lisp_path "$request_file")"

  {
    printf '(progn\n'
    printf '  (load "%s")\n' "$(escape_lisp_string "$lisp_request_file")"
    printf '  (setq *AUTOLISP_PROTOCOL_STOP* T)\n'
    printf '  (if (> *AUTOLISP_FAIL* 0) 1 0))\n'
  } >"$payload_file"

  cat "$payload_file"
}

prime_protocol_noninteractive_startup() {
  local payload

  payload="$(build_protocol_noninteractive_startup_payload)"
  autolisp_protocol_send_stdin "$payload"
}

submit_protocol_request_file() {
  local request_file="$1"
  local load_form lisp_request_file
  local stream_output=1

  PROTOCOL_CLIENT_REQ_ID=$((PROTOCOL_CLIENT_REQ_ID + 1))
  PROTOCOL_LAST_REQUEST_QUIT=0
  lisp_request_file="$(to_runtime_lisp_path "$request_file")"
  load_form="$(printf '(load "%s")\n' "$(escape_lisp_string "$lisp_request_file")")"
  if [[ "$INTERACTIVE" -eq 1 && "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 0 ]]; then
    stream_output=1
  else
    stream_output=0
  fi
  protocol_stream_request_reset
  autolisp_protocol_send_stdin "$load_form"
  wait_for_protocol_request_done "$PROTOCOL_CLIENT_REQ_ID" "$stream_output"
  if [[ "$INTERACTIVE" -eq 0 ]]; then
    protocol_flush_request_updates
  fi
}

shutdown_protocol_session() {
  autolisp_protocol_send_control "SHUTDOWN"
  wait_for_protocol_status_prefix "STOPPED" || return $?
  wait_for_batch_process_exit
}

protocol_stream_request_reset() {
  PROTOCOL_STREAM_OUT_LINES=0
  PROTOCOL_STREAM_ERR_LINES=0
  PROTOCOL_STREAM_OUTPUT_OPEN=0
  if [[ -n "${PROTOCOL_STREAM_MARKER:-}" ]]; then
    rm -f "$PROTOCOL_STREAM_MARKER"
  fi
}

protocol_emit_out_line() {
  local line="$1"

  PROTOCOL_STREAMED_OUTPUT=1
  if [[ -n "${PROTOCOL_STREAM_MARKER:-}" ]]; then
    : >"$PROTOCOL_STREAM_MARKER"
  fi

  case "$line" in
    LOAD\ *|EVAL\ *|MAIN\ *)
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      fi
      ;;
    '<<<AUTOLISP-STDOUT>>>'*)
      if autolisp_is_verbose && [[ "$PROTOCOL_STREAM_OUTPUT_OPEN" -eq 0 ]]; then
        printf 'OUTPUT\n'
        PROTOCOL_STREAM_OUTPUT_OPEN=1
      fi
      printf '%s\n' "${line#<<<AUTOLISP-STDOUT>>>}"
      ;;
    LOADED\ *)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    RESULT\ *)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      else
        printf '%s\n' "${line#RESULT }"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    MAIN-RESULT\ *)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      else
        printf '%s\n' "${line#MAIN-RESULT }"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    TOTAL=*)
      if autolisp_is_verbose; then
        printf '%s\n' "$line"
      fi
      PROTOCOL_STREAM_OUTPUT_OPEN=0
      ;;
    *)
      printf '%s\n' "$line"
      ;;
  esac
}

protocol_flush_out_updates() {
  local total_lines new_lines line

  [[ -f "$OUTFILE" ]] || return 0
  total_lines="$(wc -l <"$OUTFILE" 2>/dev/null || echo 0)"
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
  if [[ "$total_lines" -lt "$PROTOCOL_STREAM_OUT_LINES" ]]; then
    PROTOCOL_STREAM_OUT_LINES=0
    PROTOCOL_STREAM_OUTPUT_OPEN=0
  fi
  if [[ "$total_lines" -le "$PROTOCOL_STREAM_OUT_LINES" ]]; then
    return 0
  fi
  new_lines="$(awk -v start="$((PROTOCOL_STREAM_OUT_LINES + 1))" 'NR >= start { print }' "$OUTFILE")"
  while IFS= read -r line; do
    protocol_emit_out_line "$line"
  done <<<"$new_lines"
  PROTOCOL_STREAM_OUT_LINES="$total_lines"
}

protocol_flush_err_updates() {
  local total_lines new_lines line

  [[ -f "$ERRFILE" ]] || return 0
  total_lines="$(wc -l <"$ERRFILE" 2>/dev/null || echo 0)"
  [[ "$total_lines" =~ ^[0-9]+$ ]] || total_lines=0
  if [[ "$total_lines" -lt "$PROTOCOL_STREAM_ERR_LINES" ]]; then
    PROTOCOL_STREAM_ERR_LINES=0
  fi
  if [[ "$total_lines" -le "$PROTOCOL_STREAM_ERR_LINES" ]]; then
    return 0
  fi
  new_lines="$(awk -v start="$((PROTOCOL_STREAM_ERR_LINES + 1))" 'NR >= start { print }' "$ERRFILE")"
  while IFS= read -r line; do
    PROTOCOL_STREAMED_OUTPUT=1
    if [[ -n "${PROTOCOL_STREAM_MARKER:-}" ]]; then
      : >"$PROTOCOL_STREAM_MARKER"
    fi
    printf '%s\n' "$line" >&2
  done <<<"$new_lines"
  PROTOCOL_STREAM_ERR_LINES="$total_lines"
}

protocol_flush_request_updates() {
  protocol_flush_out_updates
  protocol_flush_err_updates
}

protocol_feed_waiting_input() {
  local line

  IFS= read -r line || return 1
  autolisp_protocol_send_stdin "$line"$'\n'
}

wait_for_protocol_request_done() {
  local req_id="$1"
  local stream_output="${2:-1}"
  local current_status=""
  local legacy_status=""
  local start_ts now elapsed

  start_ts="$(date +%s 2>/dev/null || echo 0)"
  while true; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi

    if [[ "$stream_output" -eq 1 ]]; then
      protocol_flush_request_updates
    fi
    current_status="$(autolisp_protocol_read_status)"
    if [[ "$current_status" == "DONE $req_id" || "$current_status" == "DONE $req_id "* ]]; then
      if [[ "$current_status" == "DONE $req_id QUIT" ]]; then
        PROTOCOL_LAST_REQUEST_QUIT=1
      fi
      if [[ "$stream_output" -eq 1 ]]; then
        protocol_flush_request_updates
      fi
      return 0
    fi
    if [[ "$current_status" == "STOPPED" ]]; then
      legacy_status="$(read_status_file)"
      if [[ "$legacy_status" == "0" ]]; then
        PROTOCOL_LAST_REQUEST_QUIT=1
        return 0
      fi
    fi
    if [[ "$current_status" == "FAILED READ" || "$current_status" == "STOPPED" ]]; then
      if [[ "$stream_output" -eq 1 ]]; then
        protocol_flush_request_updates
      fi
      return 1
    fi
    if [[ "$current_status" == "WAITING-INPUT" ]]; then
      if ! protocol_feed_waiting_input; then
        autolisp_error "stdin closed while AutoLISP was waiting for input."
        return 1
      fi
      continue
    fi
    if batch_startup_stalled "$current_status"; then
      return 124
    fi
    if batch_runner_done_without_status "$current_status"; then
      return 1
    fi

    now="$(date +%s 2>/dev/null || echo 0)"
    if [[ "$start_ts" =~ ^[0-9]+$ && "$now" =~ ^[0-9]+$ ]]; then
      elapsed=$((now - start_ts))
      if [[ "$elapsed" -ge "$TIMEOUT_SECS" ]]; then
        autolisp_error "timeout waiting for protocol request $req_id after ${TIMEOUT_SECS}s"
        return 124
      fi
    fi
    sleep 0.1
  done
}

protocol_foreground_relay_loop() {
  local current_status=""
  local line=""

  protocol_stream_request_reset
  while true; do
    protocol_flush_request_updates
    current_status="$(autolisp_protocol_read_status)"
    case "$current_status" in
      DONE*)
        protocol_flush_request_updates
        protocol_stream_request_reset
        ;;
      STOPPED|FAILED*)
        protocol_flush_request_updates
        return 0
        ;;
      WAITING-INPUT)
        if [[ -r /dev/tty ]]; then
          IFS= read -r line </dev/tty || return 1
          autolisp_protocol_send_stdin "$line"$'\n'
          continue
        fi
        ;;
    esac
    sleep 0.1
  done
}

start_protocol_foreground_relay() {
  [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]] || return 0
  PROTOCOL_STREAM_MARKER="$WORKDIR/protocol-streamed.flag"
  rm -f "$PROTOCOL_STREAM_MARKER"
  protocol_foreground_relay_loop &
  PROTOCOL_FOREGROUND_RELAY_PID=$!
}

stop_protocol_foreground_relay() {
  [[ -n "$PROTOCOL_FOREGROUND_RELAY_PID" ]] || return 0
  kill "$PROTOCOL_FOREGROUND_RELAY_PID" 2>/dev/null || true
  wait "$PROTOCOL_FOREGROUND_RELAY_PID" 2>/dev/null || true
  PROTOCOL_FOREGROUND_RELAY_PID=""
}

start_protocol_interactive_helper() {
  [[ "$USE_REMOTE_PROTOCOL" -eq 1 && "$INTERACTIVE" -eq 1 && "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]] || return 0
  exec 9<&0
  PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN=1
  run_protocol_interactive_repl <&9 &
  PROTOCOL_INTERACTIVE_HELPER_PID=$!
}

wait_protocol_interactive_helper() {
  local rc=0
  [[ -n "$PROTOCOL_INTERACTIVE_HELPER_PID" ]] || return 0
  if wait "$PROTOCOL_INTERACTIVE_HELPER_PID"; then
    rc=0
  else
    rc=$?
  fi
  PROTOCOL_INTERACTIVE_HELPER_PID=""
  if [[ "$PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN" -eq 1 ]]; then
    exec 9<&-
    PROTOCOL_INTERACTIVE_HELPER_STDIN_OPEN=0
  fi
  return "$rc"
}

run_protocol_noninteractive() {
  local request_file kind form_text

  wait_for_protocol_ready || return $?
  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      form_text="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      form_text="${ACTION_VALUES[$idx]}"
    fi
    request_file="$(build_protocol_eval_request "$form_text")"
    submit_protocol_request_file "$request_file" || return $?
  done
  if [[ "$MAIN_REQUESTED" -eq 1 ]]; then
    request_file="$(build_protocol_main_request)"
    submit_protocol_request_file "$request_file" || return $?
  fi
  shutdown_protocol_session
}

run_protocol_interactive_repl() {
  local prompt cont_prompt line buffer request_file rendered_file kind form_text idx

  prompt="autolisp> "
  cont_prompt="......> "
  wait_for_protocol_ready || return $?

  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      form_text="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      form_text="${ACTION_VALUES[$idx]}"
    fi
    request_file="$(build_protocol_eval_request "$form_text")"
    submit_protocol_request_file "$request_file" || return $?
    if [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 0 ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    elif [[ ! -f "${PROTOCOL_STREAM_MARKER:-}" ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    fi
  done

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    request_file="$(build_protocol_eval_request "$buffer")"
    submit_protocol_request_file "$request_file" || return $?
    if [[ "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 0 ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    elif [[ ! -f "${PROTOCOL_STREAM_MARKER:-}" ]]; then
      rendered_file="$WORKDIR/interactive-rendered.txt"
      render_stdout "$OUTFILE" "" 1 >"$rendered_file"
      interactive_print_response "$rendered_file" "$ERRFILE"
    fi
    if [[ "$PROTOCOL_LAST_REQUEST_QUIT" -eq 1 ]]; then
      printf 'Bye bye!\n'
      wait_for_protocol_status_prefix "STOPPED" || true
      wait_for_batch_process_exit || true
      return 0
    fi
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi

  shutdown_protocol_session
}

run_interactive_repl() {
  local self prompt cont_prompt line buffer case_dir stdout_file stderr_file kind action_form idx
  declare -a repl_args=()

  self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  prompt="autolisp> "
  cont_prompt="......> "
  [[ -n "$ENGINE" ]] && repl_args+=("--$ENGINE")
  repl_args+=("--timeout" "$TIMEOUT_SECS")
  if autolisp_is_quiet; then
    repl_args+=("--quiet")
  elif autolisp_is_verbose; then
    repl_args+=("--verbose")
  fi
  [[ -n "$DWG" ]] && repl_args+=("--dwg" "$DWG")
  repl_args+=("--mode" "$CAD_MODE" "--backend" "$CAD_BACKEND")
  if [[ "$ENGINE" == "bricscad" && -n "$BRICSCAD_MACOS_PROFILE" ]]; then
    repl_args+=("--bricscad-macos-profile" "$BRICSCAD_MACOS_PROFILE")
  fi
  if [[ "$EPURE_REQUESTED" == "1" ]]; then
    repl_args+=("--epure")
  fi

  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      action_form="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      action_form="${ACTION_VALUES[$idx]}"
    fi
    case_dir="$(mktemp -d "${TMPDIR:-/tmp}/autolisp-repl.XXXXXX")"
    stdout_file="$case_dir/stdout.txt"
    stderr_file="$case_dir/stderr.txt"
    AUTOLISP_SUPPRESS_VERSION_BANNER=1 "$self" "${repl_args[@]}" -x "$action_form" >"$stdout_file" 2>"$stderr_file" || true
    interactive_print_response "$stdout_file" "$stderr_file"
    rm -rf "$case_dir"
  done

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    case_dir="$(mktemp -d "${TMPDIR:-/tmp}/autolisp-repl.XXXXXX")"
    stdout_file="$case_dir/stdout.txt"
    stderr_file="$case_dir/stderr.txt"

    AUTOLISP_SUPPRESS_VERSION_BANNER=1 "$self" "${repl_args[@]}" -x "$buffer" >"$stdout_file" 2>"$stderr_file" || true
    interactive_print_response "$stdout_file" "$stderr_file"
    rm -rf "$case_dir"
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi
  return 0
}

run_batch_interactive_repl() {
  local prompt cont_prompt line buffer req_id payload rendered_file kind action_form idx
  prompt="autolisp> "
  cont_prompt="......> "
  req_id=0

  if ! wait_for_status_value "READY 0"; then
    return $?
  fi

  for idx in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$idx]}"
    if [[ "$kind" == "load" ]]; then
      action_form="(load \"$(escape_lisp_string "${ACTION_VALUES[$idx]}")\")"
    else
      action_form="${ACTION_VALUES[$idx]}"
    fi
    req_id=$((req_id + 1))
    payload=";REQ $req_id"$'\n'"$action_form"$'\n'
    write_atomic_file "$INPFILE" "$payload"
    if ! wait_for_status_value "READY $req_id"; then
      return $?
    fi
    rendered_file="$WORKDIR/interactive-rendered.txt"
    render_stdout "$OUTFILE" "" 1 >"$rendered_file"
    interactive_print_response "$rendered_file" "$ERRFILE"
  done

  buffer=""
  while true; do
    if [[ -t 0 ]]; then
      if [[ -n "$buffer" ]]; then
        IFS= read -r -p "$cont_prompt" line || break
      else
        IFS= read -r -p "$prompt" line || break
      fi
    else
      IFS= read -r line || break
    fi

    if [[ -n "$buffer" ]]; then
      buffer+=$'\n'
    fi
    buffer+="$line"

    if ! interactive_form_complete "$buffer"; then
      continue
    fi

    req_id=$((req_id + 1))
    payload=";REQ $req_id"$'\n'"$buffer"$'\n'
    write_atomic_file "$INPFILE" "$payload"

    if ! wait_for_status_value "READY $req_id"; then
      return $?
    fi

    rendered_file="$WORKDIR/interactive-rendered.txt"
    render_stdout "$OUTFILE" "" 1 >"$rendered_file"
    interactive_print_response "$rendered_file" "$ERRFILE"
    buffer=""
  done

  if [[ -n "${buffer//[$' \t\r\n']/}" ]]; then
    echo "autolisp: incomplete form at end of input" >&2
    return 1
  fi

  req_id=$((req_id + 1))
  payload=";REQ $req_id"$'\n'"'__AUTOLISP_QUIT__"$'\n'
  write_atomic_file "$INPFILE" "$payload"
  wait_for_status_value "STOP $req_id" || true
  # BricsCAD macOS batch shutdown is crash-prone, so terminate the launched PID
  # from the wrapper instead of asking BricsCAD to run its own _QUIT path.
  kill_bricscad_batch_process || true
  return 0
}

if [[ "$INTERACTIVE" -eq 1 && "$BOOTSTRAP_PHASE" != "full" ]]; then
  echo "Interactive mode requires --bootstrap-phase full." >&2
  exit 2
fi

OS="${AUTOLISP_OS:-$(uname -s || true)}"
IS_WINDOWS=0
case "$OS" in
  MINGW*|MSYS*|CYGWIN*) IS_WINDOWS=1 ;;
esac
IS_MACOS=0
case "$OS" in
  Darwin) IS_MACOS=1 ;;
esac

if [[ -z "${ENGINE}" ]]; then
  if [[ $IS_WINDOWS -eq 1 ]]; then
    if [[ -n "${AUTOCAD_EXE:-}" || -n "${AUTOCAD_ACCORECONSOLE:-}" ]] || compgen -G "/c/Program Files/Autodesk/*/accoreconsole.exe" >/dev/null; then
      ENGINE="autocad"
    elif [[ -n "${BRICSCAD_EXE:-}" ]] || compgen -G "/c/Program Files*/Bricsys/*/bricscad.exe" >/dev/null; then
      ENGINE="bricscad"
    else
      echo "No engine found. Use --autocad or --bricscad and set AUTOCAD_EXE / AUTOCAD_ACCORECONSOLE / BRICSCAD_EXE." >&2
      exit 3
    fi
  else
    ENGINE="bricscad"
  fi
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_AUTOLISP_WORKDIR="$SCRIPT_DIR/.autolisp-runs"
BASE_WORKDIR=""
CLEANUP_WORKDIR="${AUTOLISP_KEEP_WORKDIR:-0}"
AUTOLISP_VERBOSE="${AUTOLISP_VERBOSE:-0}"
AUTOLISP_QUIET="${AUTOLISP_QUIET:-0}"
INTERRUPTED=0
INTERRUPT_COUNT=0
MACOS_ASYNC=0
BRICSCAD_BRIDGE_MODE="direct"
BRICSCAD_COM_ATTACHED=0
BRICSCAD_COM_CREATED=0
BRICSCAD_COM_MODE="${BRICSCAD_COM_MODE:-auto}"
BRICSCAD_MACOS_EFFECTIVE_MODE=""
BRICSCAD_BATCH_PID=""
BRICSCAD_BATCH_CHILD_PID=""
BRICSCAD_BATCH_LAUNCHED=0
BRICSCAD_BATCH_RC=""
BRICSCAD_BATCH_REAPED=0
BRICSCAD_BATCH_COMPLETED=0
BRICSCAD_BATCH_START_TS=0
BRICSCAD_BATCH_STARTUP_TIMEOUT_SECS="${AUTOLISP_BRICSCAD_BATCH_STARTUP_TIMEOUT:-15}"
BRICSCAD_BATCH_EXIT_TIMEOUT_SECS="${AUTOLISP_BRICSCAD_BATCH_EXIT_TIMEOUT:-10}"

case "$CAD_MODE" in
  automation)
    AUTOCAD_COM_MODE="$CAD_BACKEND"
    BRICSCAD_COM_MODE="$CAD_BACKEND"
    ;;
  batch)
    AUTOCAD_COM_MODE="off"
    BRICSCAD_COM_MODE="off"
    ;;
esac

if [[ "$EPURE_REQUESTED" == "1" && $IS_WINDOWS -eq 1 ]]; then
  if [[ "$ENGINE" == "bricscad" ]]; then
    BRICSCAD_COM_MODE="off"
  fi
  # AutoCAD: le pont COM applique le profil EPURE via
  # Preferences.Profiles.ActiveProfile ; pas de force-off ici.
fi

# Auto-detect AUTOCAD_EXE sous Windows si non defini. On prend l'install la
# plus recente (tri lexicographique decroissant) entre acad.exe (AutoCAD
# complet) et acadlt.exe (AutoCAD LT), avec preference au complet quand les
# deux existent.
if [[ $IS_WINDOWS -eq 1 && "$ENGINE" == "autocad" && -z "$AUTOCAD_EXE" ]]; then
  _autocad_candidate=""
  _autocad_candidate="$(ls -1 "/c/Program Files/Autodesk"/AutoCAD\ */acad.exe 2>/dev/null | sort -r | head -n 1 || true)"
  if [[ -z "$_autocad_candidate" ]]; then
    _autocad_candidate="$(ls -1 "/c/Program Files/Autodesk"/AutoCAD\ LT\ */acadlt.exe 2>/dev/null | sort -r | head -n 1 || true)"
  fi
  if [[ -n "$_autocad_candidate" && -f "$_autocad_candidate" ]]; then
    AUTOCAD_EXE="$_autocad_candidate"
  fi
  unset _autocad_candidate
