    tail -F -n 0 "$WORKDIR/debug.log" 2>/dev/null | while IFS= read -r line; do
      printf '[LISP-DEBUG] %s\n' "$line" >&3
    done
  ) &
  DEBUG_TAIL_PID=$!
  autolisp_debug "runtime debug tail started pid=$DEBUG_TAIL_PID -> $WORKDIR/debug.log"
}

stop_runtime_debug_tail() {
  [[ -n "$DEBUG_TAIL_PID" ]] || return 0
  kill "$DEBUG_TAIL_PID" 2>/dev/null || true
  DEBUG_TAIL_PID=""
