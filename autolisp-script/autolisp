  printf '%s' "$s"
}

to_abs_path() {
  local p="$1"
  local dir base
  dir="$(cd "$(dirname "$p")" && pwd)"
  base="$(basename "$p")"
  printf '%s/%s' "$dir" "$base"
}

to_lisp_path() {
  local p="$1"
  p="${p//\\//}"
  printf '%s' "$p"
}

to_windows_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$p"
  elif [[ "$p" =~ ^/([a-zA-Z])/(.*)$ ]]; then
    local drive rest
    drive="${BASH_REMATCH[1]}"
    rest="${BASH_REMATCH[2]}"
    rest="${rest//\//\\}"
    printf '%s:\\%s' "${drive^^}" "$rest"
  else
    printf '%s' "$p"
  fi
}

to_unix_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -u "$p"
  elif [[ "$p" =~ ^([A-Za-z]):\\(.*)$ ]]; then
    local drive rest
    drive="${BASH_REMATCH[1]}"
    rest="${BASH_REMATCH[2]//\\//}"
    printf '/%s/%s' "${drive,,}" "$rest"
  else
    printf '%s' "$p"
  fi
}

to_runtime_lisp_path() {
  local p="$1"
  if [[ $IS_WINDOWS -eq 1 ]]; then
    p="$(to_windows_path "$p")"
  fi
  to_lisp_path "$p"
}

escape_vbs_string() {
