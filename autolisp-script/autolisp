}

run_direct_unix_cli() {
  local exe="$1"
  [[ -n "$exe" && -f "$exe" ]] || return 3
  "$exe" /b "$RUNLSPFILE" >"$WORKDIR/direct-stdout.txt" 2>"$WORKDIR/direct-stderr.txt" || true
}

case "$ENGINE" in
  autocad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_autocad || true
    else
      if [[ -n "$AUTOCAD_EXE" ]]; then
        run_direct_unix_cli "$AUTOCAD_EXE" || run_macos_autocad_fallback || true
      else
        run_macos_autocad_fallback || true
      fi
    fi
    ;;
  bricscad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_bricscad || true
    else
      if [[ $IS_MACOS -eq 1 ]]; then
        case "$BRICSCAD_MACOS_EFFECTIVE_MODE" in
          batch)
            run_macos_bricscad_batch "$(find_macos_bricscad_cli || true)" || true
            ;;
          automation)
            run_macos_bricscad_fallback || true
            ;;
          *)
            echo "Unsupported BricsCAD macOS mode: ${BRICSCAD_MACOS_EFFECTIVE_MODE:-unset}" >&2
            ;;
        esac
      elif [[ -n "$BRICSCAD_EXE" ]]; then
        "$BRICSCAD_EXE" -b "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
      else
        echo "bricscad executable not found. Set BRICSCAD_EXE." >&2
        true
      fi
    fi
    ;;
  *)
    echo "Unknown engine: $ENGINE" >&2
    exit 2
    ;;
esac

if [[ "$MACOS_ASYNC" -eq 1 ]]; then
  if [[ -z "${AUTOLISP_KEEP_WORKDIR:-}" ]]; then
    CLEANUP_WORKDIR="1"
  fi
fi

wait_rc=0
if [[ "$USE_REMOTE_PROTOCOL" -eq 1 ]]; then
  if [[ "$INTERACTIVE" -eq 1 && "$USE_FOREGROUND_BATCH_PROTOCOL" -eq 1 ]]; then
    if ! wait_protocol_interactive_helper; then
      wait_rc=$?
    fi
  elif [[ "$INTERACTIVE" -eq 1 ]]; then
    run_protocol_interactive_repl
    exit $?
  elif ! run_protocol_noninteractive; then
    wait_rc=$?
  fi
elif [[ "$USE_BATCH_INTERACTIVE_REPL" -eq 1 ]]; then
  run_batch_interactive_repl
  exit $?
else
  if ! wait_for_status; then
    wait_rc=$?
  fi

  if [[ "$wait_rc" -eq 0 ]]; then
    if ! wait_for_batch_process_exit; then
      wait_rc=$?
    fi
  fi
fi

if [[ "$wait_rc" -ne 0 ]]; then
  kill_bricscad_batch_process || true
fi

stop_protocol_foreground_relay

if [[ "$INTERRUPTED" -eq 1 ]]; then
  exit 130
fi

if [[ "$USE_REMOTE_PROTOCOL" -eq 1 && "$INTERACTIVE" -eq 1 ]]; then
  if [[ "$wait_rc" -eq 124 ]]; then
    exit 124
  fi
  exit "$wait_rc"
fi

if [[ ! -f "${PROTOCOL_STREAM_MARKER:-}" && "$PROTOCOL_STREAMED_OUTPUT" -eq 0 ]]; then
  LOGFILE_FOUND="$(find_log_file)"
  SESSION_OUTPUT_FILE="$(find_session_output_file || true)"
  render_stdout "$OUTFILE" "$SESSION_OUTPUT_FILE" "$CLI_VERBOSE" || cat "$OUTFILE" || true
  cat "$ERRFILE" >&2 || true
fi

if [[ "$wait_rc" -eq 124 ]]; then
  exit 124
fi

STATUS="1"
if [[ -s "$STATUSFILE" ]]; then
  STATUS="$(awk 'NF{line=$0} END{print line}' "$STATUSFILE" | tr -d '[:space:]')"
fi
if ! [[ "$STATUS" =~ ^[0-9]+$ ]]; then
  summary="$(awk '/^TOTAL=/{line=$0} END{print line}' "$OUTFILE" 2>/dev/null || true)"
  if [[ -n "$summary" && "$summary" =~ FAIL=0[[:space:]]+ERROR=0$ ]]; then
    STATUS=0
  else
    STATUS=1
  fi
fi

exit "$STATUS"
