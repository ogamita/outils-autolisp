#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOU'
Usage:
  autolisp-v4 [--autocad|--bricscad] [--timeout N] { source.lsp | -x expression }... [--dwg file.dwg] [--main C:MAIN]

Examples:
  autolisp test.lsp
  autolisp lib1.lsp lib2.lsp --main C:RUN
  autolisp -x '(princ (+ 1 2))'
  autolisp init.lsp -x '(setq *x* 42)' test.lsp

Semantics:
  - Les éléments { source.lsp | -x expression } sont traités dans l'ordre.
  - Chaque source.lsp est chargé avec (load "...").
  - Chaque -x expression est évalué comme une forme AutoLISP.
  - Si au moins un fichier source.lsp est fourni, (${MAIN:-C:MAIN}) est appelé à la fin.

Outputs:
  stdout  -> contenu de OUTFILE
  stderr  -> contenu de ERRFILE
  exit    -> code lu dans STATUSFILE

Environment overrides:
  AUTOCAD_ACCORECONSOLE   Path to accoreconsole.exe (Windows)
  AUTOCAD_COM_MODE        auto | attach | launch | off   (Windows + AutoCAD only)
  AUTOCAD_EXE             Path to acad.exe / acadlt.exe  (Windows)
  BRICSCAD_EXE            Path to bricscad.exe      (Windows)
  AUTOLISP_DWG            Default DWG for AutoCAD Core Console if --dwg not provided
  BRICSCAD_COM_MODE       auto | attach | launch | off   (Windows + BricsCAD only)
  AUTOLISP_TIMEOUT        Legacy timeout override in seconds
  AUTOLISP_WAIT_SECS      wait timeout for async modes / COM bridge (default: 180)
  AUTOLISP_KEEP_WORKDIR   1 to keep temporary workdir
  AUTOLISP_VERBOSE        1 for extra diagnostics

Notes:
  - AutoCAD Core Console (accoreconsole.exe) est Windows-only dans la pratique.
  - Sous Windows + BricsCAD, le script peut utiliser un pont COM autonome généré dans le workdir.
  - Sous macOS, le fallback reste piloté par UI scripting et dépend des autorisations Accessibilité.
EOU
}

ENGINE=""
DWG=""
MAIN="C:MAIN"
TIMEOUT_SECS="${AUTOLISP_WAIT_SECS:-${AUTOLISP_TIMEOUT:-180}}"
AUTOCAD_COM_MODE="${AUTOCAD_COM_MODE:-auto}"
AUTOCAD_EXE="${AUTOCAD_EXE:-}"
BRICSCAD_EXE="${BRICSCAD_EXE:-}"

declare -a ACTION_KINDS=()
declare -a ACTION_VALUES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --autocad)
      ENGINE="autocad"
      shift
      ;;
    --bricscad)
      ENGINE="bricscad"
      shift
      ;;
    --timeout)
      if [[ $# -lt 2 ]]; then
        echo "Missing value after --timeout" >&2
        usage
        exit 2
      fi
      TIMEOUT_SECS="$2"
      shift 2
      ;;
    --dwg)
      DWG="${2:-}"
      shift 2
      ;;
    --main)
      MAIN="${2:-}"
      shift 2
      ;;
    -x)
      if [[ $# -lt 2 ]]; then
        echo "Missing expression after -x" >&2
        usage
        exit 2
      fi
      ACTION_KINDS+=("eval")
      ACTION_VALUES+=("$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        ACTION_KINDS+=("load")
        ACTION_VALUES+=("$1")
        shift
      done
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      ACTION_KINDS+=("load")
      ACTION_VALUES+=("$1")
      shift
      ;;
  esac
done

if [[ ${#ACTION_KINDS[@]} -eq 0 ]]; then
  echo "Missing input: provide at least one source.lsp or -x expression" >&2
  usage
  exit 2
fi

OS="$(uname -s || true)"
IS_WINDOWS=0
case "$OS" in
  MINGW*|MSYS*|CYGWIN*) IS_WINDOWS=1 ;;
esac

if [[ -z "${ENGINE}" ]]; then
  if [[ $IS_WINDOWS -eq 1 ]]; then
    if [[ -n "${AUTOCAD_EXE:-}" || -n "${AUTOCAD_ACCORECONSOLE:-}" ]] || compgen -G "/c/Program Files/Autodesk/*/accoreconsole.exe" >/dev/null; then
      ENGINE="autocad"
    elif [[ -n "${BRICSCAD_EXE:-}" ]] || compgen -G "/c/Program Files*/Bricsys/*/bricscad.exe" >/dev/null; then
      ENGINE="bricscad"
    else
      echo "No engine found. Use --autocad or --bricscad and set AUTOCAD_EXE / AUTOCAD_ACCORECONSOLE / BRICSCAD_EXE." >&2
      exit 3
    fi
  else
    ENGINE="bricscad"
  fi
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_AUTOLISP_WORKDIR="$SCRIPT_DIR/.autolisp-runs"
BASE_WORKDIR="${AUTOLISP_WORKDIR:-$DEFAULT_AUTOLISP_WORKDIR}"
mkdir -p "$BASE_WORKDIR"
WORKDIR="$(mktemp -d "$BASE_WORKDIR/autolisp.XXXXXX")"

CLEANUP_WORKDIR="${AUTOLISP_KEEP_WORKDIR:-0}"
AUTOLISP_VERBOSE="${AUTOLISP_VERBOSE:-0}"
INTERRUPTED=0
INTERRUPT_COUNT=0
MACOS_ASYNC=0
BRICSCAD_BRIDGE_MODE="direct"
BRICSCAD_COM_ATTACHED=0
BRICSCAD_COM_CREATED=0
BRICSCAD_COM_MODE="${BRICSCAD_COM_MODE:-auto}"

on_interrupt() {
  INTERRUPT_COUNT=$((INTERRUPT_COUNT + 1))
  if [[ "$INTERRUPT_COUNT" -ge 2 ]]; then
    CLEANUP_WORKDIR="1"
    echo "autolisp: second interrupt received; aborting now." >&2
    exit 130
  fi
  INTERRUPTED=1
  CLEANUP_WORKDIR="1"
  echo "autolisp: interrupt requested; keeping workdir and finishing current handshake..." >&2
}

cleanup_workdir() {
  if [[ "${CLEANUP_WORKDIR}" != "1" ]]; then
    rm -rf "$WORKDIR"
  else
    if [[ "$AUTOLISP_VERBOSE" == "1" || "$INTERRUPTED" == "1" ]]; then
      echo "autolisp: keeping workdir: $WORKDIR" >&2
    fi
  fi
}
trap cleanup_workdir EXIT
trap on_interrupt INT TERM

OUTFILE="$WORKDIR/output.txt"
ERRFILE="$WORKDIR/errors.txt"
STATUSFILE="$WORKDIR/status.txt"
LOGDIR="$WORKDIR/logs"
: >"$OUTFILE"
: >"$ERRFILE"
echo "__PENDING__" >"$STATUSFILE"
mkdir -p "$LOGDIR"

escape_lisp_string() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

to_abs_path() {
  local p="$1"
  local dir base
  dir="$(cd "$(dirname "$p")" && pwd)"
  base="$(basename "$p")"
  printf '%s/%s' "$dir" "$base"
}

to_lisp_path() {
  local p="$1"
  p="${p//\\//}"
  printf '%s' "$p"
}

to_windows_path() {
  local p="$1"
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$p"
  else
    printf '%s' "$p"
  fi
}

find_log_file() {
  local f
  f="$(
    find "$LOGDIR" -maxdepth 1 -type f \( -name '*.log' -o -name '*.txt' \) 2>/dev/null \
      | awk 'NF' \
      | while read -r x; do
          ts=$(stat -f '%m' "$x" 2>/dev/null || stat -c '%Y' "$x" 2>/dev/null || echo 0)
          printf '%s\t%s\n' "$ts" "$x"
        done \
      | sort -nr \
      | awk 'NR==1{print $2}'
  )"
  printf '%s\n' "$f"
}

replay_from_log() {
  local logf="$1"
  [[ -n "$logf" && -f "$logf" ]] || return 0

  awk '
  BEGIN { inblock = 0; saw_output = 0 }
  /^<<<AUTOLISP-BEGIN:/ {
    kind = $0
    sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("> [%s %s]\n", a[1], a[2])
    inblock = 1
    saw_output = 0
    next
  }
  /^<<<AUTOLISP-END:/ {
    kind = $0
    sub(/^<<<AUTOLISP-END:/, "", kind)
    sub(/>>>$/, "", kind)
    split(kind, a, ":")
    printf("=> rc=%s\n", a[3])
    inblock = 0
    next
  }
  {
    if (!inblock) next
    if ($0 ~ /^[[:space:]]*$/) next
    if (!saw_output) {
      print "OUTPUT"
      saw_output = 1
    }
    print
  }
  ' "$logf"
}

find_session_output_file() {
  local candidate

  candidate="$(find_log_file)"
  if [[ -n "$candidate" && -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
    printf '%s\n' "$candidate"
    return 0
  fi

  for candidate in \
    "$WORKDIR/direct-stdout.txt" \
    "$WORKDIR/bricscad-stdout.txt" \
    "$WORKDIR/autocad-stdout.txt"
  do
    if [[ -f "$candidate" ]] && grep -q '^<<<AUTOLISP-BEGIN:' "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

render_stdout() {
  local outfile="$1"
  local sessionfile="${2:-}"

  awk -v sessionfile="$sessionfile" '
  function flush_output(    n, arr, i) {
    if (pending_output == "") return
    print "OUTPUT"
    n = split(pending_output, arr, "\n")
    for (i = 1; i <= n; i++) {
      if (arr[i] != "") print arr[i]
    }
    pending_output = ""
  }
  BEGIN {
    action_idx = 0
    pending_output = ""

    if (sessionfile != "") {
      inblock = 0
      while ((getline line < sessionfile) > 0) {
        if (line ~ /^<<<AUTOLISP-BEGIN:/) {
          kind = line
          sub(/^<<<AUTOLISP-BEGIN:/, "", kind)
          sub(/>>>$/, "", kind)
          split(kind, a, ":")
          block_key = a[1] ":" a[2]
          block_lines[block_key] = ""
          inblock = 1
          continue
        }
        if (line ~ /^<<<AUTOLISP-END:/) {
          inblock = 0
          block_key = ""
          continue
        }
        if (!inblock) continue
        if (line ~ /^[[:space:]]*$/) continue
        block_lines[block_key] = block_lines[block_key] line "\n"
      }
      close(sessionfile)
    }
  }
  /^LOAD / {
    action_idx++
    pending_output = block_lines["LOAD:" action_idx]
    print
    next
  }
  /^EVAL / {
    action_idx++
    pending_output = block_lines["EXPR:" action_idx]
    print
    next
  }
  /^MAIN / {
    action_idx++
    pending_output = block_lines["MAIN:" action_idx]
    print
    next
  }
  /^LOADED / || /^RESULT / || /^MAIN-RESULT / {
    flush_output()
    print
    next
  }
  {
    print
  }
  END {
    flush_output()
  }
  ' "$outfile"
}

declare -a SEARCH_DIRS=()
declare -a LOAD_PATHS=()
HAS_LOAD_ACTION=0

for i in "${!ACTION_KINDS[@]}"; do
  kind="${ACTION_KINDS[$i]}"
  value="${ACTION_VALUES[$i]}"
  if [[ "$kind" == "load" ]]; then
    if [[ ! -f "$value" ]]; then
      echo "Not found: $value" >&2
      exit 2
    fi
    abs_src="$(to_abs_path "$value")"
    abs_src="$(to_lisp_path "$abs_src")"
    abs_dir="$(dirname "$abs_src")"
    LOAD_PATHS+=("$abs_src")
    HAS_LOAD_ACTION=1

    already_present=0
    for existing in "${SEARCH_DIRS[@]:-}"; do
      if [[ "$existing" == "$abs_dir" ]]; then
        already_present=1
        break
      fi
    done
    if [[ $already_present -eq 0 ]]; then
      SEARCH_DIRS+=("$abs_dir")
    fi
  else
    LOAD_PATHS+=("")
  fi
done

QUIT_ON_FINISH=1
if [[ "$ENGINE" == "bricscad" && $IS_WINDOWS -eq 1 && "$BRICSCAD_COM_MODE" != "off" ]]; then
  if [[ "$BRICSCAD_COM_MODE" == "attach" ]]; then
    QUIT_ON_FINISH=0
  fi
fi

RUNLSPFILE="$WORKDIR/run-common.lsp"
{
  echo '(setq _autolisp_old_srchpath (getvar "SRCHPATH"))'
  if [[ ${#SEARCH_DIRS[@]} -gt 0 ]]; then
    srch_prefix=""
    for dir in "${SEARCH_DIRS[@]}"; do
      srch_prefix+="$(escape_lisp_string "$dir");"
    done
    printf '(setvar "SRCHPATH" (strcat "%s" _autolisp_old_srchpath))\n' "$srch_prefix"
  fi
  printf '(setq *AUTOLISP_OUTFILE* "%s")\n' "$(escape_lisp_string "$OUTFILE")"
  printf '(setq *AUTOLISP_ERRFILE* "%s")\n' "$(escape_lisp_string "$ERRFILE")"
  printf '(setq *AUTOLISP_STATUSFILE* "%s")\n' "$(escape_lisp_string "$STATUSFILE")"
  printf '(setq *AUTOLISP_LOGDIR* "%s")\n' "$(escape_lisp_string "$LOGDIR")"
  printf '(setq *AUTOLISP_LOGNAME* "%s")\n' "autolisp-session.log"
  printf '(setq *AUTOLISP_QUIT_ON_FINISH* %s)\n' "$QUIT_ON_FINISH"
  cat <<'EOLISP'
(defun autolisp-write-line (path text / f)
  (setq f (open path "a"))
  (if f
    (progn
      (write-line text f)
      (close f))))

(defun autolisp-reset-file (path / f)
  (setq f (open path "w"))
  (if f (close f)))

(defun autolisp-str (obj)
  (vl-princ-to-string obj))

(defun autolisp-set-status (code / f)
  (setq f (open *AUTOLISP_STATUSFILE* "w"))
  (if f
    (progn
      (write-line (itoa code) f)
      (close f)))
  code)

(defun autolisp-log-out (text)
  (autolisp-write-line *AUTOLISP_OUTFILE* text))

(defun autolisp-log-err (text)
  (autolisp-write-line *AUTOLISP_ERRFILE* text))

(defun autolisp-emit (s)
  (princ s)
  (princ))

(defun autolisp-mark-begin (kind idx)
  (autolisp-emit (strcat "\n<<<AUTOLISP-BEGIN:" kind ":" (itoa idx) ">>>\n")))

(defun autolisp-mark-end (kind idx rc)
  (autolisp-emit (strcat "\n<<<AUTOLISP-END:" kind ":" (itoa idx) ":" (itoa rc) ">>>\n")))

(defun autolisp-safe-getvar (name / r)
  (setq r (vl-catch-all-apply 'getvar (list name)))
  (if (vl-catch-all-error-p r) nil r))

(defun autolisp-safe-setvar (name value / r)
  (setq r (vl-catch-all-apply 'setvar (list name value)))
  (if (vl-catch-all-error-p r) nil T))

(defun autolisp-log-setup (/ old-mode old-path old-name)
  (setq old-mode (autolisp-safe-getvar "LOGFILEMODE"))
  (setq old-path (autolisp-safe-getvar "LOGFILEPATH"))
  (setq old-name (autolisp-safe-getvar "LOGFILENAME"))
  (autolisp-safe-setvar "LOGFILEPATH" *AUTOLISP_LOGDIR*)
  (if *AUTOLISP_LOGNAME*
    (autolisp-safe-setvar "LOGFILENAME" *AUTOLISP_LOGNAME*))
  (autolisp-safe-setvar "LOGFILEMODE" 1)
  (list old-mode old-path old-name))

(defun autolisp-log-restore (state / old-mode old-path old-name)
  (if state
    (progn
      (setq old-mode (nth 0 state))
      (setq old-path (nth 1 state))
      (setq old-name (nth 2 state))
      (if old-path (autolisp-safe-setvar "LOGFILEPATH" old-path))
      (if old-name (autolisp-safe-setvar "LOGFILENAME" old-name))
      (if old-mode (autolisp-safe-setvar "LOGFILEMODE" old-mode)))))

(defun autolisp-finish (code)
  (if *AUTOLISP_LOG_STATE*
    (autolisp-log-restore *AUTOLISP_LOG_STATE*))
  (if _autolisp_old_srchpath
    (setvar "SRCHPATH" _autolisp_old_srchpath))
  (autolisp-set-status code)
  (if *AUTOLISP_QUIT_ON_FINISH*
    (quit))
  code)

(defun autolisp-run-load (idx path / r)
  (autolisp-mark-begin "LOAD" idx)
  (autolisp-log-out (strcat "LOAD " path))
  (setq r (vl-catch-all-apply 'load (list path)))
  (if (vl-catch-all-error-p r)
    (progn
      (autolisp-log-err (strcat "ERROR load " path ": " (vl-catch-all-error-message r)))
      (autolisp-mark-end "LOAD" idx 1)
      nil)
    (progn
      (autolisp-log-out (strcat "LOADED " path))
      (autolisp-mark-end "LOAD" idx 0)
      T)))

(defun autolisp-run-eval (idx form-text / form-read r)
  (autolisp-mark-begin "EXPR" idx)
  (autolisp-log-out (strcat "EVAL " form-text))
  (setq form-read (vl-catch-all-apply 'read (list form-text)))
  (if (vl-catch-all-error-p form-read)
    (progn
      (autolisp-log-err (strcat "ERROR read " form-text ": " (vl-catch-all-error-message form-read)))
      (autolisp-mark-end "EXPR" idx 1)
      nil)
    (progn
      (setq r (vl-catch-all-apply 'eval (list form-read)))
      (if (vl-catch-all-error-p r)
        (progn
          (autolisp-log-err (strcat "ERROR eval " form-text ": " (vl-catch-all-error-message r)))
          (autolisp-mark-end "EXPR" idx 1)
          nil)
        (progn
          (autolisp-log-out (strcat "RESULT " (autolisp-str r)))
          (autolisp-mark-end "EXPR" idx 0)
          T)))))

(defun autolisp-run-main (idx main-name / sym-read r)
  (autolisp-mark-begin "MAIN" idx)
  (autolisp-log-out (strcat "MAIN " main-name))
  (setq sym-read (vl-catch-all-apply 'read (list main-name)))
  (if (vl-catch-all-error-p sym-read)
    (progn
      (autolisp-log-err (strcat "ERROR read-main " main-name ": " (vl-catch-all-error-message sym-read)))
      (autolisp-mark-end "MAIN" idx 1)
      nil)
    (progn
      (setq r (vl-catch-all-apply sym-read '()))
      (if (vl-catch-all-error-p r)
        (progn
          (autolisp-log-err (strcat "ERROR main " main-name ": " (vl-catch-all-error-message r)))
          (autolisp-mark-end "MAIN" idx 1)
          nil)
        (progn
          (autolisp-log-out (strcat "MAIN-RESULT " (autolisp-str r)))
          (autolisp-mark-end "MAIN" idx 0)
          T)))))

(setq *AUTOLISP_TOTAL* 0)
(setq *AUTOLISP_OK* 0)
(setq *AUTOLISP_FAIL* 0)
(setq *AUTOLISP_ERROR* 0)

(defun autolisp-note-ok ()
  (setq *AUTOLISP_TOTAL* (+ *AUTOLISP_TOTAL* 1))
  (setq *AUTOLISP_OK* (+ *AUTOLISP_OK* 1)))

(defun autolisp-note-fail ()
  (setq *AUTOLISP_TOTAL* (+ *AUTOLISP_TOTAL* 1))
  (setq *AUTOLISP_FAIL* (+ *AUTOLISP_FAIL* 1)))

(defun autolisp-summary-line ()
  (strcat "TOTAL=" (itoa *AUTOLISP_TOTAL*)
          " OK=" (itoa *AUTOLISP_OK*)
          " FAIL=" (itoa *AUTOLISP_FAIL*)
          " ERROR=" (itoa *AUTOLISP_ERROR*)))

(autolisp-reset-file *AUTOLISP_OUTFILE*)
(autolisp-reset-file *AUTOLISP_ERRFILE*)
(autolisp-set-status 99)
(setq *AUTOLISP_LOG_STATE* (autolisp-log-setup))
EOLISP

  for i in "${!ACTION_KINDS[@]}"; do
    kind="${ACTION_KINDS[$i]}"
    value="${ACTION_VALUES[$i]}"
    idx=$((i + 1))
    if [[ "$kind" == "load" ]]; then
      abs_src="${LOAD_PATHS[$i]}"
      printf '(if (autolisp-run-load %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' "$idx" "$(escape_lisp_string "$abs_src")"
    else
      printf '(if (autolisp-run-eval %s "%s") (autolisp-note-ok) (autolisp-note-fail))\n' "$idx" "$(escape_lisp_string "$value")"
    fi
  done

  if [[ "$HAS_LOAD_ACTION" -eq 1 ]]; then
    printf '(if (= *AUTOLISP_FAIL* 0) (if (autolisp-run-main %s "%s") (autolisp-note-ok) (autolisp-note-fail)))\n' "$(( ${#ACTION_KINDS[@]} + 1 ))" "$(escape_lisp_string "$MAIN")"
  fi

  cat <<'EOLISP'
(autolisp-log-out (autolisp-summary-line))
(if (> *AUTOLISP_FAIL* 0)
  (autolisp-finish 1)
  (autolisp-finish 0))
EOLISP
} >"$RUNLSPFILE"

SCRFILE="$WORKDIR/run.scr"
cat >"$SCRFILE" <<EOF2
(load "$(escape_lisp_string "$RUNLSPFILE")")
EOF2

export OUTFILE ERRFILE STATUSFILE

write_windows_autocad_vbs() {
  local vbs="$WORKDIR/bridge-autocad.vbs"
  local win_runlsp win_err win_exe
  win_runlsp="$(to_windows_path "$RUNLSPFILE")"
  win_err="$(to_windows_path "$ERRFILE")"
  win_exe="${AUTOCAD_EXE:-}"
  if [[ -n "$win_exe" ]]; then
    win_exe="$(to_windows_path "$win_exe")"
  fi

  cat >"$vbs" <<EOFVBS
Option Explicit
Dim fso, shell, mode, exePath, runLsp, errFile
Dim app, doc, cmd, progid, created, attached, rc
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")
mode = "${AUTOCAD_COM_MODE}"
exePath = "${win_exe//"/""}"
runLsp = "${win_runlsp//"/""}"
errFile = "${win_err//"/""}"
progid = "AutoCAD.Application"
created = False
attached = False
rc = 0

Sub AppendLine(path, text)
  Dim f
  Set f = fso.OpenTextFile(path, 8, True)
  f.WriteLine text
  f.Close
End Sub

Function AttachApp()
  On Error Resume Next
  Set AttachApp = GetObject(, progid)
  If Err.Number <> 0 Then
    Err.Clear
    Set AttachApp = Nothing
  End If
  On Error GoTo 0
End Function

Function CreateApp()
  On Error Resume Next
  If exePath <> "" Then
    shell.Environment("PROCESS")("AUTOCAD_LOCATION") = exePath
  End If
  Set CreateApp = CreateObject(progid)
  If Err.Number <> 0 Then
    Err.Clear
    Set CreateApp = Nothing
  End If
  On Error GoTo 0
End Function

If mode = "attach" Or mode = "auto" Then
  Set app = AttachApp()
  If Not app Is Nothing Then attached = True
End If

If app Is Nothing Then
  If mode = "attach" Then
    AppendLine errFile, "ERROR COM attach: no running AutoCAD instance found."
    WScript.Quit 2
  End If
  If mode = "launch" Or mode = "auto" Then
    Set app = CreateApp()
    If app Is Nothing Then
      AppendLine errFile, "ERROR COM launch: unable to create AutoCAD COM application."
      WScript.Quit 3
    End If
    created = True
  End If
End If

If app Is Nothing Then
  AppendLine errFile, "ERROR COM bridge: unsupported AutoCAD COM mode."
  WScript.Quit 4
End If

On Error Resume Next
app.Visible = True
If Err.Number <> 0 Then Err.Clear
Set doc = app.ActiveDocument
If Err.Number <> 0 Then
  Err.Clear
  Set doc = Nothing
End If
If doc Is Nothing Then
  Set doc = app.Documents.Add
  If Err.Number <> 0 Then
    AppendLine errFile, "ERROR COM bridge: unable to get or create AutoCAD ActiveDocument."
    Err.Clear
    WScript.Quit 5
  End If
End If
cmd = "(load """ & Replace(runLsp, "\", "/") & """) " & vbCr
Err.Clear
Call doc.SendCommand(cmd)
If Err.Number <> 0 Then
  AppendLine errFile, "ERROR COM bridge: AutoCAD SendCommand failed: " & Err.Description
  Err.Clear
  rc = 6
End If
On Error GoTo 0
WScript.Quit rc
EOFVBS
  printf '%s' "$vbs"
}

run_windows_autocad() {
  if [[ "$AUTOCAD_COM_MODE" != "off" ]]; then
    local cscript=""
    if command -v cscript >/dev/null 2>&1; then
      cscript="$(command -v cscript)"
    elif [[ -x /c/Windows/System32/cscript.exe ]]; then
      cscript="/c/Windows/System32/cscript.exe"
    fi
    if [[ -n "$cscript" ]]; then
      local vbs
      vbs="$(write_windows_autocad_vbs)"
      "$cscript" //nologo "$vbs" >"$WORKDIR/autocad-com-stdout.txt" 2>"$WORKDIR/autocad-com-stderr.txt" || true
      wait_for_status
      return 0
    fi
    echo "cscript.exe not found; falling back to direct AutoCAD launch." >&2
  fi

  if [[ -n "$AUTOCAD_EXE" && -f "$AUTOCAD_EXE" ]]; then
    "$AUTOCAD_EXE" /b "$RUNLSPFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
    return 0
  fi

  local acc="${AUTOCAD_ACCORECONSOLE:-}"
  if [[ -z "$acc" ]]; then
    acc="$(ls -1 "/c/Program Files/Autodesk"/*/accoreconsole.exe 2>/dev/null | head -n 1 || true)"
  fi
  local dwg="${DWG:-${AUTOLISP_DWG:-}}"
  if [[ -z "$acc" || ! -f "$acc" ]]; then
    echo "Neither AutoCAD COM/direct nor accoreconsole.exe is available. Set AUTOCAD_EXE or AUTOCAD_ACCORECONSOLE." >&2
    return 3
  fi
  if [[ -z "$dwg" || ! -f "$dwg" ]]; then
    echo "AutoCAD Core Console needs a DWG. Provide --dwg file.dwg or set AUTOLISP_DWG." >&2
    return 2
  fi

  "$acc" /i "$dwg" /s "$SCRFILE" >"$WORKDIR/autocad-stdout.txt" 2>"$WORKDIR/autocad-stderr.txt" || true
}

write_windows_bricscad_vbs() {
  local vbs="$WORKDIR/bridge-bricscad.vbs"
  local win_runlsp win_status win_out win_err win_exe mode
  win_runlsp="$(to_windows_path "$RUNLSPFILE")"
  win_status="$(to_windows_path "$STATUSFILE")"
  win_out="$(to_windows_path "$OUTFILE")"
  win_err="$(to_windows_path "$ERRFILE")"
  mode="$BRICSCAD_COM_MODE"
  win_exe="${BRICSCAD_EXE:-}"
  if [[ -n "$win_exe" ]]; then
    win_exe="$(to_windows_path "$win_exe")"
  fi

  cat >"$vbs" <<EOFVBS
Option Explicit
Dim fso, shell, mode, exePath, runLsp, statusFile, outFile, errFile
Dim app, doc, cmd, created, attached, rc
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")
mode = "${mode}"
exePath = "${win_exe//"/""}"
runLsp = "${win_runlsp//"/""}"
statusFile = "${win_status//"/""}"
outFile = "${win_out//"/""}"
errFile = "${win_err//"/""}"
created = False
attached = False
rc = 0

Sub AppendLine(path, text)
  Dim f
  Set f = fso.OpenTextFile(path, 8, True)
  f.WriteLine text
  f.Close
End Sub

Function TryGetApp()
  On Error Resume Next
  Set TryGetApp = GetObject(, "BricscadApp.AcadApplication")
  If Err.Number <> 0 Then
    Err.Clear
    Set TryGetApp = Nothing
  End If
  On Error GoTo 0
End Function

Function TryCreateApp()
  On Error Resume Next
  If exePath <> "" Then
    shell.Environment("PROCESS")("BRICSCAD_LOCATION") = exePath
  End If
  Set TryCreateApp = CreateObject("BricscadApp.AcadApplication")
  If Err.Number <> 0 Then
    Err.Clear
    Set TryCreateApp = Nothing
  End If
  On Error GoTo 0
End Function

Set app = Nothing
If mode = "attach" Or mode = "auto" Then
  Set app = TryGetApp()
  If Not app Is Nothing Then attached = True
End If

If app Is Nothing Then
  If mode = "attach" Then
    AppendLine errFile, "ERROR COM attach: no running BricsCAD instance found."
    rc = 2
    WScript.Echo "ATTACHED=0"
    WScript.Echo "CREATED=0"
    WScript.Quit rc
  End If
  If mode = "launch" Or mode = "auto" Then
    Set app = TryCreateApp()
    If app Is Nothing Then
      AppendLine errFile, "ERROR COM launch: unable to create BricsCAD COM application."
      rc = 3
      WScript.Echo "ATTACHED=0"
      WScript.Echo "CREATED=0"
      WScript.Quit rc
    End If
    created = True
  End If
End If

If app Is Nothing Then
  AppendLine errFile, "ERROR COM bridge: unsupported mode or COM unavailable."
  rc = 4
  WScript.Echo "ATTACHED=0"
  WScript.Echo "CREATED=0"
  WScript.Quit rc
End If

On Error Resume Next
app.Visible = True
If Err.Number <> 0 Then Err.Clear
Set doc = app.ActiveDocument
If Err.Number <> 0 Then
  Err.Clear
  Set doc = Nothing
End If
If doc Is Nothing Then
  Set doc = app.Documents.Add
  If Err.Number <> 0 Then
    AppendLine errFile, "ERROR COM bridge: unable to get or create ActiveDocument."
    Err.Clear
    rc = 5
    WScript.Echo "ATTACHED=" & CInt(attached)
    WScript.Echo "CREATED=" & CInt(created)
    WScript.Quit rc
  End If
End If
cmd = "(load """ & Replace(runLsp, "\", "/") & """) " & vbCr
Err.Clear
Call doc.SendCommand(cmd)
If Err.Number <> 0 Then
  AppendLine errFile, "ERROR COM bridge: SendCommand failed: " & Err.Description
  Err.Clear
  rc = 6
Else
  rc = 0
End If
On Error GoTo 0
WScript.Echo "ATTACHED=" & CInt(attached)
WScript.Echo "CREATED=" & CInt(created)
WScript.Quit rc
EOFVBS
  printf '%s' "$vbs"
}

wait_for_status() {
  local timeout="$TIMEOUT_SECS"
  while [[ "$timeout" -gt 0 ]]; do
    if [[ "$INTERRUPTED" -eq 1 ]]; then
      return 130
    fi
    local s
    s="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    if [[ -n "$s" && "$s" != "__PENDING__" && "$s" != "99" ]]; then
      return 0
    fi
    sleep 1
    timeout=$((timeout - 1))
  done
  echo "ERROR: timeout waiting for CAD runner completion after ${TIMEOUT_SECS}s" >&2
  if [[ "$ENGINE" == "bricscad" && $IS_WINDOWS -eq 0 && "$MACOS_ASYNC" -eq 1 ]]; then
    local status_trimmed has_output has_errors
    status_trimmed="$(tr -d '[:space:]' <"$STATUSFILE" 2>/dev/null || true)"
    has_output=0
    has_errors=0
    [[ -s "$OUTFILE" ]] && has_output=1
    [[ -s "$ERRFILE" ]] && has_errors=1
    if [[ "${status_trimmed:-}" == "__PENDING__" && "$has_output" -eq 0 && "$has_errors" -eq 0 ]]; then
      echo "HINT: on macOS + BricsCAD, select the \"2D Drafting\" workspace, not \"2D Drafting (Modern)\", then retry." >&2
    fi
  fi
  return 124
}

run_windows_bricscad() {
  local exe="${BRICSCAD_EXE:-}"
  if [[ -z "$exe" ]]; then
    exe="$(ls -1 "/c/Program Files"*/Bricsys/*/bricscad.exe 2>/dev/null | head -n 1 || true)"
  fi
  if [[ "$BRICSCAD_COM_MODE" != "off" ]]; then
    local cscript=""
    if command -v cscript >/dev/null 2>&1; then
      cscript="$(command -v cscript)"
    elif [[ -x /c/Windows/System32/cscript.exe ]]; then
      cscript="/c/Windows/System32/cscript.exe"
    fi
    if [[ -n "$cscript" ]]; then
      BRICSCAD_BRIDGE_MODE="com"
      [[ -n "$exe" ]] && export BRICSCAD_EXE="$exe"
      local vbs
      vbs="$(write_windows_bricscad_vbs)"
      "$cscript" //nologo "$vbs" >"$WORKDIR/bricscad-com-stdout.txt" 2>"$WORKDIR/bricscad-com-stderr.txt" || true
      if grep -q '^ATTACHED=1$' "$WORKDIR/bricscad-com-stdout.txt" 2>/dev/null; then
        BRICSCAD_COM_ATTACHED=1
      fi
      if grep -q '^CREATED=1$' "$WORKDIR/bricscad-com-stdout.txt" 2>/dev/null; then
        BRICSCAD_COM_CREATED=1
      fi
      wait_for_status
      return 0
    fi
    echo "cscript.exe not found; falling back to direct BricsCAD launch." >&2
  fi

  BRICSCAD_BRIDGE_MODE="direct"
  if [[ -z "$exe" || ! -f "$exe" ]]; then
    echo "bricscad.exe not found. Set BRICSCAD_EXE." >&2
    return 3
  fi
  "$exe" /B "$SCRFILE" >"$WORKDIR/bricscad-stdout.txt" 2>"$WORKDIR/bricscad-stderr.txt" || true
}

run_macos_bricscad_fallback() {
  local app=""
  app="$(ls -1d /Applications/BricsCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "BricsCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  local appname
  appname=$(basename "$app" .app)
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  /usr/bin/open -a "$app" >/dev/null 2>&1 || true
  /usr/bin/osascript - "$appname" "$lisp_cmd" <<'OSA' || true
on run argv
  set appName to item 1 of argv
  set lispCmd to item 2 of argv
  delay 1
  tell application "System Events"
    tell process appName
      set frontmost to true
    end tell
    key code 53
    key code 53
    delay 0.15
    keystroke lispCmd
    key code 36
  end tell
end run
OSA
}

run_macos_autocad_fallback() {
  local app=""
  app="$(ls -1d /Applications/Autodesk*/AutoCAD*.app 2>/dev/null | head -n 1 || true)"
  if [[ -z "$app" ]]; then
    echo "AutoCAD.app not found in /Applications (macOS fallback)." >&2
    return 3
  fi
  MACOS_ASYNC=1
  local lisp_cmd
  lisp_cmd="(load \"${RUNLSPFILE}\")"
  /usr/bin/open -a "$app" >/dev/null 2>&1 || true
  /usr/bin/osascript - "$lisp_cmd" <<'OSA' || true
on run argv
  set lispCmd to item 1 of argv
  delay 1
  tell application "System Events"
    tell process "AutoCAD"
      set frontmost to true
    end tell
    key code 53
    key code 53
    delay 0.15
    keystroke lispCmd
    key code 36
  end tell
end run
OSA
}

run_direct_unix_cli() {
  local exe="$1"
  [[ -n "$exe" && -f "$exe" ]] || return 3
  "$exe" /b "$RUNLSPFILE" >"$WORKDIR/direct-stdout.txt" 2>"$WORKDIR/direct-stderr.txt" || true
}

case "$ENGINE" in
  autocad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_autocad || true
    else
      if [[ -n "$AUTOCAD_EXE" ]]; then
        run_direct_unix_cli "$AUTOCAD_EXE" || run_macos_autocad_fallback || true
      else
        run_macos_autocad_fallback || true
      fi
    fi
    ;;
  bricscad)
    if [[ $IS_WINDOWS -eq 1 ]]; then
      run_windows_bricscad || true
    else
      if [[ -n "$BRICSCAD_EXE" ]]; then
        run_direct_unix_cli "$BRICSCAD_EXE" || run_macos_bricscad_fallback || true
      else
        run_macos_bricscad_fallback || true
      fi
    fi
    ;;
  *)
    echo "Unknown engine: $ENGINE" >&2
    exit 2
    ;;
esac

if [[ "$MACOS_ASYNC" -eq 1 ]]; then
  if [[ -z "${AUTOLISP_KEEP_WORKDIR:-}" ]]; then
    CLEANUP_WORKDIR="1"
  fi
fi

wait_rc=0
if ! wait_for_status; then
  wait_rc=$?
fi

if [[ "$INTERRUPTED" -eq 1 ]]; then
  exit 130
fi

LOGFILE_FOUND="$(find_log_file)"
SESSION_OUTPUT_FILE="$(find_session_output_file || true)"
render_stdout "$OUTFILE" "$SESSION_OUTPUT_FILE" || cat "$OUTFILE" || true
cat "$ERRFILE" >&2 || true

if [[ "$wait_rc" -eq 124 ]]; then
  exit 124
fi

STATUS="1"
if [[ -s "$STATUSFILE" ]]; then
  STATUS="$(awk 'NF{line=$0} END{print line}' "$STATUSFILE" | tr -d '[:space:]')"
fi
if ! [[ "$STATUS" =~ ^[0-9]+$ ]]; then
  summary="$(awk '/^TOTAL=/{line=$0} END{print line}' "$OUTFILE" 2>/dev/null || true)"
  if [[ -n "$summary" && "$summary" =~ FAIL=0[[:space:]]+ERROR=0$ ]]; then
    STATUS=0
  else
    STATUS=1
  fi
fi

exit "$STATUS"
