# Liste les PIDs des processus acad.exe actuellement vivants, un par
# ligne. Utilise tasklist en mode CSV sans en-tete pour fiabilite.
list_acad_pids_now() {
  MSYS_NO_PATHCONV=1 /c/Windows/System32/tasklist.exe \
      /FI "IMAGENAME eq acad.exe" /FO CSV /NH 2>/dev/null \
    | awk -F, '{gsub(/"/,"",$2); if ($2 ~ /^[0-9]+$/) print $2}' \
    | sort -u
}

# Snapshot des PIDs acad.exe a un instant donne, dans le fichier passe.
snapshot_acad_pids() {
  list_acad_pids_now >"$1" 2>/dev/null || : >"$1"
}

# Recalcule la difference entre les acad.exe vivants maintenant et le
# snapshot pris avant le lancement du pont COM. Le resultat (les
# instances que le pont a fait apparaitre) est ecrit dans
# WORKDIR/acad-com-pid.txt -- un PID par ligne. Le trap on_interrupt
# lit ce fichier pour cibler les kill.
update_com_launched_acad_pids() {
  [[ -n "${WORKDIR:-}" ]] || return 0
  local before="$WORKDIR/acad-pids-before.txt"
  local now="$WORKDIR/acad-pids-now.txt"
  local out="$WORKDIR/acad-com-pid.txt"
  [[ -f "$before" ]] || return 0
  list_acad_pids_now >"$now" 2>/dev/null || : >"$now"
  # Lignes presentes dans now mais absentes de before = nouvelles instances.
  comm -23 "$now" "$before" >"$out" 2>/dev/null || : >"$out"
}

# Tue le pont VBScript et toutes les instances acad.exe que ce pont a
# *lancees* (jamais une instance attachee de l'utilisateur).
# - cscript-pid.txt : pid du processus cscript que bash a lance en
#   arriere-plan. Tuer cscript libere la boucle de polling du wrapper.
# - acad-com-pid.txt : un PID par ligne, ecrit periodiquement par
#   update_com_launched_acad_pids comme difference entre les acad.exe
#   vivants maintenant et ceux presents AVANT le lancement de cscript.
#   En sortie normale (app.Quit reussi), cette difference redevient
#   vide. Le mode `attach` ne lance jamais de nouvelle instance, donc
#   cette fonction ne touche aucune instance que l'utilisateur a
#   ouverte lui-meme.
kill_autocad_com_process() {
  [[ -n "${WORKDIR:-}" ]] || return 0
  local cs_pidfile="$WORKDIR/cscript-pid.txt"
  local ac_pidfile="$WORKDIR/acad-com-pid.txt"
  local pid
  if [[ -f "$cs_pidfile" ]]; then
    pid="$(head -n 1 "$cs_pidfile" 2>/dev/null | tr -dc '0-9' || true)"
    if [[ -n "$pid" ]]; then
      autolisp_debug "killing cscript bridge PID=$pid"
      kill "$pid" 2>/dev/null || true
      MSYS_NO_PATHCONV=1 /c/Windows/System32/taskkill.exe /F /PID "$pid" >/dev/null 2>&1 || true
    fi
    rm -f "$cs_pidfile" 2>/dev/null || true
  fi
  if [[ -f "$ac_pidfile" ]]; then
    while IFS= read -r pid; do
      pid="$(printf '%s' "$pid" | tr -dc '0-9')"
      [[ -n "$pid" ]] || continue
      autolisp_debug "killing COM-launched acad.exe PID=$pid"
      MSYS_NO_PATHCONV=1 /c/Windows/System32/taskkill.exe /F /PID "$pid" >/dev/null 2>&1 || true
    done <"$ac_pidfile"
    rm -f "$ac_pidfile" 2>/dev/null || true
  fi
}

on_interrupt() {
  INTERRUPT_COUNT=$((INTERRUPT_COUNT + 1))
  if [[ "$INTERRUPT_COUNT" -ge 2 ]]; then
    CLEANUP_WORKDIR="1"
    kill_bricscad_batch_process || true
    kill_autocad_com_process || true
    echo "autolisp: second interrupt received; aborting now." >&2
    exit 130
  fi
  INTERRUPTED=1
  CLEANUP_WORKDIR="1"
  kill_bricscad_batch_process || true
  kill_autocad_com_process || true
  echo "autolisp: interrupt requested; keeping workdir and finishing current handshake..." >&2
}

cleanup_workdir() {
  stop_runtime_debug_tail
  if [[ "${CLEANUP_WORKDIR}" != "1" ]]; then
    rm -rf "$WORKDIR"
  else
    if ! autolisp_is_quiet && [[ "$INTERRUPTED" == "1" || "$FORCE_REPORT_WORKDIR" == "1" ]]; then
      echo "autolisp: keeping workdir: $WORKDIR" >&2
    fi
  fi
}
trap cleanup_workdir EXIT
trap on_interrupt INT TERM

reap_bricscad_batch_process() {
  local rc=0
  if [[ "$BRICSCAD_BATCH_LAUNCHED" -ne 1 || "$BRICSCAD_BATCH_REAPED" -eq 1 ]]; then
    return 0
  fi
  if [[ -z "$BRICSCAD_BATCH_CHILD_PID" ]]; then
    BRICSCAD_BATCH_REAPED=1
    return 0
  fi
  if wait "$BRICSCAD_BATCH_CHILD_PID" 2>/dev/null; then
    rc=0
  else
    rc=$?
    if [[ "$rc" -eq 127 ]]; then
      rc=0
    fi
  fi
  BRICSCAD_BATCH_RC="$rc"
  BRICSCAD_BATCH_REAPED=1
  return 0
}

