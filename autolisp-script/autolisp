# Pretty-print d'une ligne de commande pour les sondes [DEBUG run ...].
autolisp_debug_format_cmd() {
  local rendered=""
  local a
  for a in "$@"; do
    rendered+="$(printf '%q ' "$a")"
  done
  printf '%s' "${rendered% }"
}

# Stream en temps reel les messages emis par le runtime AutoLISP
# (autolisp-runtime-debug -> WORKDIR/debug.log). Actif seulement en
# mode --debug. Le tail est lance en background et stoppe a la fin.
DEBUG_TAIL_PID=""

start_runtime_debug_tail() {
  autolisp_is_debug || return 0
  [[ -n "${WORKDIR:-}" ]] || return 0
  : >"$WORKDIR/debug.log"
