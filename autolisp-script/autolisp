(defun autolisp-escape-string (text / idx len ch acc)
  (setq idx 1)
  (setq len (strlen text))
  (setq acc "")
  (while (<= idx len)
    (setq ch (substr text idx 1))
    (if (= ch "\\")
      (setq acc (strcat acc "\\\\"))
      (if (= ch "\"")
        (setq acc (strcat acc "\\\""))
        (setq acc (strcat acc ch))))
    (setq idx (+ idx 1)))
  acc)

(defun autolisp-readable-text (obj / acc first tail)
  (cond
    ((null obj)
     "nil")
    ((= (type obj) 'STR)
     (strcat "\"" (autolisp-escape-string obj) "\""))
    ((listp obj)
     (setq acc "(")
     (setq first T)
     (setq tail obj)
     (while tail
       (if first
         (setq first nil)
         (setq acc (strcat acc " ")))
       (setq acc (strcat acc (autolisp-readable-text (car tail))))
       (setq tail (cdr tail)))
     (strcat acc ")"))
    (T
     (autolisp-render obj))))

