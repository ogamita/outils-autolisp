# find_macos_bricscad_template : trouve un template DWT (ou DWG) que
# BricsCAD peut ouvrir au lancement, ce qui evite la boite de dialogue
# "Nouveau dessin" en mode batch (sans drawing argument, BricsCAD reste
# bloque a cette dialog et n'execute pas le -B script.scr).
#
# Ordre de recherche :
#   1. $AUTOLISP_BRICSCAD_TEMPLATE (override explicite)
#   2. $DWG si fourni via --dwg (compat AutoCAD core console)
#   3. ~/Library/Application Support/Bricsys/BricsCAD/V*/en_US/Templates/Default-mm.dwt
#   4. /Library/... idem (installation system-wide)
#
# Imprime le chemin trouve sur stdout, retourne 1 si rien trouve.
find_macos_bricscad_template() {
  local cand
  if [[ -n "${AUTOLISP_BRICSCAD_TEMPLATE:-}" && -f "${AUTOLISP_BRICSCAD_TEMPLATE}" ]]; then
    printf '%s\n' "$AUTOLISP_BRICSCAD_TEMPLATE"
    return 0
  fi
  if [[ -n "${DWG:-}" && -f "${DWG}" ]]; then
    printf '%s\n' "$DWG"
    return 0
  fi
  for cand in \
    "$HOME/Library/Application Support/Bricsys/BricsCAD/"*/en_US/Templates/Default-mm.dwt \
    "$HOME/Library/Application Support/Bricsys/BricsCAD/"*/en_US/Templates/Default-m.dwt \
    "$HOME/Library/Application Support/Bricsys/BricsCAD/"*/Templates/Default-mm.dwt \
    "$HOME/Library/Application Support/Bricsys/BricsCAD/"*/Templates/Default-m.dwt \
    "/Library/Application Support/Bricsys/BricsCAD/"*/en_US/Templates/Default-mm.dwt \
    "/Library/Application Support/Bricsys/BricsCAD/"*/en_US/Templates/Default-m.dwt ; do
    if [[ -f "$cand" ]]; then
      printf '%s\n' "$cand"
      return 0
    fi
  done
  return 1
}

find_macos_app_bundle_from_exe() {
  local exe="$1"
  if [[ "$exe" == *.app ]]; then
    printf '%s\n' "$exe"
    return 0
  fi
  if [[ "$exe" == */Contents/MacOS/* ]]; then
    printf '%s.app\n' "${exe%/Contents/MacOS/*}"
    return 0
  fi
  return 1
}

read_macos_bundle_version() {
  local bundle="$1"
  local plist="$bundle/Contents/Info.plist"
  [[ -f "$plist" ]] || return 1
  /usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' "$plist" 2>/dev/null || true
}

read_bricscad_runtime_info() {
  local product="" version="" program=""

  [[ -f "${AUTOLISP_PROTOCOL_INFOFILE:-}" ]] || return 1
  product="$(sed -n '1p' "$AUTOLISP_PROTOCOL_INFOFILE" 2>/dev/null || true)"
  version="$(sed -n '2p' "$AUTOLISP_PROTOCOL_INFOFILE" 2>/dev/null || true)"
  program="$(sed -n '3p' "$AUTOLISP_PROTOCOL_INFOFILE" 2>/dev/null || true)"
  if [[ -z "$product" && -z "$version" && -z "$program" ]]; then
    return 1
  fi
  printf '%s\t%s\t%s\n' "$product" "$version" "$program"
}

normalize_bricscad_version() {
  local raw="$1"
  local normalized=""

  normalized="$(printf '%s\n' "$raw" | awk '{ print $1; exit }')"
  if [[ -n "$normalized" ]]; then
    printf '%s\n' "$normalized"
    return 0
  fi
  [[ -n "$raw" ]] || return 1
  printf '%s\n' "$raw"
}

bricscad_version_for_exe() {
  local info=""
  local exe="$1"
  local bundle=""
  local version=""

  info="$(read_bricscad_runtime_info || true)"
  if [[ -n "$info" ]]; then
    version="$(printf '%s\n' "$info" | awk -F '\t' '{ print $2; exit }')"
    normalize_bricscad_version "$version"
    return $?
  fi
  bundle="$(find_macos_app_bundle_from_exe "$exe" || true)"
  if [[ -n "$bundle" ]]; then
    read_macos_bundle_version "$bundle"
    return 0
  fi
  return 1
}

bricscad_should_announce_launch() {
  local exe="$1"
  [[ "$ENGINE" == "bricscad" ]] || return 1
  autolisp_is_quiet && return 1
  return 0
}

emit_bricscad_launch_message() {
  local pid="$1"
  local exe="$2"
  local info=""
  local product="BricsCAD"
  local version=""
  local version_raw=""
  local program=""
  local msg=""

  bricscad_should_announce_launch "$exe" || return 0
  [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] || return 0

  info="$(read_bricscad_runtime_info || true)"
  if [[ -n "$info" ]]; then
    product="$(printf '%s\n' "$info" | awk -F '\t' '{ print $1; exit }')"
    version_raw="$(printf '%s\n' "$info" | awk -F '\t' '{ print $2; exit }')"
    version="$(normalize_bricscad_version "$version_raw" || true)"
    program="$(printf '%s\n' "$info" | awk -F '\t' '{ print $3; exit }')"
  else
    version="$(bricscad_version_for_exe "$exe" || true)"
  fi
  [[ -n "$product" ]] || product="BricsCAD"
  # Pas d'annonce sans version détectée: évite le bruit sur les exécutables
  # de test (fake-cad) qui ne portent ni runtime-info ni Info.plist exploitable.
  [[ -n "$version" ]] || return 0
  msg="$product $version"
  printf '%s\n' "$msg"
  if autolisp_is_verbose; then
    local extra="autolisp: launched $msg pid=$pid"
    if [[ -n "$version_raw" && "$version_raw" != "$version" ]]; then
      extra="$extra acadver=\"$version_raw\""
    fi
    if [[ -n "$program" ]]; then
      extra="$extra program=$program"
    fi
    extra="$extra profile=${BRICSCAD_MACOS_PROFILE:-default}"
    echo "$extra" >&2
  fi
}

launch_bricscad_announce_loop() {
  local exe="$1"
  local pid=""
  local tries=0

  bricscad_should_announce_launch "$exe" || return 0
  while [[ "$tries" -lt 300 ]]; do
    pid="$(find_bricscad_batch_pid || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && read_bricscad_runtime_info >/dev/null 2>&1; then
      emit_bricscad_launch_message "$pid" "$exe"
      return 0
    fi
    sleep 0.1
    tries=$((tries + 1))
  done
  return 0
}

start_bricscad_launch_announcer() {
  local exe="$1"
  bricscad_should_announce_launch "$exe" || return 0
  launch_bricscad_announce_loop "$exe" &
  BRICSCAD_LAUNCH_ANNOUNCER_PID=$!
}

stop_bricscad_launch_announcer() {
  [[ -n "$BRICSCAD_LAUNCH_ANNOUNCER_PID" ]] || return 0
  wait "$BRICSCAD_LAUNCH_ANNOUNCER_PID" 2>/dev/null || true
  BRICSCAD_LAUNCH_ANNOUNCER_PID=""
}

find_bricscad_batch_pid() {
  local pid

  pid="$(
    ps -axo pid=,command= 2>/dev/null \
      | awk -v scr="$SCRFILE" '
          index($0, scr) {
            sub(/^[[:space:]]+/, "", $0)
            split($0, fields, /[[:space:]]+/)
            print fields[1]
            exit
          }'
  )"
  if [[ "$pid" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$pid"
    return 0
  fi
  return 1
}

bricscad_batch_process_running() {
  local pid

  if [[ -n "$BRICSCAD_BATCH_PID" ]] && kill -0 "$BRICSCAD_BATCH_PID" 2>/dev/null; then
    return 0
  fi

  pid="$(find_bricscad_batch_pid || true)"
  if [[ "$pid" =~ ^[0-9]+$ ]]; then
    BRICSCAD_BATCH_PID="$pid"
    return 0
  fi

  return 1
}

macos_app_running() {
