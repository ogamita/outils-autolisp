         (signature . "(slide_image x1 y1 width height sldname)")
         (arguments . (("x1" . "Type: Integer\nX-offset from the upper-left corner of the tile, in pixels. Must be a positive value.")
                         ("y1" . "Type: Integer\nY-offset from the upper-left corner of the tile, in pixels. Must be a positive value.")
