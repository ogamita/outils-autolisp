         (guid . "GUID-D331A88A-9B6E-49C9-B745-D0A063F38FD2")))
    ("rem" .
        ((name . "rem")
         (title . "rem (AutoLISP)")
         (summary . "Divides the first number by the second, and returns the remainder")
         (source-kind . "AutoLISP")
         (alphabetic-group . "R")
         (feature-groups . ("Arithmetic"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(rem [number number ...])")
