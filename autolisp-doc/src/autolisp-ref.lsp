    ("textbox" .
        ((name . "textbox")
         (title . "textbox (AutoLISP)")
         (summary . "Measures a specified text object, and returns the diagonal coordinates of a box that encloses the text")
         (source-kind . "AutoLISP")
         (alphabetic-group . "T")
         (feature-groups . ("Geometric"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(textbox elist)")
         (arguments . (("elist" . "Type: List\nAn entity definition list defining a text object, in the format returned by entget.\nIf fields that define text parameters other than the text itself are omitted from elist, the current (or default) settings are used.\nThe minimum list accepted by textbox is that of the text itself.")))
         (return-values . "Type: List or nil\nA list of two points, if successful; otherwise nil.\nThe points returned by textbox describe the bounding box of the text object as if its insertion point is located at (0,0,0) and its rotation angle is 0. The first list returned is generally the point (0.0 0.0 0.0) unless the text object is oblique or vertical, or it contains letters with descenders (such as g and p). The value of the first point list specifies the offset from the text insertion point to the lower-left corner of the smallest rectangle enclosing the text. The second point list specifies the upper-right corner of that box. Regardless of the orientation of the text being measured, the point list returned always describes the lower-left and upper-right corners of this bounding box.")
         (release-information . nil)
         (history . nil)
         (examples . "The following command supplies the text and accepts the current defaults for the remaining parameters:\n\n(textbox '((1 . \"Hello world.\")))\n((0.000124126 -0.00823364 0.0) (3.03623 0.310345 0.0))")
         (url . "https://help.autodesk.com/cloudhelp/2023/ENU/AutoCAD-AutoLISP-Reference/files/GUID-D6C31C79-ECBF-4C7D-9285-1CFA95AC0918.htm")
         (guid . "GUID-D6C31C79-ECBF-4C7D-9285-1CFA95AC0918")))
