         (feature-groups . ("Memory Management"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(expand n-expand)")
         (arguments . (("n-expand" . "Type: Integer\nAn number indicating the amount of additional memory to be allocated. Memory is allocated as follows:\n- n-alloc\n- free symbols\n- n-alloc\n- free strings\n- n-alloc\n- free usubrs\n- n-alloc\n- free reals\n- n-alloc\n- *\n- n-expand\n- cons cells\nwhere n-alloc is the current segment size.")))
         (return-values . "Type: Integer\nA number indicating the number of free conses divided by n-alloc.")
         (release-information . nil)
         (history . nil)
         (examples . "Set the segment size to 100:\n\n(alloc 100)\n1000\n\nAllocate memory for two additional segments:\n\n(expand 2)\n82\n\nThis ensures that AutoLISP now has memory available for at least 200 additional symbols, strings, usubrs and reals each, and 8200 free conses.")
         (url . "https://help.autodesk.com/cloudhelp/2023/ENU/AutoCAD-AutoLISP-Reference/files/GUID-48C99C97-176D-4D9C-91E2-31B3C67D6EC9.htm")
