    ("fill_image" .
        ((name . "fill_image")
         (title . "fill_image (AutoLISP/DCL)")
         (summary . "Draws a filled rectangle in the currently active dialog box image tile")
         (source-kind . "AutoLISP/DCL")
         (alphabetic-group . "F")
         (feature-groups . ("Image Tile-Handling Functions Reference (AutoLISP/DCL)"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(fill_image x1 y1 width height color)")
         (arguments . (("x1" . "Type: Integer\nX coordinate of the upper-left corner of the rectangle located at (x1,y1). Must be a positive value.")
