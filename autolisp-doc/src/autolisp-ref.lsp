    ("osnap" .
        ((name . "osnap")
         (title . "osnap (AutoLISP)")
         (summary . "Returns a 3D point that is the result of applying an Object Snap mode to a specified point")
         (source-kind . "AutoLISP")
         (alphabetic-group . "O")
         (feature-groups . ("Geometric"))
