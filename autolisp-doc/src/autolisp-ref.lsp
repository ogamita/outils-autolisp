         (source-kind . "AutoLISP/DCL")
         (alphabetic-group . "N")
         (feature-groups . ("Dialog Box Opening and Closing Functions Reference (AutoLISP/DCL)"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(new_dialog dlgname dcl_id [action [screen-pt]])")
         (arguments . (("dlgname" . "Type: String\nDialog box.")
                         ("dcl_id" . "Type: Integer\nThe DCL file identifier obtained by load_dialog.")
