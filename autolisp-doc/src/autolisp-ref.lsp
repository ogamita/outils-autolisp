         (signature . "(angtos angle [unit [precision]])")
         (arguments . (("angle" . "Type: Integer or Real\nA number, in radians.")
                         ("unit" . "Type: Integer\nAn integer that specifies the angular units. If unit is omitted, angtos uses the current value of the AutoCAD AUNITS system variable. The following units may be specified:\n0 -- Degrees\n1 -- Degrees/minutes/seconds\n2 -- Grads\n3 -- Radians\n4 -- Surveyor's units")
                         ("precision" . "Type: Integer\nSpecifies the number of decimal places of precision to be returned. If omitted, angtos uses the current setting of the AutoCAD AUPREC system variable.")))
         (return-values . "Type: String or nil\nA string, if successful; otherwise nil.")
         (release-information . nil)
         (history . nil)
         (examples . "(angtos 0.785398 0 4)\n\"45.0000\"\n\n(angtos -0.785398 0 4)\n\"315.0000\"\n\n(angtos -0.785398 4)\n\"S 45d E\"")
         (url . "https://help.autodesk.com/cloudhelp/2023/ENU/AutoCAD-AutoLISP-Reference/files/GUID-C2D277B4-2F59-423F-9C56-E5A1DEFE0CCE.htm")
