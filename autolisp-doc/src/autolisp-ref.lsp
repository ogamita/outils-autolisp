    ("angtof" .
        ((name . "angtof")
         (title . "angtof (AutoLISP)")
         (summary . "Converts a string representing an angle into a real (floating-point) value in radians")
         (source-kind . "AutoLISP")
         (alphabetic-group . "A")
         (feature-groups . ("Conversion"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(angtof string [units])")
         (arguments . (("string" . "Type: String\nFormatted angular string that angtof can parse correctly to the specified unit. It can be in the same form that angtos returns, or in a form that AutoCAD allows for keyboard entry.")
                         ("units" . "Type: Integer\nSpecifies the units in which the string is formatted. The value should correspond to values allowed for the AutoCAD AUNITS system variable. If unit is omitted, angtof uses the current value of AUNITS. The following units may be specified:\n0 -- Degrees\n1 -- Degrees/minutes/seconds\n2 -- Grads\n3 -- Radians\n4 -- Surveyor's units")))
         (return-values . "Type: Real\nA real value, if successful; otherwise nil.\nThe angtof and angtos functions are complementary: if you pass angtof a string created by angtos, angtof is guaranteed to return a valid value, and vice versa (assuming the unit values match).")
         (release-information . nil)
         (history . nil)
         (examples . "(angtof \"45.0000\")\n0.785398\n\n(angtof \"45.0000\" 3)\n1.0177")
         (url . "https://help.autodesk.com/cloudhelp/2023/ENU/AutoCAD-AutoLISP-Reference/files/GUID-9DE9200B-F27E-4BB6-8AE6-BC5C8A64A527.htm")
         (guid . "GUID-9DE9200B-F27E-4BB6-8AE6-BC5C8A64A527")))
    ("angtos" .
