    ("boole" .
        ((name . "boole")
         (title . "boole (AutoLISP)")
         (summary . "Serves as a general bitwise Boolean function")
         (source-kind . "AutoLISP")
         (alphabetic-group . "B")
         (feature-groups . ("Equality and Conditional"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(boole operator int1 [int2 ...])")
         (arguments . (("operator" . "Type: Integer\nAn integer between 0 and 15 representing one of the 16 possible Boolean functions in two variables.")
                         ("int1, int2..." . "Type: Integer\nA numeric value.\nNote: boole will accept a single integer argument, but the result is unpredictable.")))
         (return-values . "Type: Integer\nA numeric value.")
         (release-information . nil)
