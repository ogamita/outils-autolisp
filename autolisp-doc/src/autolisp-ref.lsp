         (signature . "(arxunload application [onfailure])")
         (arguments . (("application" . "Type: String\nA quoted string or a variable that contains the name of a file that was loaded with the arxload function. You can omit the extension from the file name; .arx (Windows) or .bundle (Mac OS).")
                         ("onfailure" . "Type: String\nAn expression to be executed if the unload fails.")))
         (return-values . "Type: String\nThe application name, if successful. If unsuccessful and the onfailure argument is supplied, arxunload returns the value of this argument; otherwise, failure results in an error message.\nNote that locked ObjectARX applications cannot be unloaded. ObjectARX applications are locked by default.")
         (release-information . nil)
