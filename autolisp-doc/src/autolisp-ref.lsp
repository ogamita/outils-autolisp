         (guid . "GUID-4A4DCECD-E85A-4860-A58F-56B48227857F")))
    ("regapp" .
        ((name . "regapp")
         (title . "regapp (AutoLISP)")
         (summary . "Registers an application name with the current AutoCAD drawing in preparation for using extended object data")
         (source-kind . "AutoLISP")
         (alphabetic-group . "R")
         (feature-groups . ("Extended Data-Handling"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(regapp application)")
         (arguments . (("application" . "Type: String\nApplication name. The name must be a valid symbol table name.")))
         (return-values . "Type: String\nIf an application of the same name has already been registered, this function returns nil; otherwise it returns the name of the application.\nIf registered successfully, the application name is entered into the APPID symbol table. This table maintains a list of the applications that are using extended data in the drawing.")
         (release-information . nil)
