         (summary . "Displays the AutoCAD color selection dialog box with tabs for index color, true color, and color books")
         (source-kind . "AutoLISP")
         (alphabetic-group . "A")
         (feature-groups . nil)
         (supported-platforms . "Windows and Mac OS")
         (signature . "(acad_truecolordlg color [allowbylayer] [currentlayercolor])")
