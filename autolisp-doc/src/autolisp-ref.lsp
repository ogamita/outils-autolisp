                         ("list-or-atom" . "Type: Integer, Real, String, List, or T\nA list or an atom.")))
         (return-values . "Type: List\nThe value returned depends on the data type of list-or-atom. If list-or-atom is a list, cons returns that list with new-first-element added as the first item in the list. If list-or-atom is an atom, cons returns a dotted pair consisting of new-first-element and list-or-atom.")
         (release-information . nil)
