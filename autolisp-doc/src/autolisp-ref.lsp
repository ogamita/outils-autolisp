    ("grdraw" .
        ((name . "grdraw")
         (title . "grdraw (AutoLISP)")
         (summary . "Draws a vector between two points, in the current viewport")
         (source-kind . "AutoLISP")
         (alphabetic-group . "G")
         (feature-groups . ("Display Control"))
         (supported-platforms . "Windows and Mac OS")
         (signature . "(grdraw from to color [highlight])")
         (arguments . (("from" . "Type: List\n2D or 3D points (lists of two or three reals) specifying one endpoint of the vector in terms of the current UCS. AutoCAD clips the vector to fit the screen.")
                         ("to" . "Type: List\n2D or 3D points (lists of two or three reals) specifying the other endpoint of the vector in terms of the current UCS. AutoCAD clips the vector to fit the screen.")
                         ("color" . "Type: Integer\nColor used to draw the vector. A -1 signifies XOR ink, which complements anything it draws over and which erases itself when overdrawn.")
                         ("highlight" . "Type: Integer\nOther than zero, indicates that the vector is to be drawn using the default highlighting method of the display device (usually dashed).\nIf highlight is omitted or is zero, grdraw uses the normal display mode.")))
         (return-values . "Type: nil\nAlways returns nil.")
         (release-information . nil)
         (history . nil)
         (examples . "N/A")
