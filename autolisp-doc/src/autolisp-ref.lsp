         (examples . "Windows\n\n(vl-filename-base \"c:\\\\acadwin\\\\acad.exe\")\n\"ACAD\"\n\n(vl-filename-base \"c:\\\\acadwin\")\n\"ACADWIN\"\n\nMac OS\n\n(vl-filename-base \"/myutilities/lsp/utilities.lsp\")\n\"utilities\"\n\n(vl-filename-base \"/myutilities/support\")\n\"support\"")
