         (release-information . nil)
         (history . nil)
         (examples . "(setq al '((name box) (width 3) (size 4.7263) (depth 5)))\n((NAME BOX) (WIDTH 3) (SIZE 4.7263) (DEPTH 5))\n\n(assoc 'size al)\n(SIZE 4.7263)\n\n(assoc 'weight al)\nnil")
